$env:CARGO_HOME = 'E:\Dev\.cargo'
$env:CARGO_TARGET_DIR = 'E:\civis-target'
Set-Location 'C:\Users\koosh\.claude\lanes\substrate-feat-cloud-dispatch'

$outputFile = Join-Path (Get-Location) 'build_output.txt'

# Run cargo check and capture output
$result = cargo check -p substrate-core -p cloud-cursor -p cloud-kilo -p cloud-codex -p cloud-dispatch-conformance -p driver-cli 2>&1

# Write output to file
$result | Out-File -FilePath $outputFile -Encoding utf8

# Write exit code
"EXIT_CODE=$LASTEXITCODE" | Out-File -FilePath $outputFile -Encoding utf8 -Append
"FINISHED_AT=$(Get-Date)" | Out-File -FilePath $outputFile -Encoding utf8 -Append
