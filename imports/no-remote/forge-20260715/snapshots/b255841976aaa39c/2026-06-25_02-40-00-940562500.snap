#!/usr/bin/env python3
"""Registry accuracy sweep — diff GitHub repo list vs ECOSYSTEM_MAP.md."""
import json, re, subprocess, sys

# Re-fetch GitHub repo list directly via gh
result = subprocess.run(
    ["gh", "repo", "list", "KooshaPari", "--limit", "300",
     "--json", "name,description,isArchived,primaryLanguage,pushedAt,isFork"],
    capture_output=True
)
if result.returncode != 0:
    print("gh repo list failed:", result.stderr.decode("utf-8", errors="replace"), file=sys.stderr)
    sys.exit(1)

all_repos = json.loads(result.stdout.decode("utf-8", errors="replace"))
gh_names = {r["name"] for r in all_repos}
print(f"Total KooshaPari repos on GitHub: {len(gh_names)}", file=sys.stderr)

with open(r"C:\Users\koosh\infra-research\phenotype-registry\ECOSYSTEM_MAP.md",
          "r", encoding="utf-8") as f:
    eco = f.read()

mentioned = set()
for m in re.finditer(r"KooshaPari/([A-Za-z0-9._\-]+)", eco):
    mentioned.add(m.group(1))

for m in re.finditer(r"\*\*([A-Z][A-Za-z0-9._\-]+)\*\*", eco):
    name = m.group(1)
    if name in gh_names:
        mentioned.add(name)

unknown = sorted(gh_names - mentioned)
print(f"\n=== UNKNOWN (live on GitHub, NOT in ECOSYSTEM_MAP.md): {len(unknown)} ===",
      file=sys.stderr)
for n in unknown:
    print(f"  {n}", file=sys.stderr)
    print(n)

# Also emit a CSV with full metadata
print("\n=== FULL UNKNOWN WITH METADATA ===", file=sys.stderr)
unknown_set = set(unknown)
for r in all_repos:
    if r["name"] in unknown_set:
        print(f"{r['name']},{r.get('primaryLanguage', '')},{r.get('isArchived', False)},{(r.get('pushedAt') or '')[:10]},{r.get('description', '').replace(',', ';')}")
