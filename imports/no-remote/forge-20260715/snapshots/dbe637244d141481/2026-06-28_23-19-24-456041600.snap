@echo off
REM ============================================================================
REM  omniroute-dev.cmd - thin wrapper around the OmniRoute-fresh2 checkout
REM
REM  Source of truth: C:\Users\koosh\OmniRoute-fresh2 (single source + runtime)
REM  Strategy: just delegate to bin/omniroute.mjs in the fork. No tarball, no
REM            bun-global install, no file-sync step, no second copy of code.
REM
REM  Workflow:
REM    omniroute-dev pull         git pull + bun install in the fork
REM    omniroute-dev <subcmd>     runs bin/omniroute.mjs with <subcmd>
REM
REM  Update flow (one command, no separate "sync" step):
REM    1. edit code in C:\Users\koosh\OmniRoute-fresh2
REM    2. omniroute-dev pull           (sync fork with upstream if you want)
REM    3. restart the running omniroute process
REM    4. omniroute-dev <subcmd>       (now picks up the fresh code)
REM ============================================================================

setlocal EnableExtensions EnableDelayedExpansion

set "OMNIROUTE_REPO=C:\Users\koosh\OmniRoute-fresh2"
set "OMNIROUTE_BIN=%OMNIROUTE_REPO%\bin\omniroute.mjs"
set "OMNIROUTE_BUN=C:\Users\koosh\AppData\Roaming\npm\bun.cmd"

REM Load host env if present (OMNIROUTE_* keys, ENCRYPTION_KEY, API_KEYs)
if exist "C:\Users\koosh\.omniroute\.env" (
  for /f "usebackq tokens=1,* delims==" %%A in ("C:\Users\koosh\.omniroute\.env") do (
    if not "%%A"=="" if not "%%A:~0,1"=="#" set "%%A=%%B"
  )
)

REM ----- dispatch subcommands -------------------------------------------------
if /i "%~1"=="pull"   goto :pull
if /i "%~1"=="update" goto :pull
if /i "%~1"=="where"  goto :where
if /i "%~1"=="help"   goto :help
if /i "%~1"=="--help" goto :help
if /i "%~1"=="-h"     goto :help

REM default: passthrough to the fork's bin/omniroute.mjs
if not exist "%OMNIROUTE_BIN%" (
  echo [omniroute-dev] FATAL: %OMNIROUTE_BIN% not found
  echo                Run: cd /d %OMNIROUTE_REPO% ^&^& git pull ^&^& bun install
  exit /b 1
)
node "%OMNIROUTE_BIN%" %*
endlocal & exit /b %errorlevel%

:pull
echo Pulling latest from fork's upstream tracking branch...
git -C "%OMNIROUTE_REPO%" pull --ff-only || goto :pull_fail
echo Running bun install in fork...
call "%OMNIROUTE_BUN%" install --no-audit --no-fund --silent
endlocal & exit /b %errorlevel%

:pull_fail
echo.
echo [omniroute-dev] git pull failed. Likely you have local edits or
echo                  the fork is on a feature branch without an upstream.
echo                  Try:  git -C "%OMNIROUTE_REPO%" status
exit /b 1

:where
echo Fork repo:  %OMNIROUTE_REPO%
echo Entry bin:  %OMNIROUTE_BIN%
node "%OMNIROUTE_BIN%" --version 2>nul
endlocal & exit /b 0

:help
echo.
echo  omniroute-dev - thin wrapper around C:\Users\koosh\OmniRoute-fresh2
echo.
echo  Routing:
echo    omniroute-dev pull     git pull + bun install in the fork
echo    omniroute-dev where    show fork path and version
echo    omniroute-dev ^<subcmd^>  passthrough to fork's bin/omniroute.mjs
echo.
echo  This wrapper replaces the previous omniroute-dev-backup.cmd launcher.
echo  There is no separate "installed" copy of omniroute - the fork IS the
echo  runtime. Edit code in %OMNIROUTE_REPO%, restart the server, done.
echo.
endlocal & exit /b 0