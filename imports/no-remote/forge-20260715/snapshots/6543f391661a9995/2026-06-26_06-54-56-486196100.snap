[workspace]
resolver = "2"
# Note: crates/port-types, port-runtime, port-publisher, port-composer each
# declare themselves as single-crate workspaces and are intentionally NOT
# members of this parent workspace. They are consumed via path deps by
# their siblings only. crates/phenotype-* (top-level) and ports/ are
# likewise standalone.
members = [
    "bindings/rust-ffi",     # nvms-ffi
    "pheno-compose-driver",  # pheno-compose-driver
    "crates/pheno-config",   # pheno-config
]

[workspace.package]
version = "0.1.0"
edition = "2021"
rust-version = "1.75"
license = "MIT OR Apache-2.0"
repository = "https://github.com/KooshaPari/PhenoCompose"
description = "PhenoCompose - Phenotype deployment composition (NVMS driver + Rust FFI bindings)"
authors = ["kooshapari"]
publish = false

[workspace.dependencies]
# Core
async-trait = "0.1"
thiserror = "1.0"
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
bindgen = "0.68"
figment = { version = "0.10", features = ["toml", "env"] }
