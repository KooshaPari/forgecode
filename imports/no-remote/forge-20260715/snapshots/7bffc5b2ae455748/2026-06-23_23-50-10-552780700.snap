#!/usr/bin/env python3
import json, sys, os
sys.stdout.reconfigure(encoding='utf-8')
for repo in ["eyetracker", "eventra", "configra", "benchora", "authvault", "quillr"]:
    path = rf"C:\Users\koosh\Dev\_runs_{repo}.json"
    if not os.path.exists(path):
        print(f"=== {repo} ===  FILE_MISSING")
        continue
    try:
        d = json.load(open(path, encoding="utf-8"))
    except Exception as e:
        print(f"=== {repo} ===  PARSE_ERROR {e}")
        continue
    runs = [r for r in d.get("workflow_runs", []) if r.get("head_branch") == "main"]
    fail = [r for r in runs if r.get("conclusion") == "failure"]
    print(f"=== {repo} === main_runs_last20={len(runs)} failures={len(fail)}")
    for r in fail[:5]:
        n = (r.get("name") or "")[:50]
        s = (r.get("head_sha") or "")[:7]
        c = r.get("created_at", "")
        u = r.get("html_url", "")
        print(f"  FAIL: {n:50} | {s} | {c} | {u}")
