name: Journey Gate

on:
  push:
    branches: [main]
  pull_request:

permissions:
  contents: read
  actions: read

jobs:
  journey-verify:
    runs-on: ubuntu-24.04
    timeout-minutes: 5
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683

      - name: Verify journey manifest directory exists
        run: |
          if [ ! -d docs/journeys/manifests ]; then
            echo "ERROR: docs/journeys/manifests/ directory not found"
            exit 1
          fi
          echo "Journey manifests directory exists"

      - name: Verify iconography spec exists
        run: |
          if [ ! -f docs/operations/iconography/SPEC.md ]; then
            echo "ERROR: docs/operations/iconography/SPEC.md not found"
            exit 1
          fi
          echo "Iconography spec exists"

      - name: Verify journey-traceability.md exists
        run: |
          if [ ! -f docs/operations/journey-traceability.md ]; then
            echo "ERROR: docs/operations/journey-traceability.md not found"
            exit 1
          fi
          echo "Journey traceability doc exists"

      - name: Validate manifest JSON (if any exist)
        run: |
          if ls docs/journeys/manifests/*.json 1>/dev/null 2>&1; then
            for f in docs/journeys/manifests/*.json; do
              if ! jq empty "$f" 2>/dev/null; then
                echo "INVALID JSON: $f"
                exit 1
              fi
            done
            echo "All manifests valid JSON"
          else
            echo "No manifests yet (placeholder only)"
          fi

