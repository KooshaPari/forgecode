// ESLint v9 flat config for AppGen.
// Focused on legacy-tooling anti-patterns:
//   - no console.log (use proper logger; see desktop-electrobun/src/logger.ts)
//   - no debugger
//   - no eval
//   - no var (use let/const)
//   - prefer const for never-reassigned bindings
//   - sane TypeScript rules (no any, no unused)
//
// The desktop-electrobun subpackage is a Bun/Electrobun target with its own
// devDeps; it is intentionally not linted from this root config because
// its toolchain (Bun types) is not available here.
import js from "@eslint/js";
import tsParser from "@typescript-eslint/parser";
import tsPlugin from "@typescript-eslint/eslint-plugin";
import prettier from "eslint-config-prettier";

export default [
  {
    ignores: [
      "node_modules/**",
      "desktop-electrobun/**",
      "tools/legacy-enforcement/scanner/**",
      "legacy_tooling_report.*",
      "coverage/**",
      "dist/**",
      "build/**",
    ],
  },
  js.configs.recommended,
  {
    files: ["**/*.{js,jsx,ts,tsx}"],
    languageOptions: {
      ecmaVersion: 2022,
      sourceType: "module",
      parser: tsParser,
      parserOptions: {
        ecmaFeatures: { jsx: true },
      },
      globals: {
        // Vitest test globals (tests/smoke.test.ts uses describe/it/expect)
        describe: "readonly",
        it: "readonly",
        test: "readonly",
        expect: "readonly",
        beforeEach: "readonly",
        afterEach: "readonly",
        beforeAll: "readonly",
        afterAll: "readonly",
        vi: "readonly",
        // React Native core globals (Metro injects these)
        window: "readonly",
        document: "readonly",
        process: "readonly",
        console: "readonly",
        global: "readonly",
        Buffer: "readonly",
        __dirname: "readonly",
        __filename: "readonly",
        module: "readonly",
        require: "readonly",
        exports: "readonly",
        setTimeout: "readonly",
        clearTimeout: "readonly",
        setInterval: "readonly",
        clearInterval: "readonly",
        setImmediate: "readonly",
        clearImmediate: "readonly",
        fetch: "readonly",
      },
    },
    plugins: {
      "@typescript-eslint": tsPlugin,
    },
    rules: {
      "no-console": ["error", { allow: ["warn", "error"] }],
      "no-debugger": "error",
      "no-eval": "error",
      "no-implied-eval": "error",
      "no-new-func": "error",
      "no-var": "error",
      "prefer-const": "warn",
      eqeqeq: ["error", "always", { null: "ignore" }],
      "no-unused-vars": "off",
      "@typescript-eslint/no-unused-vars": [
        "warn",
        { argsIgnorePattern: "^_", varsIgnorePattern: "^_" },
      ],
      "@typescript-eslint/no-explicit-any": "warn",
    },
  },
  prettier,
];
