name: branch-protection

# WP-14: Branch protection + PTX as required check
#
# Pinpoints the recommended `main` branch protection rules + required
# status checks for phenotype-tooling. Generated via `gh api` per the
# adoption guide in docs/WP-14-BRANCH-PROTECTION.md.
#
# Apply once with:
#   gh api \
#     --method PUT \
#     -H "Accept: application/vnd.github+3" \
#     repos/KooshaPari/phenotype-tooling/branches/main/protection \
#     --input .github/branch-protection/main.json
#
# This file is documentation; once applied, GitHub stores the state
# server-side. Re-applying is idempotent.

{
  "required_status_checks": {
    "strict": true,
    "contexts": [
      "lint / fmt",
      "lint / clippy",
      "build / check",
      "test / unit",
      "ptx / governance",
      "bench / regression",
      "audit / cargo-deny",
      "audit / trufflehog",
      "scorecard / openssf"
    ]
  },
  "enforce_admins": true,
  "required_pull_request_reviews": {
    "dismissal_restrictions": {},
    "dismiss_stale_reviews": true,
    "require_code_owner_reviews": true,
    "required_approving_review_count": 1,
    "require_last_push_approval": true
  },
  "restrictions": null,
  "required_linear_history": true,
  "allow_force_pushes": false,
  "allow_deletions": false,
  "block_creations": false,
  "required_conversation_resolution": true,
  "lock_branch": false,
  "allow_fork_syncing": false,
  "required_signatures": true
}
