#!/usr/bin/env python
"""
Pre-execution gate for the compute/infra audit.

Refuses to report GO unless:
  1. scaffolding/decisions.json exists
  2. .depth in {phase1, all, all345, phase1_only}
  3. .nanovms_repoint and .phenotype_sdk keys present
  4. dags/compute_infra_dag.yaml exists
  5. .total_units is in [1, 10000]

Outputs STATUS: GO (...) or STATUS: NO-GO (...) and exits 0 / 1 respectively.
"""
from __future__ import annotations
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent

def fail(reason: str) -> "None":
    print(f"STATUS: NO-GO ({reason})")
    sys.exit(1)

def main() -> int:
    decisions_path = ROOT / "scaffolding" / "decisions.json"
    if not decisions_path.exists():
        fail("decisions_missing")
    try:
        d = json.loads(decisions_path.read_text(encoding="utf-8"))
    except Exception as e:
        fail(f"decisions_unparseable: {e}")
    depth = d.get("depth")
    if depth not in {"phase1", "all", "all345", "phase1_only"}:
        fail(f"depth_unrecognized:{depth}")
    for k in ("nanovms_repoint", "phenotype_sdk"):
        if k not in d:
            fail(f"key_missing:{k}")
    dag_path = ROOT / "dags" / "compute_infra_dag.yaml"
    if not dag_path.exists():
        fail("dag_missing")
    try:
        import yaml
        dag = yaml.safe_load(dag_path.read_text(encoding="utf-8"))
    except Exception as e:
        fail(f"dag_unparseable: {e}")
    total = dag.get("total_units")
    # The DAG nests the execution shape under `dag:`. Tolerate either shape.
    dag_block = dag.get("dag") if isinstance(dag.get("dag"), dict) else dag
    total = dag_block.get("total_units", 0)
        fail(f"total_units_out_of_range:{total}")
    print(f"STATUS: GO (depth={depth}, units={total})")
    return 0

if __name__ == "__main__":
    sys.exit(main())
