#!/usr/bin/env python3
"""Audit each branch in KooshaPari/OmniRoute and classify it.

Outputs a CSV-like text file with:
  branch, default_sha, protected, ahead, behind, last_commit_date, author,
  linked_pr_open, classification
"""
import json
import urllib.request
import urllib.error
import sys
import os
from datetime import datetime, timezone

TOKEN = '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'
OUT = r'C:\Users\koosh\_branch_audit.json'


def gh(path, params=None):
    url = f'https://api.github.com{path}'
    if params:
        from urllib.parse import urlencode
        url += '?' + urlencode(params)
    req = urllib.request.Request(url, headers={
        'Authorization': f'Bearer {TOKEN}',
        'Accept': 'application/vnd.github+json',
        'User-Agent': 'forge-script'
    })
    try:
        with urllib.request.urlopen(req, timeout=20) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        return {'__error__': e.code, '__body__': e.read().decode('utf-8', 'replace')[:200]}
    except Exception as e:
        return {'__error__': str(e)}


def classify(name, meta):
    n = name.lower()
    # Rules of thumb
    if name == 'main':
        return 'main'
    if n.startswith('upstream-pr/'):
        return 'upstream-port'
    if n.startswith('koosha/') or n.startswith('wip/') or n.startswith('release/'):
        if n.startswith('koosha/upstream-'):
            return 'upstream-port'
        return 'koosha-active'
    if n.startswith('rebase/') or n.startswith('rebase-') or n.startswith('land/') or n.startswith('land-pr'):
        return 'cherry-scaffold'
    if n.startswith('pr-') and '-' in n.split('/', 1)[0] and len(n.split('-')[1]) <= 3:
        return 'cherry-scaffold'
    if n.startswith('codex/'):
        return 'codex-archive'
    if n.startswith('feat/') or n.startswith('feat-') or n.startswith('feature/'):
        return 'feature-archive'
    if n.startswith('fix/'):
        return 'fix-archive'
    if n.startswith('chore/') or n.startswith('docs/') or n.startswith('security/'):
        return 'misc-archive'
    if n.startswith('qol/') or n.startswith('port/') or n.startswith('merge/') or n.startswith('ship/'):
        return 'misc-archive'
    if n.startswith('pr-') and n[3:].split('-')[0].isdigit():
        return 'pr-staging'
    if n in ('v3.8.34',):
        return 'release-pin'
    return 'other'


def main():
    branches = json.load(open(r'C:\Users\koosh\_omniroute_branches_all.json', encoding='utf-8'))
    print(f'Auditing {len(branches)} branches...', file=sys.stderr)
    audit = []
    for i, b in enumerate(branches):
        name = b['name']
        sha = b['commit']['sha']
        # Get commit details for date/author
        commit = gh(f'/repos/KooshaPari/OmniRoute/commits/{sha}')
        if isinstance(commit, dict) and '__error__' in commit:
            commit_meta = {'date': None, 'author': None}
        else:
            commit_meta = {
                'date': commit.get('commit', {}).get('author', {}).get('date'),
                'author': commit.get('commit', {}).get('author', {}).get('name')
            }
        # Get compare behind/ahead vs main
        comp = gh(f'/repos/KooshaPari/OmniRoute/compare/main...{name}')
        if isinstance(comp, dict) and '__error__' in comp:
            ahead = behind = None
            permalink = None
        else:
            ahead = comp.get('ahead_by')
            behind = comp.get('behind_by')
            permalink = comp.get('permalink')
        # Linked PR (if any)
        prs = gh(f'/repos/KooshaPari/OmniRoute/pulls', {'head': f'KooshaPari:{name}', 'state': 'open'})
        pr_state = None
        pr_number = None
        pr_url = None
        if isinstance(prs, list) and prs:
            p = prs[0]
            pr_state = p.get('state')
            pr_number = p.get('number')
            pr_url = p.get('html_url')

        entry = {
            'name': name,
            'sha': sha[:12],
            'protected': b.get('protected', False),
            'ahead': ahead,
            'behind': behind,
            'last_commit_date': commit_meta['date'],
            'author': commit_meta['author'],
            'linked_pr_open': pr_state == 'open',
            'pr_number': pr_number,
            'pr_url': pr_url,
            'compare_permalink': permalink,
            'classification': classify(name, None),
        }
        audit.append(entry)
        print(f'  [{i+1}/{len(branches)}] {name:55} {entry["classification"]:18} ahead={ahead} behind={behind} PR={pr_number}', file=sys.stderr)

    with open(OUT, 'w', encoding='utf-8') as f:
        json.dump(audit, f, indent=2)
    print(f'Wrote {len(audit)} entries to {OUT}', file=sys.stderr)


if __name__ == '__main__':
    main()
