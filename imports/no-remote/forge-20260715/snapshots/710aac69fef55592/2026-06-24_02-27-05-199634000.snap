# Phenotype-org standard .gitignore — Rust
# Source: https://github.com/KooshaPari/phenotype-tooling/blob/main/templates/gitignore-rust

# Build artifacts
/target/
**/*.rs.bk
Cargo.lock.bak

# Editor
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Repo-specific lines preserved from prior .gitignore:
debug
target
*.pdb
**/mutants.out*/

# VitePress / Node
node_modules/
docs/.vitepress/dist/
docs/.vitepress/cache/
package-lock.json
