[package]
name = "eventkit-obs"
version = "0.1.0"
edition = "2021"
license = "MIT OR Apache-2.0"
description = "Observability utilities for Eventra/eventkit: structured logging, correlation IDs, metrics hooks, and health probes"
repository = "https://github.com/KooshaPari/Eventra"
rust-version = "1.75"

[dependencies]
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter", "fmt", "json"] }
uuid = { version = "1", features = ["v4", "serde"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde_json = "1"
parking_lot = "0.12"
ureq = { version = "2", default-features = false, features = ["tls"] }
axum = { version = "0.7", optional = true }
tokio = { version = "1", features = ["rt-multi-thread", "macros", "signal", "net"], optional = true }

[features]
default = []
http-health = ["dep:axum", "dep:tokio"]

[[bin]]
name = "eventkit-healthcheck"
path = "src/bin/healthcheck.rs"
