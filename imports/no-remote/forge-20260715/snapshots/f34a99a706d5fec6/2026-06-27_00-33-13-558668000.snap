import json, subprocess, sys

repos = [
    ('phenotype-sdk', 'KooshaPari/phenotype-sdk'),
    ('Dev', 'KooshaPari/phenotype-gfx'),
    ('Eidolon', 'KooshaPari/Eidolon'),
    ('4sgm', 'KooshaPari/4sgm'),
    ('phenodag', 'KooshaPari/phenodag'),
    ('portage', 'KooshaPari/portage'),
    ('Tracera', 'KooshaPari/Tracera'),
    ('phenotype-registry', 'KooshaPari/phenotype-registry'),
    ('Civis', 'KooshaPari/Civis'),
    ('forge', 'KooshaPari/forge'),
]

all_data = {}
for local_name, gh_remote in repos:
    print(f"=== {local_name} ({gh_remote}) ===", flush=True)
    try:
        out = subprocess.check_output(
            ['gh', 'pr', 'list', '--repo', gh_remote, '--state', 'all', '--limit', '40',
             '--json', 'number,title,state,headRefName'],
            stderr=subprocess.STDOUT, text=True, timeout=30,
        )
        data = json.loads(out)
    except subprocess.CalledProcessError as e:
        print(f"  ERROR: {e.output.strip()[:200]}")
        all_data[local_name] = {'error': e.output.strip()[:200]}
        continue
    except Exception as e:
        print(f"  ERROR: {e}")
        all_data[local_name] = {'error': str(e)}
        continue

    all_data[local_name] = {'prs': data}
    open_prs = [p for p in data if p['state'] == 'OPEN']
    closed_prs = [p for p in data if p['state'] == 'CLOSED']
    merged_prs = [p for p in data if p['state'] == 'MERGED']
    print(f"  total={len(data)} open={len(open_prs)} closed={len(closed_prs)} merged={len(merged_prs)}")
    for p in closed_prs:
        print(f"  CLOSED #{p['number']}: {p['title']}")

with open('_lane_4_7_prs.json', 'w') as f:
    json.dump(all_data, f, indent=2)
print("\nWrote _lane_4_7_prs.json")
