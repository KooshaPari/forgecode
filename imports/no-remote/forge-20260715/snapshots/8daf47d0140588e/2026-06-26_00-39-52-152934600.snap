// src/server.ts — OmniRoute Step-1 entrypoint
// Hono on Bun runtime, bifrost as the LLM provider layer.
// Replaces Next.js 16 / React 19 routing. Legacy code is moved to ./legacy.

import { Hono } from "hono";
import { logger } from "hono/logger";
import { cors } from "hono/cors";
import { serve } from "bun";
import { bifrost, listProviders, type ProviderSpec } from "./bifrost";
import { discovery } from "./discovery";

const app = new Hono();

app.use("*", logger());
app.use(
  "*",
  cors({
    origin: (origin) => origin ?? "*",
    credentials: true,
  })
);

app.get("/health", (c) =>
  c.json({
    status: "ok",
    runtime: `bun ${Bun.version}`,
    ts: new Date().toISOString(),
    providers: listProviders().length,
  })
);

app.get("/v1/providers", (c) => c.json({ providers: listProviders() }));

// bifrost chat-completions passthrough. Uses streaming when `stream: true`.
// Bifrost handles provider auth, retries, and circuit breaking.
app.post("/v1/chat/completions", async (c) => {
  const body = await c.req.json().catch(() => ({}));
  try {
    const out = await bifrost.chat(body);
    return c.json(out);
  } catch (err) {
    return c.json(
      { error: { message: (err as Error).message, type: "provider_error" } },
      502
    );
  }
});

app.post("/v1/discover", async (c) => {
  const body = await c.req.json().catch(() => ({}));
  const result = await discovery.scan(body);
  return c.json(result);
});

const port = Number(process.env.PORT ?? 3000);

serve({
  port,
  fetch: app.fetch,
});

console.log(`[omniroute] bun ${Bun.version} listening on :${port}`);
console.log(`[omniroute] bifrost providers: ${listProviders().length}`);

export type { ProviderSpec };