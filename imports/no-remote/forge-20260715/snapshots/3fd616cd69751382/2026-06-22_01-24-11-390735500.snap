[package]
name = "phenotype-event-store"
version.workspace = true
edition.workspace = true
license.workspace = true
repository.workspace = true
description = "Durable SQLite-backed event store with outbox + DLQ + schema registry + projections. Absorbed from KooshaPari/phenoEvents on 2026-06-21."

[lib]
path = "src/lib.rs"

[dependencies]
phenotype-event-bus = { path = "../phenotype-event-bus" }
phenotype-event-contracts = { path = "../phenotype-event-contracts" }
thiserror = { workspace = true }
serde = { workspace = true }
serde_json = { workspace = true }
tokio = { workspace = true }
tracing = { workspace = true }
uuid = { version = "1", features = ["v7", "serde"] }
sqlx = { version = "0.8", default-features = false, features = ["runtime-tokio-rustls", "sqlite", "macros", "chrono", "uuid", "json"] }

[dev-dependencies]
tokio = { workspace = true, features = ["full"] }
tempfile = "3"