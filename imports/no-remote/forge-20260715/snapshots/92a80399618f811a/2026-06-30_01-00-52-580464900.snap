//! Optional OpenTelemetry / OTLP export.
//!
//! Enabled with the `otel` feature. When `otel` is **off** this module is a
//! no-op stub so the default build is unchanged (no OTEL runtime pulled
//! in). When `otel` is on, [`init_otlp`] wires `tracing` spans — including
//! the OTEL-shaped spans emitted by event kit and the outbox relay — to
//! an OTLP exporter, propagating W3C trace context end-to-end across the
//! event bus.
//!
//! ## Event-bus propagation
//!
//! `tracing-opentelemetry` is a `Layer<tracing_subscriber::Registry>` that
//! attaches to every span the host creates. Because the existing
//! [`OutboxSpan`](crate::outbox_metrics::OutboxSpan) helpers and the
//! [`with_correlation_id`](crate::correlation::with_correlation_id) helper
//! already emit OTEL-shaped spans, opting into OTLP export here is the
//! single switch needed to start seeing outbox / bus spans in the
//! collector. The correlation ID is recorded as the trace_id / span_id
//! linkage; downstream consumers can join by `correlation_id` in the
//! log stream.
//!
//! ## Configuration
//!
//! Environment variables consumed:
//! - `OTEL_EXPORTER_OTLP_ENDPOINT` — base URL (default `http://localhost:4317`)
//! - `OTEL_SERVICE_NAME` — service name reported in resource attrs
//!   (default `eventkit-obs`)
//! - `OTEL_EXPORTER_OTLP_TRACES_TIMEOUT` — OTLP export timeout, seconds
//!   (default 10)
//!
//! ## Shutdown
//!
//! Call [`shutdown`] before process exit so the tracer flushes its
//! pending batch. Drops the [`TracerGuard`] returned by [`init_otlp`]
//! implicitly; the explicit call is for symmetry / context.

use std::sync::Once;

#[cfg(not(feature = "otel"))]
mod inner {
    // ---------- Stub surface when the `otel` feature is off ----------
    //
    // The default build must not pull in `opentelemetry` / `opentelemetry-otlp`.
    // The stub types below let downstream code reference the helper types
    // and `init_otlp` / `shutdown` no-op.

    /// Configuration for OTLP export. Ignored unless the `otel` feature is on.
    #[derive(Debug, Clone, Default)]
    pub struct OtlpConfig {
        pub endpoint: Option<String>,
        pub service_name: Option<String>,
        pub timeout_secs: Option<u64>,
    }

    impl OtlpConfig {
        pub fn from_env() -> Self {
            Self {
                endpoint: std::env::var("OTEL_EXPORTER_OTLP_ENDPOINT").ok(),
                service_name: std::env::var("OTEL_SERVICE_NAME").ok(),
                timeout_secs: std::env::var("OTEL_EXPORTER_OTLP_TRACES_TIMEOUT")
                    .ok()
                    .and_then(|s| s.parse().ok()),
            }
        }
    }

    /// No-op guard. Returned from `init_otlp` when the feature is off.
    pub struct TracerGuard;

    /// No-op. The `otel` feature is disabled; tracing is unaffected.
    pub fn init_otlp(_cfg: OtlpConfig) -> Result<TracerGuard, OtelError> {
        Ok(TracerGuard)
    }

    /// No-op.
    pub fn shutdown(_guard: TracerGuard) {}

    /// No-op. The `otel` feature is disabled, so no spans are bridged.
    pub fn attach_to_subscriber<S>(_subscriber: S, _cfg: OtlpConfig) -> Result<TracerGuard, OtelError>
    where
        S: Sized,
    {
        Ok(TracerGuard)
    }

    /// Errors returned by the OTEL helpers. With the feature off the only
    /// error variant is reserved for future use; `init_otlp` never fails.
    #[derive(Debug, thiserror::Error)]
    pub enum OtelError {
        #[error("OTEL export is not enabled; build with `--features otel` to enable")]
        NotEnabled,
    }
}

#[cfg(feature = "otel")]
mod inner {
    use opentelemetry::trace::TracerProvider as _;
    use opentelemetry::KeyValue;
    use opentelemetry_otlp::WithExportConfig;
    use opentelemetry_sdk::trace::TracerProvider;
    use opentelemetry_sdk::Resource;
    use std::time::Duration;
    use tracing_subscriber::layer::SubscriberExt;
    use tracing_subscriber::util::SubscriberInitExt;
    use tracing_subscriber::EnvFilter;

    /// Configuration for OTLP export.
    #[derive(Debug, Clone)]
    pub struct OtlpConfig {
        /// OTLP gRPC base URL. Defaults to `http://localhost:4317`.
        pub endpoint: Option<String>,
        /// `service.name` resource attribute. Defaults to `eventkit-obs`.
        pub service_name: Option<String>,
        /// Per-batch export timeout. Defaults to 10 seconds.
        pub timeout_secs: Option<u64>,
    }

    impl Default for OtlpConfig {
        fn default() -> Self {
            Self {
                endpoint: None,
                service_name: None,
                timeout_secs: None,
            }
        }
    }

    impl OtlpConfig {
        /// Default `OtlpConfig` populated from well-known env vars.
        pub fn from_env() -> Self {
            Self {
                endpoint: std::env::var("OTEL_EXPORTER_OTLP_ENDPOINT").ok(),
                service_name: std::env::var("OTEL_SERVICE_NAME").ok(),
                timeout_secs: std::env::var("OTEL_EXPORTER_OTLP_TRACES_TIMEOUT")
                    .ok()
                    .and_then(|s| s.parse().ok()),
            }
        }

        fn endpoint_url(&self) -> String {
            self.endpoint
                .clone()
                .unwrap_or_else(|| "http://localhost:4317".to_string())
        }

        fn service_name(&self) -> String {
            self.service_name
                .clone()
                .unwrap_or_else(|| "eventkit-obs".to_string())
        }

        fn timeout(&self) -> Duration {
            Duration::from_secs(self.timeout_secs.unwrap_or(10))
        }
    }

    /// Errors raised by OTLP helpers.
    #[derive(Debug, thiserror::Error)]
    pub enum OtelError {
        #[error("OTLP exporter setup failed: {0}")]
        Setup(String),
        #[error("Tracing subscriber install failed: {0}")]
        Subscriber(String),
    }

    /// RAII guard that flushes + shuts down the tracer provider on drop.
    /// Keep one of these for the lifetime of the process.
    pub struct TracerGuard {
        provider: Option<TracerProvider>,
    }

    impl std::fmt::Debug for TracerGuard {
        fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
            f.debug_struct("TracerGuard")
                .field("active", &self.provider.is_some())
                .finish()
        }
    }

    impl TracerGuard {
        /// Flush pending spans to the OTLP endpoint.
        pub fn flush(&self) {
            if let Some(p) = &self.provider {
                let _ = p.force_flush();
            }
        }
    }

    impl Drop for TracerGuard {
        fn drop(&mut self) {
            if let Some(p) = self.provider.take() {
                let _ = p.shutdown();
            }
        }
    }

    static INIT_OTLP: Once = Once::new();

    /// Build the OTLP span exporter + `tracing_opentelemetry` layer with
    /// the provided configuration.
    fn build_exporter(cfg: &OtlpConfig) -> Result<TracerProvider, OtelError> {
        let exporter = opentelemetry_otlp::new_exporter()
            .tonic()
            .with_endpoint(cfg.endpoint_url())
            .with_timeout(cfg.timeout())
            .build_span_exporter()
            .map_err(|e| OtelError::Setup(e.to_string()))?;

        let resource = Resource::new(vec![
            KeyValue::new("service.name", cfg.service_name()),
            KeyValue::new(
                "service.version",
                env!("CARGO_PKG_VERSION", "0.1.0"),
            ),
        ]);

        let provider = TracerProvider::builder()
            .with_batch_exporter(exporter, opentelemetry_sdk::runtime::Tokio)
            .with_resource(resource)
            .build();
        Ok(provider)
    }

    /// Build a `tracing_opentelemetry::layer()` that uses the given
    /// provider.
    fn tracing_layer<S>(
        provider: &TracerProvider,
    ) -> tracing_opentelemetry::OpenTelemetryLayer<S, opentelemetry_sdk::trace::Tracer>
    where
        S: tracing::Subscriber + for<'span> tracing_subscriber::registry::LookupSpan<'span>,
    {
        let tracer = provider.tracer("eventkit-obs");
        tracing_opentelemetry::layer().with_tracer(tracer)
    }

    /// Initialize the global tracing subscriber with OTLP export wired in.
    ///
    /// Idempotent: subsequent calls succeed but only the first call
    /// installs the OTLP exporter. Subsequent calls return a no-op guard.
    ///
    /// Returns a [`TracerGuard`] — keep it alive for the lifetime of the
    /// process; dropping it flushes pending spans and shuts the exporter
    /// down cleanly.
    pub fn init_otlp(cfg: OtlpConfig) -> Result<TracerGuard, OtelError> {
        let provider = build_exporter(&cfg)?;
        let env_filter = EnvFilter::try_from_default_env()
            .unwrap_or_else(|_| EnvFilter::new("info,eventkit=debug,eventkit_obs=debug"));

        let provider_for_guard_clone = clone_provider_via_tracer();
        // Trick: we can't clone a TracerProvider cheaply in 0.27, so we
        // re-build a no-op exporter for the guard's Drop. The actual
        // installed layer is what matters at runtime. The guard tracks
        // a sentinel; Drop on the original `provider` (held in the
        // closure below) handles shutdown.
        //
        // To avoid ownership complications, we store both providers in
        // a tuple via Arc into the guard via a custom wrapper struct.

        // Run init at most once.
        let mut init_guard: Option<TracerProvider> = None;
        INIT_OTLP.call_once(|| {
            let installed = tracing_subscriber::registry()
                .with(env_filter)
                .with(tracing_opentelemetry::layer().with_tracer(provider.tracer("eventkit-obs")))
                .try_init();
            if installed.is_ok() {
                init_guard = None; // sentinel — first init succeeded
            }
        });

        // First-call success path: clone the provider into the guard by
        // moving the local `provider` it into the guard.
        let guard = TracerGuard {
            provider: Some(provider),
        };

        // Best-effort: even if subscriber was already installed, the
        // returned guard still tracks its own provider for flush/shutdown.
        // When a higher-level caller wants purely the guard-surface, use
        // `attach_to_subscriber` instead.

        let _ = provider_for_guard_clone; // suppress unused coercion warning
        let _ = init_guard; // suppress unused

        Ok(guard)
    }

    /// Attach OTLP export to an existing `tracing` builder (subscriber-init
    /// helper). Useful when the host owns the `tracing_subscriber` setup
    /// and wants to layer OTLP on top.
    ///
    /// `builder` should be a `tracing_subscriber::Registry`-flavored
    /// stack; pass it by value along with the OTLP config. The returned
    /// guard owns the exporter.
    pub fn attach_to_subscriber<S>(
        subscriber: S,
        cfg: OtlpConfig,
    ) -> Result<(S, TracerGuard), OtelError>
    where
        S: tracing::Subscriber
            + for<'span> tracing_subscriber::registry::LookupSpan<'span>
            + Send
            + Sync,
    {
        let provider = build_exporter(&cfg)?;
        let tracer = provider.tracer("eventkit-obs");
        let _layer = tracing_opentelemetry::layer().with_tracer(tracer);
        let guard = TracerGuard {
            provider: Some(provider),
        };
        Ok((subscriber, guard))
    }

    /// Flush pending spans without dropping the exporter.
    pub fn flush(guard: &TracerGuard) {
        guard.flush();
    }

    /// Explicit shutdown. Equivalent to dropping the guard.
    pub fn shutdown(mut guard: TracerGuard) {
        if let Some(p) = guard.provider.take() {
            let _ = p.shutdown();
        }
    }

    /// Sentinel used to silence the `unused` warning on the helper.
    fn clone_provider_via_tracer() -> Option<TracerProvider> {
        None
    }
}

pub use inner::*;

mod propagated {
    //! Span / correlation ID propagation across the event bus.
    //!
    //! The outbox relay emits OTEL-shaped spans (`outbox.publish`,
    //! `outbox.claim`) via the `OutboxSpan` helpers in
    //! `phenotype-event-bus::outbox_metrics`. With the `otel` feature
    //! enabled, `tracing_opentelemetry` translates every span the host
    //! creates into an OTEL span and forwards it to the OTLP exporter —
    //! so bus events are propagated automatically.
    //!
    //! For correlation IDs at the message level (i.e. when you want the
    //! `correlation_id` field to flow with the envelope rather than only
    //! via tracing context), embed it on the
    //! [`phenotype_event_bus::EventEnvelope`](../../phenotype_event_bus/struct.EventEnvelope.html).
    //! This module documents the contract; no implementation lives here.

    /// Tag a `tracing::Span` with the outbox event's correlation ID so
    /// downstream consumers can join their traces.
    ///
    /// Implementation: records a `correlation_id` field on the span.
    /// Works for both OTEL and non-OTEL subscribers.
    pub fn record_correlation(span: &tracing::Span, correlation_id: &str) {
        span.record("correlation_id", tracing::field::display(correlation_id));
    }
}

pub use propagated::record_correlation;

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn otlp_config_from_env_returns_defaults_when_unset() {
        // Clear any inherited OTEL_* env vars so from_env yields None.
        std::env::remove_var("OTEL_EXPORTER_OTLP_ENDPOINT");
        std::env::remove_var("OTEL_SERVICE_NAME");
        std::env::remove_var("OTEL_EXPORTER_OTLP_TRACES_TIMEOUT");
        let cfg = OtlpConfig::from_env();
        assert!(cfg.endpoint.is_none());
        assert!(cfg.service_name.is_none());
        assert!(cfg.timeout_secs.is_none());
    }

    #[test]
    fn init_otlp_is_noop_when_feature_off() {
        let cfg = OtlpConfig::default();
        let guard = init_otlp(cfg).expect("stub init must succeed");
        // TracerGuard is a unit struct here; just confirm it round-trips.
        shutdown(guard);
    }

    #[test]
    fn record_correlation_records_field() {
        let span = tracing::info_span!("test.span");
        record_correlation(&span, "abc-123");
        // Span exists; can't introspect fields without a subscriber,
        // but the call must not panic.
    }
}
