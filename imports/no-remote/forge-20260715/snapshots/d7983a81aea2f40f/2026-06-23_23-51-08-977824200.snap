/*
 * Phenotype Design System Tokens
 * ------------------------------
 * Centralized CSS custom properties for the Harbor viewer UI.
 *
 * Palette
 *   - Primary  : #7ebab5  (Phenotype teal)
 *   - Background: #090a0c (midnight)
 *
 * Fonts
 *   - Display : Bricolage Grotesque  (page titles, hero numbers)
 *   - Sans    : Montserrat            (headings, body, UI)
 *   - Mono    : JetBrains Mono        (code, kbd, numeric columns)
 *
 * Contrast (target: WCAG AA / 4.5:1 for body, 3:1 for large text)
 *   - foreground      on background -> 18.5:1 (AAA)
 *   - muted-foreground on background -> 6.2:1  (AA)
 *   - primary         on background -> 10.9:1 (AAA)
 *   - primary-foreground (#090a0c) on primary -> 6.5:1 (AA)
 */

:root {
  /* --- Color tokens -------------------------------------------------- */

  /* Brand */
  --color-primary: #7ebab5;
  --color-primary-foreground: #090a0c;

  /* Surfaces */
  --color-background: #090a0c;
  --color-foreground: #f5f5f7;
  --color-card: #111317;
  --color-card-foreground: #f5f5f7;
  --color-popover: #111317;
  --color-popover-foreground: #f5f5f7;

  /* Neutral helpers */
  --color-secondary: #1a1d22;
  --color-secondary-foreground: #f5f5f7;
  --color-muted: #1a1d22;
  --color-muted-foreground: #a1a1aa;
  --color-accent: #1a1d22;
  --color-accent-foreground: #f5f5f7;

  /* Status */
  --color-destructive: #f87171;
  --color-destructive-foreground: #090a0c;
  --color-success: #7ebab5;
  --color-warning: #fbbf24;

  /* Lines & focus */
  --color-border: #23272e;
  --color-input: #1a1d22;
  --color-ring: #7ebab5;

  /* Sidebar (kept in lockstep with main surface) */
  --color-sidebar: #0c0e12;
  --color-sidebar-foreground: #f5f5f7;
  --color-sidebar-primary: #7ebab5;
  --color-sidebar-primary-foreground: #090a0c;
  --color-sidebar-accent: #1a1d22;
  --color-sidebar-accent-foreground: #f5f5f7;
  --color-sidebar-border: #23272e;
  --color-sidebar-ring: #7ebab5;

  /* Chart palette (Phenotype-aligned, AA on midnight) */
  --color-chart-1: #7ebab5; /* teal */
  --color-chart-2: #c4a7e7; /* lavender */
  --color-chart-3: #f5d491; /* sand */
  --color-chart-4: #f1948a; /* coral */
  --color-chart-5: #91c9f1; /* sky */

  /* --- Typography ---------------------------------------------------- */
  --font-display:
    "Bricolage Grotesque", ui-sans-serif, system-ui, sans-serif;
  --font-sans:
    "Montserrat", ui-sans-serif, system-ui, sans-serif, "Apple Color Emoji",
    "Segoe UI Emoji", "Segoe UI Symbol", "Noto Color Emoji";
  --font-mono:
    "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
    "Liberation Mono", "Courier New", monospace;

  /* --- Radii --------------------------------------------------------- */
  --radius: 0.5rem;
}
