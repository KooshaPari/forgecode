[workspace]
resolver = "2"
members = [
    "agentkit",
    "agentora-graph",
    "agentora-crew",
    "agentora-skills",
    "agentora-ipc",
    "agentora-cli",
    "agentora-mcp",
    "agentora-obs",
    "agentora-py",
    "agentora-ts",
    "agentora-cs",
    "agentora-ffi",
]
exclude = [
    "agents/phenoagent",
    "agents/phenoagent/phenotype-daemon",
    "agents/phenoagent/phenotype-skills",
]

[workspace.package]
edition = "2021"
rust-version = "1.75"
license = "Apache-2.0"
repository = "https://github.com/KooshaPari/agentkit"
homepage = "https://github.com/KooshaPari/agentkit"

[workspace.dependencies]
# Internal
agentkit        = { path = "agentkit" }
agentora-graph  = { path = "agentora-graph" }
agentora-crew   = { path = "agentora-crew" }
agentora-skills = { path = "agentora-skills" }
agentora-ipc    = { path = "agentora-ipc" }
agentora-cli    = { path = "agentora-cli" }
agentora-mcp    = { path = "agentora-mcp" }
agentora-obs    = { path = "agentora-obs" }
agentora-ffi    = { path = "agentora-ffi" }

# Async + runtime
tokio       = { version = "1.40", features = ["full"] }
async-trait = "0.1"
async-stream = "0.3"
futures     = "0.3"

# Serialization
serde      = { version = "1", features = ["derive"] }
serde_json = "1"
rmp-serde  = "1.3"
msgpack    = "0.4"

# Errors
thiserror = "1"
anyhow    = "1"

# Observability
tracing        = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter", "json"] }
opentelemetry  = "0.24"
opentelemetry-otlp = "0.17"
opentelemetry-stdout = "0.5"

# Concurrency / data
dashmap  = "6"
parking_lot = "0.12"
crossbeam-channel = "0.5"
rayon     = "1.10"

# Time
chrono = { version = "0.4", features = ["serde"] }

# Hashing
xxhash-rust = { version = "0.8", features = ["xxh3"] }

# Config
toml = "0.8"

# Sys
sysinfo = "0.32"

# Notify (daemon FS watcher)
notify = "6"

# Compression
lz4_flex = "0.11"
