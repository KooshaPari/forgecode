$content = Get-Content -Path 'C:\Users\koosh\_wsm3d_audit\WSM3D_BACKUP_README.md' -Raw
$sha = ''
try {
  $existingJson = gh api repos/KooshaPari/WorldSphereMod/contents/README.md 2>$null
  if ($existingJson) {
    $existing = $existingJson | ConvertFrom-Json
    if ($existing.sha) { $sha = $existing.sha }
  }
} catch { Write-Host "No existing README or gh failed" }
$bytes = [System.Text.Encoding]::UTF8.GetBytes($content)
$base64 = [Convert]::ToBase64String($bytes)
$msg = 'backup: replace auto-generated README with recovery context'
if (-not $sha) {
  $body = '{"message":"' + $msg + '","content":"' + $base64 + '"}'
} else {
  $body = '{"message":"' + $msg + '","content":"' + $base64 + '","sha":"' + $sha + '"}'
}
$body | Out-File -FilePath 'C:\Users\koosh\_wsm3d_audit\readme_payload.json' -Encoding ASCII -NoNewline
Write-Host ('Payload size: ' + (Get-Item 'C:\Users\koosh\_wsm3d_audit\readme_payload.json').Length + ' bytes')
Write-Host ('SHA used: ' + ($sha | Out-String).Trim())
