{
  "$schema": "https://raw.githubusercontent.com/microsoft/pyright/main/packages/vscode-pyright/schemas/pyrightconfig.schema.json",
  "include": [
    "src/tracertm/__init__.py",
    "src/tracertm/matrix.py",
    "src/tracertm/governance.py",
    "src/tracertm/mlflow_compat.py",
    "src/tracertm/test_governance.py",
    "src/tracertm/test_mlflow_compat.py",
    "src/tracertm/core",
    "src/tracertm/schemas",
    "src/tracertm/storage",
    "src/tracertm/ports",
    "src/tracertm/proto",
    "src/tracertm/clients",
    "src/tracertm/observability",
    "src/tracertm/self_tracing",
    "src/tracertm/scoring",
    "src/tracertm/infrastructure",
    "src/tracertm/database",
    "src/tracertm/config",
    "src/tracertm/agent",
    "src/tracertm/cli",
    "src/tracertm/mcp",
    "src/tracertm/tui",
    "src/tracertm/v1",
    "src/tracertm/grpc",
    "src/tracertm/adapters",
    "src/tracertm/performance",
    "src/tracertm/services/execution",
    "src/tracertm/services/recording"
  ],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    "**/.venv",
    "**/venv",
    "**/site-packages",
    "**/dist",
    "**/build",
    "**/.pytest_cache",
    "**/.mypy_cache",
    "**/.ruff_cache",
    "**/htmlcov",
    "**/.tox",
    "**/.git",
    "**/.idea",
    "**/.vscode",
    "**/.worktrees",
    "**/.next",
    "**/out",
    "**/_exports.py",
    "**/api/routers/auth.py",
    "**/api/routers/code_trace.py",
    "**/api/routers/ingest.py",
    "**/api/routers/sdlc_pm.py",
    "**/api/routers/org_intel.py",
    "**/api/routers/evidence.py",
    "**/api/routers/impact_scoring.py",
    "**/api/routers/impact.py",
    "**/repositories",
    "**/services/github_import_service.py",
    "**/services/jira_import_service.py",
    "**/services/blast_radius_service.py",
    "**/ml/registry.py",
    "**/ml/test_inference_models.py",
    "**/ml/test_model_registry.py",
    "**/api/handlers",
    "**/api/main.py",
    "**/api/deps.py",
    "**/api/config"
  ],
  "typeCheckingMode": "strict",
  "reportMissingTypeStubs": false,
  "reportMissingImports": "none",
  "reportMissingModuleSource": false,
  "reportUnusedImport": true,
  "reportUnusedClass": true,
  "reportUnusedFunction": true,
  "reportUnusedVariable": true,
  "reportDuplicateImport": true,
  "reportWildcardImportFromLibrary": false,
  "reportOptionalMemberAccess": false,
  "reportOptionalSubscript": false,
  "reportPrivateUsage": false,
  "reportDeprecated": true,
  "reportUnnecessaryTypeIgnoreComment": true,
  "reportMissingTypeArgument": "none",
  "reportUnknownVariableType": "none",
  "reportUnknownMemberType": "none",
  "reportUnknownParameterType": "none",
  "reportUnknownArgumentType": "none",
  "pythonVersion": "3.13",
  "pythonPlatform": "All",
  "extraPaths": [
    "src"
  ]
}
