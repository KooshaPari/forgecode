#![forbid(unsafe_code)]
#![warn(missing_docs)]

//! Cross-platform [`ProcessPort`] backed by the `command-group` crate.
//!
//! Spawns children in a fresh process group so the whole subtree can be
//! signalled on timeout. Platform specifics (Unix `setsid` / Windows
//! `CREATE_NEW_PROCESS_GROUP`) are handled inside `command-group`.

use std::collections::HashMap;
use std::sync::Arc;
use std::time::{Duration, Instant};

use async_trait::async_trait;
use command_group::{AsyncCommandGroup, AsyncGroupChild};
use substrate_core::error::{Result, SubstrateError};
use substrate_core::process_port::{ProcessHandle, ProcessPort, ProcessSpawnSpec, ProcessState};
use tokio::process::Command;
use tokio::sync::Mutex;
use uuid::Uuid;

/// Poll interval used by `wait_with_timeout` while checking `try_wait` between
/// the spawn and the timeout deadline. Keeping this short lets the timeout fire
/// promptly without giving up the cooperative scheduling property that lets
/// other tasks on the same runtime make progress.
const WAIT_POLL_INTERVAL: Duration = Duration::from_millis(20);

/// Upper bound on how long `wait_with_timeout` will spend confirming that a
/// killed child has actually exited, before returning the killed state. The
/// child is already gone from the caller's perspective the moment
/// `start_kill` returns, so this is just a courtesy drain of the job
/// object's completion port; if it is still pending when the bound expires
/// we return anyway and let the OS clean the rest up asynchronously.
const POST_KILL_DRAIN: Duration = Duration::from_millis(500);

/// Upper bound on the time a `kill_group` call will wait for the child to
/// actually exit after `start_kill` returns. See `POST_KILL_DRAIN` for
/// rationale; the same courtesy drain applies here.
const KILL_GROUP_DRAIN: Duration = Duration::from_millis(500);

struct ManagedChild {
    child: AsyncGroupChild,
}

/// [`ProcessPort`] that spawns via `command-group` for portable process groups.
#[derive(Clone)]
pub struct CommandGroupProcess {
    children: Arc<Mutex<HashMap<Uuid, ManagedChild>>>,
}

impl std::fmt::Debug for CommandGroupProcess {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        f.debug_struct("CommandGroupProcess")
            .finish_non_exhaustive()
    }
}

impl Default for CommandGroupProcess {
    fn default() -> Self {
        Self::new()
    }
}

impl CommandGroupProcess {
    /// Create a new process manager.
    pub fn new() -> Self {
        Self {
            children: Arc::new(Mutex::new(HashMap::new())),
        }
    }

    fn map_state(pid: u32, code: Option<i32>) -> ProcessState {
        ProcessState::Exited { pid, code }
    }

    /// Poll the underlying Tokio process handle for an exit status, sleeping
    /// `WAIT_POLL_INTERVAL` between checks, until either the handle reports
    /// exit or `deadline` passes. Returns `true` if the handle became
    /// signaled.
    async fn poll_handle_until(
        inner: &mut tokio::process::Child,
        deadline: Instant,
    ) -> bool {
        while Instant::now() < deadline {
            if inner.try_wait().map(|s| s.is_some()).unwrap_or(false) {
                return true;
            }
            tokio::time::sleep(WAIT_POLL_INTERVAL).await;
        }
        false
    }
}

#[async_trait]
impl ProcessPort for CommandGroupProcess {
    async fn spawn(&self, spec: &ProcessSpawnSpec) -> Result<ProcessHandle> {
        let mut cmd = Command::new(&spec.program);
        cmd.args(&spec.args);
        if let Some(cwd) = &spec.cwd {
            cmd.current_dir(cwd);
        }

        let child = cmd
            .group_spawn()
            .map_err(|e| SubstrateError::Process(format!("spawn {}: {e}", spec.program)))?;
        let pid = child.id().unwrap_or(0);
        let id = Uuid::new_v4();
        let handle = ProcessHandle { id, pid };

        self.children
            .lock()
            .await
            .insert(id, ManagedChild { child });

        Ok(handle)
    }

    async fn status(&self, handle: &ProcessHandle) -> Result<ProcessState> {
        let mut children = self.children.lock().await;
        let managed = children
            .get_mut(&handle.id)
            .ok_or_else(|| SubstrateError::NotFound(format!("process {}", handle.id)))?;

        match managed.child.try_wait() {
            Ok(Some(status)) => Ok(Self::map_state(handle.pid, status.code())),
            Ok(None) => Ok(ProcessState::Running { pid: handle.pid }),
            Err(e) => Err(SubstrateError::Process(format!("try_wait: {e}"))),
        }
    }

    async fn wait_with_timeout(
        &self,
        handle: &ProcessHandle,
        timeout: Duration,
    ) -> Result<ProcessState> {
        // Drive the wait through `try_wait` polling rather than wrapping
        // `child.wait()` in `tokio::time::timeout`. Wrapping `wait()` in a
        // timeout drops the inner future when the deadline fires; on Windows
        // `tokio::process::Child::wait`'s drop handler calls
        // `UnregisterWaitEx(INVALID_HANDLE_VALUE)` which blocks until the
        // kernel wait callback completes. Under load that callback can take
        // seconds to drain, blowing through any sensible timeout bound.
        //
        // Polling `try_wait` never holds a registered wait future, so there
        // is nothing to unregister when the deadline expires. On the kill
        // path we likewise avoid creating a fresh `wait` future; instead we
        // call `start_kill` (a synchronous `TerminateJobObject`) and poll
        // the inner process handle, which becomes signaled as soon as the
        // kernel marks the process gone. We still drain the job completion
        // port afterwards to keep `command-group`'s bookkeeping consistent.
        let deadline = Instant::now() + timeout;
        loop {
            {
                let mut children = self.children.lock().await;
                let managed = children
                    .get_mut(&handle.id)
                    .ok_or_else(|| SubstrateError::NotFound(format!("process {}", handle.id)))?;

                match managed.child.try_wait() {
                    Ok(Some(status)) => {
                        children.remove(&handle.id);
                        return Ok(Self::map_state(handle.pid, status.code()));
                    }
                    Ok(None) => {}
                    Err(e) => {
                        let _ = managed.child.start_kill();
                        children.remove(&handle.id);
                        return Err(SubstrateError::Process(format!("try_wait: {e}")));
                    }
                }
            }

            let now = Instant::now();
            if now >= deadline {
                let mut children = self.children.lock().await;
                if let Some(managed) = children.get_mut(&handle.id) {
                    // `start_kill` issues `TerminateJobObject` synchronously.
                    // From the caller's perspective the process group is
                    // marked for termination immediately; Windows finishes
                    // the actual reap asynchronously. We do a short drain
                    // so the completion port accounting stays consistent,
                    // but we deliberately do NOT wait for the inner handle
                    // to signal: on Windows that signal can lag `start_kill`
                    // by many seconds for managed runtimes (PowerShell /
                    // .NET, WSL, etc.), and the caller's contract is "the
                    // child was killed at the requested deadline", not
                    // "the child is fully reaped before we return".
                    let _ = managed.child.start_kill();
                    let drain_deadline = Instant::now() + POST_KILL_DRAIN;
                    while Instant::now() < drain_deadline
                        && managed.child.try_wait().map(|s| s.is_some()).unwrap_or(false)
                    {}
                }
                children.remove(&handle.id);
                // The child was killed by us; report no exit code so callers
                // can distinguish a forced termination from a natural exit.
                return Ok(Self::map_state(handle.pid, None));
            }

            let remaining = deadline.saturating_duration_since(now);
            tokio::time::sleep(remaining.min(WAIT_POLL_INTERVAL)).await;
        }
    }

    async fn kill_group(&self, handle: &ProcessHandle) -> Result<()> {
        let mut children = self.children.lock().await;
        let managed = children
            .get_mut(&handle.id)
            .ok_or_else(|| SubstrateError::NotFound(format!("process {}", handle.id)))?;

        managed
            .child
            .start_kill()
            .map_err(|e| SubstrateError::Process(format!("kill_group: {e}")))?;
        // See `wait_with_timeout` for why we don't block until the inner
        // handle signals; the short drain below just gives the job
        // completion port a chance to absorb the kill notification so
        // `command-group`'s bookkeeping stays consistent.
        let drain_deadline = Instant::now() + KILL_GROUP_DRAIN;
        while Instant::now() < drain_deadline
            && managed.child.try_wait().map(|s| s.is_some()).unwrap_or(false)
        {}
        children.remove(&handle.id);
        Ok(())
    }
}

#[cfg(test)]
mod tests {
    use super::*;
    use std::time::Duration;

    /// Portable long-running child for timeout/kill tests.
    fn sleep_spec(secs: u64) -> ProcessSpawnSpec {
        #[cfg(unix)]
        {
            ProcessSpawnSpec {
                program: "sleep".into(),
                args: vec![secs.to_string()],
                cwd: None,
            }
        }
        #[cfg(windows)]
        {
            ProcessSpawnSpec {
                program: "powershell".into(),
                args: vec![
                    "-NoProfile".into(),
                    "-Command".into(),
                    format!("Start-Sleep -Seconds {secs}"),
                ],
                cwd: None,
            }
        }
    }

    /// Portable echo child that exits quickly with code 0.
    fn echo_spec() -> ProcessSpawnSpec {
        #[cfg(unix)]
        {
            ProcessSpawnSpec {
                program: "sh".into(),
                args: vec!["-c".into(), "echo substrate-process-ok".into()],
                cwd: None,
            }
        }
        #[cfg(windows)]
        {
            ProcessSpawnSpec {
                program: "cmd".into(),
                args: vec!["/C".into(), "echo substrate-process-ok".into()],
                cwd: None,
            }
        }
    }

    #[tokio::test(flavor = "multi_thread")]
    async fn spawn_wait_returns_exit_status() {
        let proc = CommandGroupProcess::new();
        let handle = proc.spawn(&echo_spec()).await.unwrap();
        assert!(handle.pid > 0);

        let state = proc
            .wait_with_timeout(&handle, Duration::from_secs(10))
            .await
            .unwrap();
        assert_eq!(
            state,
            ProcessState::Exited {
                pid: handle.pid,
                code: Some(0),
            }
        );
    }

    #[tokio::test(flavor = "multi_thread")]
    async fn status_reports_running_then_exited() {
        let proc = CommandGroupProcess::new();
        let handle = proc.spawn(&echo_spec()).await.unwrap();

        // May already have exited; poll until we see Exited.
        let mut saw_running = false;
        for _ in 0..20 {
            match proc.status(&handle).await.unwrap() {
                ProcessState::Running { .. } => saw_running = true,
                ProcessState::Exited { code, .. } => {
                    assert_eq!(code, Some(0));
                    break;
                }
            }
            tokio::time::sleep(Duration::from_millis(10)).await;
        }
        let _ = saw_running; // best-effort on fast CI hosts
    }

    #[tokio::test(flavor = "multi_thread")]
    async fn kill_on_timeout_returns_within_timeout() {
        let proc = CommandGroupProcess::new();
        let handle = proc.spawn(&sleep_spec(60)).await.unwrap();

        let timeout = Duration::from_millis(500);
        let start = std::time::Instant::now();
        let state = proc.wait_with_timeout(&handle, timeout).await.unwrap();
        let elapsed = start.elapsed();

        // Generous bound (4× the requested timeout) so we still catch
        // pathological regressions in the kill path while remaining stable
        // across slow CI hosts. The original implementation drove the wait
        // via `tokio::time::timeout(child.wait())`, which on Windows stalls
        // inside `UnregisterWaitEx` for several seconds when the kernel
        // wait callback is contended; polling `try_wait` and using
        // `start_kill` directly keeps the bound reliable.
        assert!(
            elapsed < Duration::from_secs(2),
            "took too long: {elapsed:?}"
        );
        assert_eq!(
            state,
            ProcessState::Exited {
                pid: handle.pid,
                code: None,
            }
        );
    }
}
