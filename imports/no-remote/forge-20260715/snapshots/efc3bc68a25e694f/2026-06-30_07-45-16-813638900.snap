#!/usr/bin/env python3
"""Fetch + decode clinepass.mdx + provider SDK files."""
import json, os, re, subprocess, sys
os.environ["NO_COLOR"] = "1"
os.environ["PYTHONIOENCODING"] = "utf-8"

def gh(path):
    r = subprocess.run(["gh","api",path], capture_output=True, text=True, encoding="utf-8", shell=False, env=os.environ)
    out = re.sub(r"\x1b\[[0-9;]*[A-Za-z]","",r.stdout)
    if r.returncode != 0:
        return None, r.stderr
    try:
        return json.loads(out), None
    except Exception as e:
        return None, f"{e}; head={out[:200]!r}"

def dump(ref, path, label):
    d, err = gh(f"/repos/cline/cline/contents/{path}?ref={ref}")
    if err or not d:
        print(f"FAIL {label}: {err}", file=sys.stderr); return
    import base64
    txt = base64.b64decode(d["content"]).decode("utf-8")
    out_path = f"C:\Users\koosh\_tmp_cp\{label}.txt" if False else label + ".txt"
    open(out_path, "w", encoding="utf-8").write(txt)
    print(f"=== {label} ({path}) ===")
    print(txt)

REF = "dbe15202e1b7dc12b6bfd8c86b450d678f3ec33d"
dump(REF, "docs/getting-started/clinepass.mdx", "clinepass_mdx")
