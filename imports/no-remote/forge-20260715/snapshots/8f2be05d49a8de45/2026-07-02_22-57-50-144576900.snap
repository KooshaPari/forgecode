[package]
name = "civ-build"
description = "Procedural voxel building grammar + freehand authoring; produces shared BuildingGraph"
version.workspace = true
edition.workspace = true
license.workspace = true
publish = false

[dependencies]
serde = { version = "1.0", features = ["derive"] }
tracing = "0.1"
civ-voxel = { path = "../voxel" }
civ-economy = { path = "../economy" }
ron = "0.8"
rand = "0.8.6"
rand_chacha = "0.3"

[dev-dependencies]
proptest = "1.11"
ron = "0.8"
