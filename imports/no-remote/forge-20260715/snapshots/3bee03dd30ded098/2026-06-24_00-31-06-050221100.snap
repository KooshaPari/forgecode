         "registry":"phenotype-registry","agileplus":"agileplus","sdk":"phenotype-sdk"}

# Compact unit representation: (id, title, repo, pillar, type, acceptance, pre, prio)
# Use empty list for pre, default priority M
def line(u, pre=None, prio="M", branch=None):
    if branch is None:
        branch = u.lower()
    return {
        "id": u[0], "epic": u[0][0], "title": u[1], "repo": REPOS[u[2]],
        "pillar": u[3], "pillar_name": PILLAR[u[3]], "type": u[4],
        "priority": prio,
        "branch": f"ci-infra/{branch}" if u[2] != "registry" else None,
        "pre": pre or [], "acceptance": u[5],
    }

