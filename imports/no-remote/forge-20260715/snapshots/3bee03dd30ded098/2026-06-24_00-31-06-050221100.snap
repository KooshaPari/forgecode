PILLAR = {"L0":"Architecture","L1":"Boundaries","L2":"Testing","L3":"CI","L4":"Security",
    "L5":"Docs","L6":"Repo hygiene","L7":"Coverage","L8":"Performance","L9":"Build",
    "L10":"Type safety","L11":"Observability","L12":"SBOM/SLSA","L13":"Reproducibility",
    "L14":"Modularity","L15":"API stability","L16":"Error model","L17":"Config",
    "L18":"State","L19":"Concurrency","L20":"I/O","L21":"Networking","L22":"Cost",
    "L23":"Carbon","L24":"Compliance","L25":"Release","L26":"Onboarding",
    "L27":"Internal cross-repo","L28":"External diff","L29":"Future-proofing",}
