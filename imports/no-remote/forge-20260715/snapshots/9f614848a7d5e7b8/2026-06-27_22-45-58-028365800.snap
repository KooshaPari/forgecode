$repo = "C:\Users\koosh\_compute_infra_audit\PhenoCompose.git"
$files = git -C $repo ls-tree -r HEAD --name-only
$result = @()
foreach ($f in $files) {
    $ts = git -C $repo log -1 --format="%ct" -- $f
    $result += "$ts $f"
}
$result -join "`n" | Out-File -FilePath "C:\Users\koosh\_compute_infra_audit\timestamps.txt" -Encoding ASCII
