[workspace]
resolver = "2"
# Active members — only crates/libs with actual source files.
# Remaining scaffolding (44 crates, 19 libs) tracked but excluded from
# workspace until source is implemented. See: kitty-specs/003-agileplus-platform-completion.
members = [
  "rust", # agileplus-proto: tonic/prost gRPC stubs (buf-generated)
]

[workspace.package]
version = "0.1.0"
edition = "2024"
license = "MIT"
rust-version = "1.88"

[workspace.lints.rust]
unsafe_code = "forbid"

[workspace.lints.clippy]
all = "warn"
pedantic = "warn"

[workspace.dependencies]
# Serialization
serde = { version = "1.0", features = ["derive"] }
serde_json = "1"
serde_yaml = "0.9"

# Async runtime
tokio = { version = "1.39", features = ["full"] }
tokio-stream = "0.1"
tokio-util = "0.7"
futures = "0.3"
futures-util = "0.3"

# Error handling
thiserror = "2"
anyhow = "1"

# Web / HTTP
axum = { version = "0.8", features = ["json", "macros"] }
axum-extra = { version = "0.10", features = ["typed-header"] }
tower = { version = "0.5", features = ["limit", "timeout"] }
tower-http = { version = "0.6", features = ["cors", "fs", "trace"] }
hyper = "1"
hyper-util = "0.1"

# Observability
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }
opentelemetry = { version = "0.27", features = ["metrics"] }
opentelemetry_sdk = { version = "0.27", features = [
  "metrics",
  "trace",
  "rt-tokio",
] }
opentelemetry-otlp = { version = "0.27", features = ["tonic", "gzip-tonic"] }
tracing-opentelemetry = "0.27"
sentry = { version = "0.34", features = ["tracing"] }

# Time
chrono = { version = "0.4", features = ["serde"] }

# Crypto / hashing
sha2 = "0.10"
zeroize = { version = "1", features = ["derive"] }
base64 = "0.22"

# gRPC / proto (used by agileplus-proto, agileplus-grpc, plugin-grpc, agent-service)
tonic = { version = "0.13", features = ["transport", "prost"] }
tonic-build = "0.13"
tonic-health = "0.13"
prost = "0.13"
prost-build = "0.13"

# Async utilities
async-trait = "0.1"

# Templating
askama = "0.12"

# Git
gix = "0.65"
git2 = "0.19"

# CLI
clap = { version = "4", features = ["derive"] }

# Data / storage
rusqlite = { version = "0.32", features = ["bundled"] }
redis = { version = "0.27", features = ["tokio-comp", "connection-manager"] }

# HTTP client
reqwest = { version = "0.12", features = ["json"] }

# Benchmarks
criterion = "0.5"

# Utils
uuid = { version = "1", features = ["v4"] }
rand = "0.8"
toml = "0.8"
dirs-next = "2"
keyring = "3"

# OpenAPI
utoipa = "4"
async-nats = "0.38"
paste = "1"
agileplus-config = { path = "crates/agileplus-config" }
agileplus-proto = { path = "crates/agileplus-proto" }

# cargo-machete false-positive ignores (dev-only / proc-macro / build-deps)
[workspace.metadata.cargo-machete]
ignored = [
  "cucumber",
  "axum-test",
  "paste",
  "dirs",
  "serde_yaml",
  "uuid",
  "async-trait",
  "tracing-subscriber",
  "tracing-appender",
  "tracing-opentelemetry",
  "futures",
  "futures-util",
  "tonic",
  "tonic-build",
  "prost",
  "prost-build",
  "utoipa",
  "opentelemetry",
  "opentelemetry_sdk",
  "opentelemetry-otlp",
  "gix",
  "tempfile",
]
