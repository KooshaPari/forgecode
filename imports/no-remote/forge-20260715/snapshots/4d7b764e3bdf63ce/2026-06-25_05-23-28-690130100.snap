{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "isolatedModules": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "tests/**/*",
    "vitest.config.ts",
    "tools/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "desktop-electrobun",
    "assets",
    "dist",
    "build"
  ]
}
