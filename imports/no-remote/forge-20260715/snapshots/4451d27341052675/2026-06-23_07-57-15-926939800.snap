[package]
name = "agentora-ipc"
version = "0.1.0"
edition = "2021"
description = "IPC for agentora: UDS, SHM ring, mpsc queue, dedup"

[dependencies]
# --- absorbed from pheno-proc-uds ---
tokio = { version = "1", features = ["rt", "net", "macros", "io-util", "sync", "time"] }
futures = "0.3"
tokio-util = { version = "0.7", features = ["codec"] }
thiserror = "2.0"

# --- new for agentora-ipc ---
serde = { version = "1", features = ["derive"] }
serde_json = "1"
rmp-serde = "1"
dashmap = "6"
tracing = "0.1"
sysinfo = "0.33"

[target.'cfg(unix)'.dependencies]
tokio-unix-ipc = "0.6"
cfg-if = "1"

[lib]
name = "agentora_ipc"
path = "src/lib.rs"
