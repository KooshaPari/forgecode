[workspace.package]
version = "0.2.0"
edition = "2021"
license = "MIT OR Apache-2.0"
rust-version = "1.75"
repository = "https://github.com/KooshaPari/HexaKit"
description = "Phenotype Infrastructure Kit"
authors = ["kooshapari"]

[workspace]
resolver = "2"
exclude = [
  "crates/focalpoint",  # 867MB repo with vendor dir; fetch too large for subtree-add; pending manual absorption
  "Metron",             # archived → PhenoObservability crates/metrickit (2026-06-17)
  "agileplus",          # canonical → KooshaPari/AgilePlus (2026-06-17)
  "Traceon",            # archived → PhenoObservability crates/tracingkit (2026-06-17)
  "crates/stashly",     # canonical → phenoShared / phenotype-types per v2 charter
  "crates/settly",      # canonical → phenotype-config (Wave 8 stub prune)
  "crates/phenotype-bdd", # canonical → TestingKit wave B (2026-06-17)
  # P3 wave 1 — error crates canonical in phenoShared (API-compatible)
  "crates/phenotype-error-core",
  "crates/phenotype-errors",
  # P3 wave 2 — event crates interim phenoShared (Eventra absorb pending); http-client → ResilienceKit
  "crates/phenotype-event-bus",
  "crates/phenotype-http-client-core",
  # P3 wave 3 — logging → PO; time now local in HexaKit; state-machine + policy → ResilienceKit
  "crates/phenotype-logging",
  "crates/phenotype-state-machine",
  "crates/phenotype-policy-engine",
  # P3 wave 4 — security + macros + async-traits → phenoShared (contracts deferred: API diverge)
  "crates/phenotype-async-traits",
  "crates/phenotype-macros",
  # Wave 12 — health traits interim phenoShared (PO runtime differs)
  "crates/phenotype-health",
  # now local crates/phenotype-cache-adapter (absorbed from pheno monorepo)
  # eco-consolidate — config-loader, mcp
  "crates/phenotype-config-loader",
  "crates/phenotype-mcp",
  # Wave 13 lane B — test infra → TestingKit
  "crates/phenotype-test-infra",
  # Wave 13 lane C — generic Contract trait interim phenoShared; slice crates → role owners
  "crates/phenotype-contracts",
  # Wave 13 lane D — cipher → Authvault
  "crates/cipher",
  # Wave C tail — crypto + casbin → Authvault
  "crates/phenotype-crypto",
  "crates/phenotype-casbin-wrapper",
  # Phase 2 E2a — utils → phenoShared
  "crates/phenotype-iter",
  "crates/phenotype-string",
  "crates/phenotype-validation",
  # Phase 3 Wave A — observability → PhenoObservability
  "crates/phenotype-sentry-config",
  "crates/phenotype-telemetry",
  # Phase 3 Wave B — testing → TestingKit
  "crates/phenotype-contract",
  "crates/phenotype-test-fixtures",
  # Wave H — analytics + nexus decompose
  "crates/phenotype-analytics",
  "libs/nexus",
  # P2 infrakit drain — incomplete stub; excluded until deps + dyn trait fixed
  "crates/phenotype-security-aggregator",
  # Phase 4 wave 5 — config core → phenoShared (H14 interim; terminal → phenotype-config)
  "libs/phenotype-config-core",
]
members = [
  "crates/phenotype-router",
  "crates/hexakit-cli",
  "crates/phenotype-contract-adapters",
  "crates/phenotype-contract-tests",
  "crates/phenotype-compliance-scanner",
  "crates/phenotype-cost-core",
  "crates/phenotype-error-macros",
  "crates/phenotype-git-core",
  "crates/phenotype-port-traits",
  "crates/phenotype-ports-canonical",
  "crates/phenotype-process",
  "crates/phenotype-shared-config",
  "crates/phenotype-core",
  "crates/phenotype-infrastructure",
  "crates/phenotype-project-registry",
  "crates/phenotype-security-aggregator",
  "crates/phenotype-xdd-lib",
  "forgecode-fork",
  "crates/phenotype-cache-adapter",
  "crates/phenotype-event-sourcing",
  "crates/phenotype-rate-limit",
  "crates/phenotype-retry",
  "crates/phenotype-time",
  "crates/clap-ext",
  "crates/clap-ext-macros",
]
[workspace.dependencies]
# H15 absorption: clap CLI extensions
clap = { version = "4", features = ["derive", "env", "cargo", "wrap_help"] }
clap-ext = { path = "crates/clap-ext" }
clap-ext-macros = { path = "crates/clap-ext-macros" }
colored = "2"
proc-macro2 = "1"
quote = "1"
syn = { version = "2", features = ["full", "extra-traits"] }
# Core
sentry = "0.34"
# Core
serde = { version = "1", features = ["derive"] }
serde_json = "1"
thiserror = "2"
anyhow = "1"
dirs = "5"
async-trait = "0.1"
chrono = { version = "0.4", features = ["serde"] }
uuid = { version = "1", features = ["v4", "serde"] }
tokio = { version = "1", features = ["full"] }
tokio-stream = { version = "0.1", features = ["sync"] }
dashmap = "5"
parking_lot = "0.12"
lru = "0.16"
toml = "0.8"
regex = "1"
tempfile = "3"
sha2 = "0.10"
tracing = "0.1"
tracing-subscriber = "0.3"
futures = "0.3"
strum = { version = "0.26", features = ["derive"] }
once_cell = "1.19"
blake3 = "1"
hex = "0.4"
zstd = "0.13"
unicode-normalization = "0.1"
rand = "0.8"
moka = { version = "0.12", features = ["sync"] }
derive_builder = "0.20"
criterion = "0.5"
mockall = "0.12"
proptest = "1.4"
ulid = { version = "1", features = ["serde"] }

# Phenotype internal crates
arc-swap = "1"
# phenoShared interim pins drained wave 5b (ADR-ECO-014) — terminal DOMAIN_ROLES owners
phenotype-error-core = { git = "https://github.com/KooshaPari/phenotype-types", branch = "main" }
phenotype-errors = { git = "https://github.com/KooshaPari/phenotype-types", branch = "main" }
# Eventra terminal owner (wave 5b)
phenotype-event-bus = { git = "https://github.com/KooshaPari/Eventra", branch = "main", package = "phenotype-event-bus" }
phenotype-event-sourcing = { path = "crates/phenotype-event-sourcing" }
# ResilienceKit = phenotype-resilience DOMAIN_ROLES owner
phenotype-http-client-core = { git = "https://github.com/KooshaPari/ResilienceKit", branch = "main" }
phenotype-state-machine = { git = "https://github.com/KooshaPari/ResilienceKit", branch = "main" }
phenotype-policy-engine = { git = "https://github.com/KooshaPari/ResilienceKit", branch = "main" }
phenotype-logging = { git = "https://github.com/KooshaPari/PhenoObservability", branch = "main", package = "phenotype-logging" }
phenotype-time = { path = "crates/phenotype-time" }
phenotype-rate-limit = { path = "crates/phenotype-rate-limit" }
phenotype-retry = { path = "crates/phenotype-retry" }
# phenotype-rust-sdk thin facade (ADR-ECO-014)
phenotype-async-traits = { git = "https://github.com/KooshaPari/phenotype-rust-sdk", branch = "main" }
phenotype-macros = { git = "https://github.com/KooshaPari/phenotype-rust-sdk", branch = "main" }
phenotype-config-loader = { git = "https://github.com/KooshaPari/phenotype-config", branch = "main" }
phenotype-mcp = { git = "https://github.com/KooshaPari/substrate", branch = "main" }
# ResilienceKit traits crate (HealthChecker API — PO runtime differs)
phenotype-health = { git = "https://github.com/KooshaPari/ResilienceKit", branch = "main", package = "phenotype-health" }
# archive-if-unused stub — inline HexaKit shim; zero phenoShared git deps fleet-wide (ADR-ECO-014)
phenotype-cache-adapter = { path = "crates/phenotype-cache-adapter" }
phenotype-contract-adapters = { path = "crates/phenotype-contract-adapters" }
# Contracts decompose: slice crates on role owners; generic Contract → phenotype-rust-sdk
phenotype-auth-contracts = { git = "https://github.com/KooshaPari/Authvault", branch = "main", package = "phenotype-auth-contracts" }
phenotype-event-contracts = { git = "https://github.com/KooshaPari/Eventra", branch = "main", package = "phenotype-event-contracts" }
phenotype-agent-contracts = { git = "https://github.com/KooshaPari/Agentora", branch = "main", package = "phenotype-agent-contracts" }
phenotype-contracts = { git = "https://github.com/KooshaPari/phenotype-rust-sdk", branch = "main" }
phenotype-security-aggregator = { git = "https://github.com/KooshaPari/Authvault", branch = "main", package = "phenotype-security-aggregator" }
phenotype-test-infra = { git = "https://github.com/KooshaPari/TestingKit", branch = "main" }
phenotype-cipher = { git = "https://github.com/KooshaPari/Authvault", branch = "main", package = "phenotype-cipher" }
phenotype-crypto = { git = "https://github.com/KooshaPari/Authvault", branch = "main", package = "phenotype-crypto" }
phenotype-casbin-wrapper = { git = "https://github.com/KooshaPari/Authvault", branch = "main", package = "phenotype-casbin-wrapper" }
phenotype-iter = { git = "https://github.com/KooshaPari/phenotype-types", branch = "main", package = "phenotype-iter" }
phenotype-string = { git = "https://github.com/KooshaPari/phenotype-types", branch = "main", package = "phenotype-string" }
phenotype-validation = { git = "https://github.com/KooshaPari/phenotype-types", branch = "main", package = "phenotype-validation" }
phenotype-sentry-config = { git = "https://github.com/KooshaPari/PhenoObservability", branch = "main", package = "phenotype-sentry-config" }
phenotype-telemetry = { git = "https://github.com/KooshaPari/PhenoObservability", branch = "main", package = "phenotype-telemetry" }
phenotype-contract = { git = "https://github.com/KooshaPari/TestingKit", branch = "main", package = "phenotype-contract" }
phenotype-test-fixtures = { git = "https://github.com/KooshaPari/TestingKit", branch = "main", package = "phenotype-test-fixtures", default-features = false }
phenotype-compliance-scanner = { path = "crates/phenotype-compliance-scanner" }
phenotype-config-core = { git = "https://github.com/KooshaPari/phenotype-config", branch = "main", package = "phenotype-config-core" }
phenotype-core = { path = "crates/phenotype-core" }
phenotype-cost-core = { path = "crates/phenotype-cost-core" }
phenotype-error-macros = { path = "crates/phenotype-error-macros" }
phenotype-git-core = { path = "crates/phenotype-git-core" }
phenotype-infrastructure = { path = "crates/phenotype-infrastructure" }
phenotype-port-traits = { path = "crates/phenotype-port-traits" }
phenotype-ports-canonical = { path = "crates/phenotype-ports-canonical" }
phenotype-process = { path = "crates/phenotype-process" }
phenotype-project-registry = { path = "crates/phenotype-project-registry" }
phenotype-shared-config = { path = "crates/phenotype-shared-config" }

# External utilities
axum = "0.7"
axum-extra = "0.9"
clap = { version = "4", features = ["derive", "env", "cargo", "wrap_help"] }
figment = "0.10"
colored = "2"
proc-macro2 = "1"
quote = "1"
syn = { version = "2", features = ["full"] }
futures-util = "0.3"
http-body-util = "0.1"
hyper = { version = "1", features = ["full"] }
hyper-util = { version = "0.1", features = ["full"] }
bytes = "1.0"
opentelemetry = { version = "0.24", features = ["trace"] }
opentelemetry_sdk = { version = "0.24", features = ["trace"] }
reqwest = { version = "0.12", features = ["json", "rustls-tls", "stream"], default-features = false }
async-stream = "0.3"
rusqlite = { version = "0.32", features = ["bundled"] }
tokio-test = "0.4"
tokio-util = "0.7"
tower = "0.4"
tower-http = { version = "0.5", features = ["trace"] }
tracing-actix-web = "4"
tracing-opentelemetry = "0.24"


[package]
name = "hexakit"
version = "0.1.0"
edition = "2021"
license = "MIT OR Apache-2.0"
license-file = "LICENSE"
description = "HexaKit — Phenotype Infrastructure Kit: shared Rust crates powering the Phenotype platform (config, errors, logging, contracts, MCP, policy, compliance, analytics, etc.)"
homepage = "https://github.com/KooshaPari/HexaKit"
documentation = "https://docs.rs/hexakit"
repository = "https://github.com/KooshaPari/HexaKit"
readme = "README.md"
publish = false
keywords = ["phenotype", "hexa"]
categories = ["development-tools"]
authors = ["kooshapari"]
[dependencies]
sha2 = { workspace = true }
blake3 = { workspace = true }
hex = { workspace = true }
thiserror = { workspace = true }

# Release profile (moved from crates/settly and crates/stashly)
[profile.release]
lto = true
codegen-units = 1
