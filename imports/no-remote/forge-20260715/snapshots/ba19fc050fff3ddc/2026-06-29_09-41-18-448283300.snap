#!/usr/bin/env python3
"""
extractor.py — fast Python extractor for Codex + Claude Code conversation traces.

Produces three JSONL streams:
  raw_extract_index.jsonl       one row per trace (identity, sizes, token totals, models)
  raw_extract_turns.jsonl       one row per turn (text chars, tool calls, token counts, heuristic flags)
  raw_extract_artifacts.jsonl   one row per file path or repo/spec/ADR mention in a user/assistant/tool block

Designed to run in <2 minutes for 200+ Claude files plus 50 Codex files.

Usage: python extractor.py [--max-claude N] [--max-codex N] [--max-forge N] [--out-dir DIR]
"""
import argparse
import json
import os
import re
import sys
import time
from collections import Counter, defaultdict
from pathlib import Path

# ---- Heuristic thresholds (deliberately conservative; downstream can re-tune) ----
CACHE_REUSE_THRESHOLD_TOKENS = 4000
HANDLE_THRESHOLD_TOOL_PER_TURN = 3
SUMMARY_THRESHOLD_TOKENS = 20000
FULL_CTX_THRESHOLD_CHARS = 5000
SPAN_LONG_HORIZON_S = 86400

# ---- Artifact detection regex ----
FILE_RE = re.compile(r'(?i)([A-Za-z0-9_\-\./\\]+\.(?:md|markdown|json|ya?ml|toml|rs|py|ts|tsx|js|jsx|sh|ps1|bat|txt|sql|html|css|kt|swift|go|java|cs|cpp|c|h|hpp))')
ADR_RE = re.compile(r'(?i)((?:adr|architecture[-_]decision)[-_]?\d{2,4})')
SPEC_RE = re.compile(r'(?i)(/spec[s]?/[\w\-./]+)')


def normalize_path(p: str) -> str:
    return p.replace('\\', '/').lower()


def get_bucket(size: int, turn_count: int, first_ts: str, last_ts: str) -> str:
    long_h = False
    if first_ts and last_ts:
        try:
            from datetime import datetime
            a = datetime.fromisoformat(first_ts.replace('Z', '+00:00'))
            b = datetime.fromisoformat(last_ts.replace('Z', '+00:00'))
            if (b - a).total_seconds() >= SPAN_LONG_HORIZON_S:
                long_h = True
        except Exception:
            pass
    if turn_count >= 500 or size >= 524288:
        long_h = True
    if long_h:
        return 'long_horizon'
    if turn_count <= 5 and size <= 5120:
        return 'short'
    return 'medium'


def get_length_class(bucket: str) -> str:
    return 'long' if bucket == 'long_horizon' else bucket


# ---- Claude Code extractor ----

def extract_claude(path: Path):
    """Streaming pass over a Claude jsonl. Returns (trace_obj, [turn_rows], [artifact_rows])."""
    turns = []
    artifacts = []

    size = path.stat().st_size
    first_ts = ''
    last_ts = ''
    models = set()
    tool_use = 0
    tool_result = 0
    input_t = 0
    output_t = 0
    cache_creation_t = 0
    cache_read_t = 0
    session_id = ''
    agent_id = ''
    is_sidechain = False
    cwd = ''
    git_branch = ''
    version = ''
    slug = ''
    first_user_message = ''
    last_user_message_len = 0
    turn_idx = 0
    prev_ts_ms = 0
    context_size_chars = 0

    line_count = 0
    bad_count = 0

    with open(path, 'rb') as f:
        for raw in f:
            line_count += 1
            if not raw.strip():
                continue
            try:
                rec = json.loads(raw)
            except Exception:
                bad_count += 1
                continue

            if not session_id and rec.get('sessionId'):
                session_id = rec.get('sessionId')
            if rec.get('sessionId') and rec.get('isSidechain'):
                is_sidechain = True
            if rec.get('cwd'):
                cwd = rec.get('cwd')
            if rec.get('gitBranch'):
                git_branch = rec.get('gitBranch')
            if rec.get('version'):
                version = rec.get('version')
            if rec.get('slug'):
                slug = rec.get('slug')
            if rec.get('agentId'):
                agent_id = rec.get('agentId')

            ts_str = rec.get('timestamp') or ''
            ts_ms = 0
            if ts_str:
                try:
                    from datetime import datetime
                    dt = datetime.fromisoformat(ts_str.replace('Z', '+00:00'))
                    ts_ms = int(dt.timestamp() * 1000)
                    if not first_ts:
                        first_ts = ts_str
                    last_ts = ts_str
                except Exception:
                    pass

            rtype = rec.get('type')
            if rtype not in ('user', 'assistant'):
                continue

            msg = rec.get('message') or {}
            if msg.get('model'):
                models.add(msg['model'])

            text = ''
            tool_use_this_turn = 0
            tool_result_this_turn = 0
            tool_name_here = ''
            tool_input_chars = 0
            tool_result_chars = 0

            content = msg.get('content')
            if isinstance(content, str):
                text = content
            elif isinstance(content, list):
                parts = []
                for block in content:
                    bt = block.get('type')
                    if bt == 'text':
                        parts.append(block.get('text', ''))
                        # Artifact extraction from assistant/user text
                        for m in FILE_RE.finditer(block.get('text', '')):
                            artifacts.append((normalize_path(m.group(1)), rtype, '', m.end() - m.start()))
                        for m in ADR_RE.finditer(block.get('text', '')):
                            artifacts.append((normalize_path('/adr/' + m.group(1).lower()), rtype, '', m.end() - m.start()))
                        for m in SPEC_RE.finditer(block.get('text', '')):
                            artifacts.append((normalize_path(m.group(1)), rtype, '', m.end() - m.start()))
                    elif bt == 'tool_use':
                        tool_use += 1
                        tool_use_this_turn += 1
                        tname = block.get('name', '')
                        tool_name_here = tname
                        if tname:
                            models.add('tool:' + tname)
                        ti = block.get('input') or {}
                        # JSON compact for size; cheap and correct
                        tool_input_chars += len(json.dumps(ti, separators=(',', ':')))
                        for key in ('file_path', 'filePath', 'path', 'notebook_path'):
                            if key in ti:
                                fp = ti[key]
                                artifacts.append((normalize_path(fp), rtype, tname, len(fp)))
                                break
                        else:
                            if 'command' in ti:
                                cmd = ti['command']
                                if isinstance(cmd, str):
                                    cmd_short = cmd[:120]
                                    artifacts.append((normalize_path('cmd:' + cmd_short), rtype, tname, len(cmd_short)))
                            elif 'url' in ti:
                                artifacts.append((normalize_path('url:' + ti['url']), rtype, tname, len(ti['url'])))
                    elif bt == 'tool_result':
                        tool_result += 1
                        tool_result_this_turn += 1
                        tr = block.get('content')
                        if isinstance(tr, str):
                            tool_result_chars += len(tr)
                        elif isinstance(tr, list):
                            for tb in tr:
                                if isinstance(tb, dict) and tb.get('type') == 'text':
                                    tool_result_chars += len(tb.get('text', ''))
                text = '\n'.join(parts)

            usage = msg.get('usage') or {}
            input_turn = int(usage.get('input_tokens') or 0)
            output_turn = int(usage.get('output_tokens') or 0)
            cached_turn = int(usage.get('cache_read_input_tokens') or 0)
            cc_turn = int(usage.get('cache_creation_input_tokens') or 0)
            input_t += input_turn
            output_t += output_turn
            cache_read_t += cached_turn
            cache_creation_t += cc_turn

            turn_idx += 1
            context_size_chars += len(text)
            elapsed_ms = (ts_ms - prev_ts_ms) if prev_ts_ms > 0 else 0
            prev_ts_ms = ts_ms

            could_use_cache = (turn_idx > 1 and context_size_chars > CACHE_REUSE_THRESHOLD_TOKENS * 4 and cache_read_t == 0)
            could_use_handle = (tool_result_this_turn >= HANDLE_THRESHOLD_TOOL_PER_TURN)
            could_use_summary = (context_size_chars > SUMMARY_THRESHOLD_TOKENS * 4 and turn_idx > 5)
            requires_full_context = (rtype == 'user' and len(text) > FULL_CTX_THRESHOLD_CHARS)

            turns.append({
                'turn_idx': turn_idx,
                'role': rtype,
                'text_chars': len(text),
                'tool_name': tool_name_here,
                'tool_input_chars': tool_input_chars,
                'tool_result_chars': tool_result_chars,
                'input_tokens': input_turn,
                'cached_input_tokens': cached_turn,
                'output_tokens': output_turn,
                'elapsed_ms_since_prev': elapsed_ms,
                'context_size_chars_at_turn': context_size_chars,
                'could_use_cache': could_use_cache,
                'could_use_handle': could_use_handle,
                'could_use_summary': could_use_summary,
                'requires_full_context': requires_full_context,
                'ts': ts_str,
            })

            if rtype == 'user' and len(text) > 0:
                if not first_user_message:
                    first_user_message = text
                last_user_message_len = len(text)

    is_sub = ('\\subagents\\' in str(path) or '/subagents/' in str(path))
    depth = 0
    if is_sub:
        depth = 1
        parts = str(path).replace('\\', '/').split('/')
        for i, seg in enumerate(parts):
            if seg in ('subagents', 'nested', 'sub'):
                depth += 1

    bucket = get_bucket(size, turn_idx, first_ts, last_ts)

    return {
        'index': {
            'source': 'claudecode',
            'source_path': str(path),
            'source_file': path.name,
            'size_bytes': size,
            'line_count': line_count,
            'bad_lines': bad_count,
            'turn_count': turn_idx,
            'first_ts': first_ts,
            'last_ts': last_ts,
            'session_id': session_id,
            'parent_session_id': '',
            'agent_id': agent_id,
            'is_subagent': is_sub,
            'is_sidechain': is_sidechain,
            'fork_depth': depth,
            'agent_tree_depth': depth,
            'driver_type': 'agent_spawned' if is_sub else 'human',
            'driver_signal': 'subagents_dir' if is_sub else 'project_root',
            'driver_source': 'claude_path_heuristic',
            'project_root': path.parent.name,
            'cwd': cwd,
            'git_branch': git_branch,
            'version': version,
            'slug': slug,
            'models': ','.join(sorted(models)),
            'input_tokens': input_t,
            'output_tokens': output_t,
            'cache_creation_input_tokens': cache_creation_t,
            'cache_read_input_tokens': cache_read_t,
            'tool_use': tool_use,
            'tool_result': tool_result,
            'sent_tokens': cache_read_t + input_t,
            'first_user_message': first_user_message[:4000],
            'last_user_message_length': last_user_message_len,
            'bucket': bucket,
            'length_class': get_length_class(bucket),
        },
        'turns': turns,
        'artifacts': artifacts,
    }


# ---- Codex extractor ----

def extract_codex(path: Path):
    """Streaming pass over a Codex rollout jsonl. Note: Codex stores message text in
    event_msg.user_message.message AND in response_item.message.content.
    Token counts come from event_msg.token_count.info.total_token_usage.
    """
    turns = []
    artifacts = []

    size = path.stat().st_size
    first_ts = ''
    last_ts = ''
    models = set()
    tool_use = 0
    tool_result = 0
    input_t = 0
    output_t = 0
    cache_creation_t = 0
    cache_read_t = 0
    session_id = ''
    agent_id = ''
    cwd = ''
    git_branch = ''
    first_user_message = ''
    last_user_message_len = 0
    turn_idx = 0
    prev_ts_ms = 0
    context_size_chars = 0
    driver_type = 'human'
    driver_signal = ''
    thread_source = ''
    is_sub = False

    line_count = 0
    bad_count = 0

    with open(path, 'rb') as f:
        for raw in f:
            line_count += 1
            if not raw.strip():
                continue
            try:
                rec = json.loads(raw)
            except Exception:
                bad_count += 1
                continue

            ts = rec.get('timestamp') or ''
            ts_ms = 0
            if ts:
                try:
                    from datetime import datetime
                    dt = datetime.fromisoformat(ts.replace('Z', '+00:00'))
                    ts_ms = int(dt.timestamp() * 1000)
                    if not first_ts:
                        first_ts = ts
                    last_ts = ts
                except Exception:
                    pass

            t = rec.get('type')
            payload = rec.get('payload') or {}

            if t == 'session_meta':
                session_id = payload.get('id', '')
                cwd = payload.get('cwd', '')
                git_branch = payload.get('git_branch', '')
                agent_id = payload.get('model_provider', '')
                src_val = payload.get('source')
                if src_val and src_val != 'exec':
                    driver_type = 'agent_spawned'
                    is_sub = True
                if payload.get('thread_source') == 'agent':
                    driver_type = 'agent_spawned'
                    is_sub = True
                driver_signal = 'source=' + str(src_val)
                thread_source = payload.get('thread_source') or ''
            elif t == 'turn_context':
                if payload.get('model'):
                    models.add(payload['model'])
            elif t == 'event_msg':
                pt = payload.get('type')
                if pt == 'user_message':
                    msg = payload.get('message') or ''
                    text = msg if isinstance(msg, str) else json.dumps(msg, separators=(',', ':'))
                    if not first_user_message and text:
                        first_user_message = text
                    last_user_message_len = len(text)
                    for m in FILE_RE.finditer(text):
                        artifacts.append((normalize_path(m.group(1)), 'user_message', '', m.end() - m.start()))
                    for m in ADR_RE.finditer(text):
                        artifacts.append((normalize_path('/adr/' + m.group(1).lower()), 'user_message', '', m.end() - m.start()))
                    for m in SPEC_RE.finditer(text):
                        artifacts.append((normalize_path(m.group(1)), 'user_message', '', m.end() - m.start()))
                elif pt == 'token_count':
                    info = payload.get('info') or {}
                    tu = info.get('total_token_usage') or {}
                    input_t = int(tu.get('input_tokens') or 0)
                    output_t = int(tu.get('output_tokens') or 0)
                    cache_read_t = int(tu.get('cached_input_tokens') or 0)
                    turn_idx += 1
                    elapsed_ms = (ts_ms - prev_ts_ms) if prev_ts_ms > 0 else 0
                    prev_ts_ms = ts_ms
                    turns.append({
                        'turn_idx': turn_idx,
                        'role': 'token_count',
                        'text_chars': 0,
                        'tool_name': '',
                        'tool_input_chars': 0,
                        'tool_result_chars': 0,
                        'input_tokens': input_t,
                        'cached_input_tokens': cache_read_t,
                        'output_tokens': output_t,
                        'elapsed_ms_since_prev': elapsed_ms,
                        'context_size_chars_at_turn': context_size_chars,
                        'could_use_cache': (turn_idx > 1 and (cache_creation_t + cache_read_t) == 0),
                        'could_use_handle': False,
                        'could_use_summary': (context_size_chars > SUMMARY_THRESHOLD_TOKENS * 4 and turn_idx > 5),
                        'requires_full_context': False,
                        'ts': ts,
                    })
                    context_size_chars = input_t * 4
                elif pt == 'task_started':
                    turn_idx += 1
                    if payload.get('model_context_window'):
                        context_size_chars = int(payload['model_context_window']) * 4
            elif t == 'response_item':
                pt = payload.get('type')
                if pt == 'message':
                    role = payload.get('role') or ''
                    content = payload.get('content') or ''
                    text = ''
                    if isinstance(content, list):
                        parts = []
                        for block in content:
                            if block.get('type') in ('input_text', 'output_text', 'text'):
                                parts.append(block.get('text', ''))
                        text = '\n'.join(parts)
                    elif isinstance(content, str):
                        text = content
                    if role == 'user' and not first_user_message and text:
                        first_user_message = text[:4000]
                    if role == 'user':
                        last_user_message_len = len(text)
                    turn_idx += 1
                    elapsed_ms = (ts_ms - prev_ts_ms) if prev_ts_ms > 0 else 0
                    prev_ts_ms = ts_ms
                    turns.append({
                        'turn_idx': turn_idx,
                        'role': 'message_' + role,
                        'text_chars': len(text),
                        'tool_name': '',
                        'tool_input_chars': 0,
                        'tool_result_chars': 0,
                        'input_tokens': 0,
                        'cached_input_tokens': 0,
                        'output_tokens': 0,
                        'elapsed_ms_since_prev': elapsed_ms,
                        'context_size_chars_at_turn': context_size_chars,
                        'could_use_cache': False,
                        'could_use_handle': False,
                        'could_use_summary': False,
                        'requires_full_context': (role == 'user' and len(text) > FULL_CTX_THRESHOLD_CHARS),
                        'ts': ts,
                    })
                    # Artifact extraction
                    for m in FILE_RE.finditer(text):
                        artifacts.append((normalize_path(m.group(1)), 'message_' + role, '', m.end() - m.start()))
                    for m in ADR_RE.finditer(text):
                        artifacts.append((normalize_path('/adr/' + m.group(1).lower()), 'message_' + role, '', m.end() - m.start()))
                    for m in SPEC_RE.finditer(text):
                        artifacts.append((normalize_path(m.group(1)), 'message_' + role, '', m.end() - m.start()))
                elif pt in ('function_call', 'custom_tool_call'):
                    tool_use += 1
                    arg = payload.get('arguments') or payload.get('input')
                    arg_str = arg if isinstance(arg, str) else json.dumps(arg, separators=(',', ':'))
                    turn_idx += 1
                    elapsed_ms = (ts_ms - prev_ts_ms) if prev_ts_ms > 0 else 0
                    prev_ts_ms = ts_ms
                    turns.append({
                        'turn_idx': turn_idx,
                        'role': pt,
                        'text_chars': 0,
                        'tool_name': payload.get('name', ''),
                        'tool_input_chars': len(arg_str) if isinstance(arg_str, str) else 0,
                        'tool_result_chars': 0,
                        'input_tokens': 0,
                        'cached_input_tokens': 0,
                        'output_tokens': 0,
                        'elapsed_ms_since_prev': elapsed_ms,
                        'context_size_chars_at_turn': context_size_chars,
                        'could_use_cache': False,
                        'could_use_handle': False,
                        'could_use_summary': False,
                        'requires_full_context': False,
                        'ts': ts,
                    })
                elif pt in ('function_call_output', 'custom_tool_call_output'):
                    tool_result += 1
                    out = payload.get('output')
                    out_str = out if isinstance(out, str) else json.dumps(out, separators=(',', ':'))
                    turn_idx += 1
                    elapsed_ms = (ts_ms - prev_ts_ms) if prev_ts_ms > 0 else 0
                    prev_ts_ms = ts_ms
                    turns.append({
                        'turn_idx': turn_idx,
                        'role': pt,
                        'text_chars': 0,
                        'tool_name': '',
                        'tool_input_chars': 0,
                        'tool_result_chars': len(out_str) if isinstance(out_str, str) else 0,
                        'input_tokens': 0,
                        'cached_input_tokens': 0,
                        'output_tokens': 0,
                        'elapsed_ms_since_prev': elapsed_ms,
                        'context_size_chars_at_turn': context_size_chars,
                        'could_use_cache': False,
                        'could_use_handle': False,
                        'could_use_summary': False,
                        'requires_full_context': False,
                        'ts': ts,
                    })

    bucket = get_bucket(size, turn_idx, first_ts, last_ts)
    user_msg_count = sum(1 for t in turns if t['role'] in ('message_user', 'user'))

    return {
        'index': {
            'source': 'codex',
            'source_path': str(path),
            'source_file': path.name,
            'size_bytes': size,
            'line_count': line_count,
            'bad_lines': bad_count,
            'turn_count': user_msg_count,
            'first_ts': first_ts,
            'last_ts': last_ts,
            'session_id': session_id,
            'parent_session_id': '',
            'agent_id': agent_id,
            'is_subagent': is_sub,
            'is_sidechain': False,
            'fork_depth': 0,
            'agent_tree_depth': 0,
            'driver_type': driver_type,
            'driver_signal': driver_signal + ';thread_source=' + thread_source,
            'driver_source': 'codex_session_meta',
            'project_root': cwd,
            'cwd': cwd,
            'git_branch': git_branch,
            'version': '',
            'slug': '',
            'models': ','.join(sorted(models)),
            'input_tokens': input_t,
            'output_tokens': output_t,
            'cache_creation_input_tokens': cache_creation_t,
            'cache_read_input_tokens': cache_read_t,
            'tool_use': tool_use,
            'tool_result': tool_result,
            'sent_tokens': cache_read_t + input_t,
            'first_user_message': first_user_message,
            'last_user_message_length': last_user_message_len,
            'bucket': bucket,
            'length_class': get_length_class(bucket),
        },
        'turns': turns,
        'artifacts': artifacts,
    }


# ---- Forge (no conversation traces on this machine) ----

def extract_forge(path: Path):
    size = path.stat().st_size
    return {
        'index': {
            'source': 'forge',
            'source_path': str(path),
            'source_file': path.name,
            'size_bytes': size,
            'line_count': 0,
            'bad_lines': 0,
            'turn_count': 0,
            'first_ts': '',
            'last_ts': '',
            'session_id': '',
            'parent_session_id': '',
            'agent_id': '',
            'is_subagent': False,
            'is_sidechain': False,
            'fork_depth': 0,
            'agent_tree_depth': 0,
            'driver_type': 'unknown',
            'driver_signal': 'forge_no_conversation_trace',
            'driver_source': 'forge_no_conversation_trace',
            'project_root': path.parent.name,
            'cwd': '',
            'git_branch': '',
            'version': '',
            'slug': '',
            'models': '',
            'input_tokens': 0,
            'output_tokens': 0,
            'cache_creation_input_tokens': 0,
            'cache_read_input_tokens': 0,
            'tool_use': 0,
            'tool_result': 0,
            'sent_tokens': 0,
            'first_user_message': '',
            'last_user_message_length': 0,
            'bucket': 'short',
            'length_class': 'short',
        },
        'turns': [],
        'artifacts': [],
    }


# ---- Driver ----

def main():
    ap = argparse.ArgumentParser()
    ap.add_argument('--max-claude', type=int, default=132)
    ap.add_argument('--max-codex', type=int, default=48)
    ap.add_argument('--max-forge', type=int, default=4)
    ap.add_argument('--out-dir', default=r'C:\Users\koosh\AppData\Local\Temp\extract_stream')
    args = ap.parse_args()

    userprofile = os.environ.get('USERPROFILE') or os.path.expanduser('~')
    codex_root = Path(userprofile) / '.codex' / 'sessions'
    claude_root = Path(userprofile) / '.claude' / 'projects'
    forge_root = Path(userprofile) / '.forge' / 'sessions'

    out_dir = Path(args.out_dir)
    out_dir.mkdir(parents=True, exist_ok=True)
    index_path = out_dir / 'raw_extract_index.jsonl'
    turns_path = out_dir / 'raw_extract_turns.jsonl'
    artifacts_path = out_dir / 'raw_extract_artifacts.jsonl'
    # don't delete existing files — open with 'w' below overtruncates
    pass

    def list_files(root: Path, suffix: str, sort_desc: bool = True):
        if not root.exists():
            return []
        # Non-recursive + recursive mix: use rglob
        files = [f for f in root.rglob('*' + suffix) if f.is_file()]
        # sort by LastWriteTime desc
        files.sort(key=lambda f: f.stat().st_mtime, reverse=sort_desc)
        return files

    t0 = time.perf_counter()

    # Codex
    codex_files = [f for f in list_files(codex_root, '.jsonl') if f.stat().st_size > 200][:args.max_codex]
    print(f'Codex files: {len(codex_files)}', file=sys.stderr)
    cx_id = 0
    with index_path.open('a', encoding='utf-8') as idx_f, turns_path.open('a', encoding='utf-8') as trn_f, artifacts_path.open('a', encoding='utf-8') as art_f:
        for f in codex_files:
            cx_id += 1
            trace_id = f'cx{cx_id:03d}'
            res = extract_codex(f)
            res['index']['trace_id'] = trace_id
            for tr in res['turns']:
                tr['trace_id'] = trace_id
                trn_f.write(json.dumps(tr, separators=(',', ':')) + '\n')
            for path_norm, src_block, tool_name, chars in res['artifacts']:
                art_f.write(json.dumps({
                    'trace_id': trace_id,
                    'path_norm': path_norm,
                    'source_block': src_block,
                    'tool_name': tool_name,
                    'chars': chars,
                }, separators=(',', ':')) + '\n')
            idx_f.write(json.dumps(res['index'], separators=(',', ':')) + '\n')
    print(f'  Codex done in {time.perf_counter() - t0:.1f}s', file=sys.stderr)

    # Claude
    t1 = time.perf_counter()
    # Claude: prefer largest files (most informative), then most recent
    claude_files_all = list_files(claude_root, '.jsonl')
    claude_files_all = [f for f in claude_files_all if f.stat().st_size > 200]
    # Mix: 20 largest for token-rich data + rest = newest
    claude_large = sorted(claude_files_all, key=lambda f: f.stat().st_size, reverse=True)[:20]
    claude_recent = sorted(claude_files_all, key=lambda f: f.stat().st_mtime, reverse=True)
    seen = set()
    claude_files = []
    for f in claude_large + claude_recent:
        if f in seen:
            continue
        seen.add(f)
        claude_files.append(f)
        if len(claude_files) >= args.max_claude:
            break
    print(f'Claude files: {len(claude_files)} (mixed top-20-largest + newest)', file=sys.stderr)
    cl_id = 0
    with index_path.open('a', encoding='utf-8') as idx_f, turns_path.open('a', encoding='utf-8') as trn_f, artifacts_path.open('a', encoding='utf-8') as art_f:
        for f in claude_files:
            cl_id += 1
            trace_id = f'cl{cl_id:03d}'
            try:
                res = extract_claude(f)
            except Exception as e:
                print(f'  skip {f.name}: {e}', file=sys.stderr)
                continue
            res['index']['trace_id'] = trace_id
            for tr in res['turns']:
                tr['trace_id'] = trace_id
                trn_f.write(json.dumps(tr, separators=(',', ':')) + '\n')
            for path_norm, src_block, tool_name, chars in res['artifacts']:
                art_f.write(json.dumps({
                    'trace_id': trace_id,
                    'path_norm': path_norm,
                    'source_block': src_block,
                    'tool_name': tool_name,
                    'chars': chars,
                }, separators=(',', ':')) + '\n')
            idx_f.write(json.dumps(res['index'], separators=(',', ':')) + '\n')
            print(f'  cl{cl_id:03d}: {f.name}  size={f.stat().st_size:,}  turns={len(res["turns"])}', file=sys.stderr)
    print(f'  Claude done in {time.perf_counter() - t1:.1f}s', file=sys.stderr)

    # Forge (no-op conversation traces)
    t2 = time.perf_counter()
    if forge_root.exists():
        forge_files = list_files(forge_root, '')[:args.max_forge]
        # include non-suffix files like .justfile, .yml
        if not forge_files:
            forge_files = [f for f in forge_root.rglob('*') if f.is_file()][:args.max_forge]
    else:
        forge_files = []
    print(f'Forge files: {len(forge_files)}', file=sys.stderr)
    fg_id = 0
    with index_path.open('a', encoding='utf-8') as idx_f:
        for f in forge_files:
            fg_id += 1
            trace_id = f'fg{fg_id:03d}'
            res = extract_forge(f)
            res['index']['trace_id'] = trace_id
            idx_f.write(json.dumps(res['index'], separators=(',', ':')) + '\n')

    dt = time.perf_counter() - t0
    print(f'TOTAL: {dt:.1f}s', file=sys.stderr)
    print(f'Index  : {index_path.stat().st_size:,} bytes', file=sys.stderr)
    print(f'Turns  : {turns_path.stat().st_size:,} bytes', file=sys.stderr)
    print(f'Artefacts: {artifacts_path.stat().st_size:,} bytes', file=sys.stderr)


if __name__ == '__main__':
    main()
