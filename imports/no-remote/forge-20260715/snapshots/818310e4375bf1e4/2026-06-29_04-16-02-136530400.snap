import json, re
import json, sys
sys.stdout.reconfigure(encoding='utf-8')
with open(r'C:\Users\koosh\_repos_inventory.json','r',encoding='utf-8') as f:
    raw = f.read()
import re
ansi = re.compile(r'\x1b\[[0-9;]*[A-Za-z]')
clean = ansi.sub('', raw)
data = json.loads(clean)

nonforks = [r for r in data if not r['fork']]
forks = [r for r in data if r['fork']]

print(f'TOTAL: {len(data)}  NON-FORKS: {len(nonforks)}  FORKS: {len(forks)}')
print()

# Print non-forks sorted by name
print('=== NON-FORKS ===')
for r in sorted(nonforks, key=lambda x: x['name']):
    lang = r.get('lang', '') or '-'
    desc = (r.get('desc', '') or '')[:70]
    print(f'{r["name"]:35s} {lang:15s} | {desc}')

print()
print('=== FORKS ===')
for r in sorted(forks, key=lambda x: x['name']):
    lang = r.get('lang', '') or '-'
    desc = (r.get('desc', '') or '')[:70]
    print(f'{r["name"]:35s} {lang:15s} FORK | {desc}')

# Save clean JSON for agents
with open(r'C:\Users\koosh\_repos_clean.json', 'w') as f:
    json.dump(data, f, indent=2)
print('\nSaved clean JSON to _repos_clean.json')
