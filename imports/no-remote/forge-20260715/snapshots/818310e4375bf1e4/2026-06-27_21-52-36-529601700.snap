import json
with open(r'C:\Users\koosh\AppData\Local\Temp\forge_shell_stdout_GoNIsR.txt','r',encoding='utf-8') as f:
    data = json.load(f)

nonforks = [r for r in data if not r['fork']]
forks = [r for r in data if r['fork']]
print(f'ACTIVE: {len(data)}  NON-FORKS: {len(nonforks)}  FORKS: {len(forks)}')
print('=== NON-FORKS ===')
for r in sorted(nonforks, key=lambda x: x['name']):
    lang = (r.get('lang') or '')
    desc = (r.get('desc') or '')[:70]
    print(f'{r["name"]:35s} {lang:15s} | {desc}')
print('=== FORKS ===')
for r in sorted(forks, key=lambda x: x['name']):
    lang = (r.get('lang') or '')
    desc = (r.get('desc') or '')[:70]
    print(f'{r["name"]:35s} {lang:15s} | {desc}')
