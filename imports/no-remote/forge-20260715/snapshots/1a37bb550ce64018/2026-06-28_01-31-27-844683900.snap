# Write header with real tabs
[byte[]]$hdr = 0x62,0x72,0x61,0x6e,0x63,0x68,0x09,0x73,0x68,0x61,0x09,0x64,0x61,0x74,0x65
[System.IO.File]::WriteAllBytes($out, $hdr)

foreach ($entry in $list) {
  $name = $entry.n
  $sha  = $entry.s
  $api  = "repos/$repo/branches/$([uri]::EscapeDataString($name))"
  $date = gh api $api --jq ".commit.commit.committer.date" 2>$null
  if (-not $date) { $date = 'ERR' }
  $line = '{0}`t{1}`t{2}' -f $name, $sha, $date
  Write-Host $line
  Add-Content -Path $out -Value $line -Encoding utf8
}