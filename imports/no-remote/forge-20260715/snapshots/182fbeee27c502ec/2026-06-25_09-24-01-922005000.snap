name: Tier-1 Enforcement (PR Gate)

on:
  pull_request:
    branches: [main, master]
  push:
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read
  security-events: write
  pull-requests: write

jobs:
  # ── Job 1: Security scan (cargo audit) ──────────────────────────────
  security-audit:
    name: Security Audit (cargo-audit)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - uses: rustsec/audit-check@v2
        with:
          token: ${{ secrets.GITHUB_TOKEN }}

  # ── Job 2: SBOM generation & validation ─────────────────────────────
  sbom-check:
    name: SBOM Generation & Validation
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6

      - name: Install Rust toolchain
        uses: dtolnay/rust-toolchain@stable

      - name: Install cargo-cyclonedx
        uses: taiki-e/install-action@v2
        with:
          tool: cargo-cyclonedx

      - name: Generate CycloneDX SBOM
        run: |
          cargo cyclonedx --output-format json
          echo "✅ SBOM generated"

      - name: Validate SBOM output exists and is non-empty
        run: |
          sbom_file="$(ls *.cdx.json 2>/dev/null | head -1)"
          if [ -z "$sbom_file" ]; then
            echo "❌ No .cdx.json file found after generation"
            ls -la
            exit 1
          fi
          echo "✅ SBOM file: $sbom_file"
          size=$(wc -c < "$sbom_file")
          if [ "$size" -lt 100 ]; then
            echo "❌ SBOM file suspiciously small ($size bytes)"
            exit 1
          fi
          echo "✅ SBOM is valid ($size bytes)"

      - name: Upload SBOM as artifact
        uses: actions/upload-artifact@v7
        with:
          name: sbom-bomlet
          path: '*.cdx.json'
          retention-days: 60

  # ── Job 3: LICENSE presence & content check ─────────────────────────
  license-check:
    name: LICENSE Presence Check
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6

      - name: Verify LICENSE file exists
        run: |
          if [ -f LICENSE ]; then
            echo "✅ LICENSE file present"
            head -5 LICENSE
          elif [ -f LICENSE-MIT ]; then
            echo "✅ LICENSE-MIT file present"
            head -5 LICENSE-MIT
          elif [ -f LICENSE.md ]; then
            echo "✅ LICENSE.md file present"
            head -5 LICENSE.md
          elif [ -f LICENSE-MIT ]; then
            echo "✅ LICENSE-MIT file present"
            head -5 LICENSE-MIT
          elif [ -f LICENSE-Apache-2.0 ]; then
            echo "✅ LICENSE-Apache-2.0 file present"
            head -5 LICENSE-Apache-2.0
          elif [ -f LICENSE.txt ]; then
            echo "✅ LICENSE.txt file present"
            head -5 LICENSE.txt
          else
            echo "❌ No LICENSE file found"
            exit 1
          fi

      - name: Check LICENSE is not boilerplate empty
        run: |
          line_count=$(wc -l < LICENSE)
          if [ "$line_count" -lt 5 ]; then
            echo "❌ LICENSE file appears too short ($line_count lines); may be a placeholder"
            exit 1
          fi
          echo "✅ LICENSE file is substantive ($line_count lines)"

  # ── Job 4: CHANGELOG updated check ──────────────────────────────────
  changelog-check:
    name: CHANGELOG Update Check
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
        with:
          fetch-depth: 0

      - name: Check CHANGELOG.md was modified
        run: |
          if [ "${{ github.event_name }}" = "pull_request" ]; then
            base="${{ github.event.pull_request.base.sha }}"
            head="${{ github.event.pull_request.head.sha }}"
            if git diff --name-only "$base"..."$head" | grep -q "^CHANGELOG.md"; then
              echo "✅ CHANGELOG.md has been updated in this PR"
            else
              echo "❌ CHANGELOG.md has NOT been modified in this PR"
              echo "Please update CHANGELOG.md under [Unreleased] with your changes."
              exit 1
            fi
          else
            echo "⏭️ Skipping CHANGELOG check (not a PR event)"
          fi
