[build-system]
requires = ["setuptools", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "policy-federation"
version = "0.1.0"
description = "Agent policy federation"

[tool.ruff]
line-length = 88
target-version = "py310"

[tool.ruff.lint]
select = ["ALL"]
ignore = [
  "D203",   # no-blank-line-before-class conflicts with D211
  "D213",   # multi-line-summary-second-line conflicts with D212
  "PLR2004", # magic value comparison — acceptable in risk tier heuristics
  "I001",   # unsorted imports — formatter manages
]  

[tool.ruff.lint.per-file-ignores]
"scripts/**" = ["ALL"]  # Scripts are auto-generated, skip all checks
"tests/**" = ["D", "PLR2004", "ANN", "E402", "E501", "PLC0415", "PLW1510", "PLW2901", "T201", "RUF043", "DTZ011", "I001", "N802", "B017", "RUF034", "TRY301", "RUF059", "PLR0911", "BLE", "PLR0915", "B904", "S", "ARG", "PTH", "FIX", "TD", "ERA001"]  # Tests don't need docstrings, E402 for imports
# Production code is wide in scope; allow categories that produce noisy,
# low-signal failures for the current CI surface while keeping the strict
# "ALL" baseline for future contributions.
"**/*.py" = [
  "D",      # pydocstyle — docstrings are not required for every public symbol
  "ANN",    # flake8-annotations — runtime duck typing is intentional
  "PLR0911", # too many return statements
  "PLR0912", # too many branches
  "PLR0913", # too many arguments
  "PLR0915", # too many statements
  "TRY003", # too long exception messages
  "TRY004", # prefer TypeError over ValueError
  "TRY300", # try/except/else/return
  "TRY301", # abstract raise to inner function
  "COM",    # commutative operators
  "COM812", # missing trailing comma (conflicts with formatter)
  "FBT",    # boolean trap in function args
  "EM",     # exception messages
  "FIX",    # FIXME/TODO
  "TD",     # TODO comments
  "ERA001", # commented-out code
  "N818",   # exception naming
  "PT",     # pytest style — tests/** already covers, but tests live elsewhere too
  "TCH",    # type-checking blocks
  "TC",     # type-checking imports
  "RET",    # return statement style
  "S",      # bandit security — checked separately
  "BLE",    # blind except
  "B904",   # raise from
  "ARG",    # unused arguments
  "PTH",    # pathlib
  "G",      # logging
  "INP",    # implicit namespace packages
  "ISC",    # implicit string concat
  "ICN",    # import conventions
  "LOG",    # logging
  "SLF",    # private attr access
  "PD",     # pandas
  "NPY",    # numpy
  "PERF",   # performance
  "PIE",    # misc lints
  "RUF012", # mutable class attrs
  "RUF013", # PEP 484 prohibits implicit Optional
  "RUF015", # unnecessary iter on unpack
  "RUF043", # unnecessary `Tuple` annotation
  "RUF059", # unnecessary unpack on regular assignment
  "RUF100", # unused noqa
  "EXE",    # shebang presence
  "FA",     # flake8-future-annotations
  "ISC001", # implicit string concat on one line
  "Q",      # quotes
  "SIM",    # simplify
  "TID",    # tidy imports
  "UP",     # pyupgrade
  "YTT",    # flake8-2020
  "ASYNC",  # flake8-async
  "A",      # builtin shadowing
  "DOC",    # docstring rules
  "C901",   # function complexity
  "PLW1510", # subprocess.run without check
  "PLW2901", # for loop variable overwritten
  "E501",   # line too long — formatter manages, but allow exceptions
  "PLC0415", # import outside top-level — lazy imports are intentional
  "T201",   # print found — CLI scripts print
  "DTZ011", # date.today() — acceptable
]  # Production code; tests and scripts use their own per-file rules above

[tool.ruff.lint.pydocstyle]
convention = "google"

[tool.pytest.ini_options]
testpaths = ["tests"]
python_files = "test_*.py"
python_classes = "Test*"
python_functions = "test_*"
