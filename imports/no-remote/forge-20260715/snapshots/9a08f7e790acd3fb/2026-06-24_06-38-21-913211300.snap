$ErrorActionPreference = 'Stop'
$bashScript = 'C:\Users\koosh\forge\agentuserstatus-merge\phenotype-tooling\bin\repo-delete-gate.sh'
$psScript   = 'C:\Users\koosh\forge\agentuserstatus-merge\phenotype-tooling\bin\repo-delete-gate.ps1'

Write-Host '== bash syntax check =='
& bash -n $bashScript
if ($LASTEXITCODE -eq 0) { 'BASH_OK' } else { 'BASH_FAIL' }

