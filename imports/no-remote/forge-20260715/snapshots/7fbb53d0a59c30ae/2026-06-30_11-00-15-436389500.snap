  "key_findings": [
    {
      "id": "F1-CRITICAL-resolver3",
      "severity": "critical",
      "title": "Cargo.toml uses invalid resolver='3' — all cargo-based grade checks fail 0/17 = F",
      "evidence": "Cargo.toml:2 has 'resolver = \"3\"'. Valid options are '1' or '2'. cargo rejects the manifest, so every cargo-derived check returns 0/2 or 0/3: build, test-unit, fmt, clippy, doc, test-snapshot, test-fuzz, coverage. Confirmed at HEAD (49fa8a1) and at main (0a81178) — introduced by PR #370 (commit 4616b35 'feat(registry): absorption-justification fleet + cross-repo grade dashboard'), 2026-06-25. .grade-reports/grade.json shows score:0/17 grade:F (timestamp 2026-06-30T04:27:41Z). Likely intended was 'resolver = \"2\"' (edition 2021 default with features).",
      "blast_radius": "Registry's own grade is broken. Any repo that consumes registry metadata or uses these same templates inherits the defect. Validator/auditor lookups over registry as a standards hub cannot trust grade.json until patched.",
      "remediation_pointer": "Patch Cargo.toml:2 'resolver = \"3\"' -> 'resolver = \"2\"' (preferred for edition 2021 with features= support). Then re-run bash grade.sh --json."
    },
    {
      "id": "F2-HIGH-deny-toml-unexpected-keys",
      "severity": "high",
      "title": "deny.toml uses cargo-deny v0.16+ keys that the installed cargo-deny cannot parse",
      "evidence": "deny.toml:27 'wildcard-dependencies = \"allow\"' is unexpected; cargo-deny version in use does not recognize it. deny.toml:4 '[dependencies]' with 'warn-on-unused' is also unrecognized (new schema is a different layout). .grade-reports/deny.raw records these errors. Blocks deny (security license/advisory gate) and incidentally makes the audit pillar non-passing.",
      "remediation_pointer": "Either downgrade deny.toml to old schema or upgrade cargo-deny binary. Recommend upgrading deny to current schema (drop wildcard-dependencies, move warn-on-unused to top-level or [graph])."
    },
    {
      "id": "F3-HIGH-nanovms-status-3way-conflict",
      "severity": "high",
      "title": "nanovms status disagrees across 3 SSOT candidate files",
      "evidence_cards": {
        "projects/nanovms.json:5": "\"status\": \"archived\"",
        "catalog/registry.yaml:475": "  - id: nanovms ... status: active ... tier: federated-service ... role: platform",
        "audits/absorption-justifications/nanovms-2026-06-30.md": "verdict AFFIRM, 'retained active Go/TS infra surface'"
      },
      "also_at_variance_with": [
        "DOMAIN_ROLES.md platform row (nanovms crate in tooling, consistent with active/federated)",
        "ECOSYSTEM_MAP.md 'shared-lib' row (nanovms 3-tier VMM listed as live)",
        "audits/absorption-justifications/GRADES.md shows 'nanovms-2026-06-30.md 14/14 L4'"
      ],
      "blast_radius": "Cross-repo consumers cannot resolve 'is nanovms absorpable or not'. Validator-loop auto-units from grade deltas can flip dispositions. ADR-049 references 'phenotype-infra/crates/nanovms-core' as canonical, but the top-level projects card still asserts archived.",
      "remediation_pointer": "Reconcile by either (a) updating projects/nanovms.json to {status:'active', archived:false, disposition:'AFFIRM'} to match catalog + audit, or (b) updating catalog/registry.yaml + 3 audits if there's a real plan to archive. Recommend (a) — audits are recent and explicit, and DOMAIN_ROLES.md already implies active."
    },
    {
      "id": "F4-MEDIUM-uncommitted-changes-on-A18-branch",
      "severity": "medium",
      "title": "config/A18-license-adoption has meaningful uncommitted changes",
      "evidence": "git status --short: 'M Cargo.toml', 'M LICENSE-APACHE', 'M package.json', '?? NOTICE', '?? agileplus-specs/005-compute-infra-hardening/'. Diff context: Cargo.toml adds [workspace.package] license and [package] license.workspace=true. LICENSE-APACHE swaps a 2-line placeholder for the full 201-line Apache-2.0 text. package.json has minor edits. Plus untracked NOTICE (Apache §4(d) attribution file) and a new agileplus-specs/005-... tree for A18 work packages.",
      "blast_radius": "If the auditor is responsible for `config/A18-license-adoption`, the working tree has uncommitted state tied to A18 (apache license adoption). The A18 spec at agileplus-specs/005-compute-infra-hardening/A18-license-adoption/spec.md (lines 33, 40) flags this registry as 'placeholder Apache' — these uncommitted edits are the in-progress fix. Any push or merge must include them.",
      "remediation_pointer": "Stage + commit these changes under a single conventional-commits message e.g. 'feat(registry, A18): adopt Apache-2.0 LICENSE + NOTICE + dual-license manifest' before merging config/A18-license-adoption."
    },
    {
      "id": "F5-MEDIUM-sota-md-is-template",
      "severity": "medium",
      "title": "SOTA.md is a literal unfilled template (no concrete content) at the standards spine",
      "evidence": "Every dimension in SOTA.md uses {{TOKEN}} placeholders: {{PROJECT_NAME}}, {{DATE}}, {{TECH_CHOICE}}, {{DX_CHOICE}}, {{UX_CHOICE}}, etc. Yet DAG yaml meta.standards_authority='phenotype-registry' and DOMAIN_ROLES.md line 3 declares 'Authority: phenotype-registry'. The hub documents authority but does not exercise its own SOTA format.",
      "note": "This may be intentional for the 'index/governance' repo (vs. an app repo), but it is not documented as an exception in any ADR or rules file.",
      "remediation_pointer": "Either (a) author an actual SOTA.md describing registry's own choices, or (b) add an ADR/decision noting this repo is exempt from the SOTA template because it is an index, not a runtime substrate."
    },
