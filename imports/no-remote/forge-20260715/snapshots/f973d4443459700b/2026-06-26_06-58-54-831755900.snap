[package]
name = "nvms-ffi"
version = "0.1.0"
edition = "2021"
description = "Rust FFI bindings to NVMS Go Core"
license = "MIT OR Apache-2.0"
repository = "https://github.com/KooshaPari/PhenoCompose"
documentation = "https://docs.rs/nvms-ffi"
keywords = ["phenotype", "pheno-compose", "ffi"]
categories = ["api-bindings"]
authors = ["kooshapari"]

[dependencies]

[build-dependencies]
bindgen = "0.68"

[#[features]
default = []

# Historical note: a `cuda = []` feature was removed in 2026-06-23 (PC-001
# from plans/2026-06-22-compute-infra-dag-v1.md). The flag was never
# referenced via `#[cfg(feature = "cuda")]` anywhere in the source; the
# `nvms_cuda_*` symbols in the FFI are always available through the
# in-process `shim` module (and the externally-linked C library once
# nanovms's CGo archive is wired in per CONSOLIDATION.md #2).
#
# If we later gate actual CUDA-specific codegen behind a feature, the
# flag name to revive is `cuda` (with the standard `dep:` prefix on
# any optional dependency it ends up depending on).

# ── WASM feature ─────────────────────────────────────────────────────
#
# Enable when cross-compiling to wasm32-wasi.  This marks the build
# for a WASM target so the build script can skip bindgen and limit
# crate-types to `rlib` only.
wasm = []

[lib]
name = "nvms_ffi"
crate-type = ["rlib"]

# NOTE: cdylib / staticlib are added dynamically by build.rs when the
# `wasm` feature is NOT active (i.e. for native targets).  On
# wasm32-wasi those crate-types are invalid, so we keep only rlib here.
