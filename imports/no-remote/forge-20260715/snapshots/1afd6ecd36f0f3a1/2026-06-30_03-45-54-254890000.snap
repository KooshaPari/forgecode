{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": false,
    "checkJs": false,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": false,
    "lib": ["dom", "esnext"],
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@omniroute/open-sse": ["./open-sse"],
      "@omniroute/open-sse/*": ["./open-sse/*"]
    }
  },
  "include": [
    "open-sse/config/providers/index.ts",
    "open-sse/config/providers/shared.ts",
    "open-sse/config/providers/registry/clinepass/index.ts",
    "open-sse/config/providers/registry/crof/index.ts"
  ]
}
