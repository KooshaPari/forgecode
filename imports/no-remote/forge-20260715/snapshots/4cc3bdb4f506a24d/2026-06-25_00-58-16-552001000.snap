name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
  workflow_dispatch:

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  ci:
    name: Python CI
    continue-on-error: true
    uses: KooshaPari/template-commons/.github/workflows/reusable-python-ci.yml@main
    with:
      python-versions: "[\"3.9\", \"3.10\", \"3.11\", \"3.12\"]"
      enable-coverage: true

  security:
    name: Security Audit
    continue-on-error: true
    uses: KooshaPari/template-commons/.github/workflows/reusable-security-scan.yml@main
    with:
      language: python
    secrets:
      SEMGREP_APP_TOKEN: ${{ secrets.SEMGREP_APP_TOKEN }}

  phenotype-validate:
    name: Governance Validation
    continue-on-error: true
    uses: KooshaPari/phenotypeActions/.github/workflows/validate-governance.yml@main

