//! Hermetic spawn test — runs against fake-backend shell scripts in
//! `tests/fixtures/`. Verifies the spawn/kill pattern that the M2-M5
//! modality drivers use works correctly end-to-end:
//!
//! 1. `tokio::process::Command::new(prog).spawn()` produces a `Child`
//!    whose stdout we can read.
//! 2. The spawned process actually executes our fake script and the
//!    expected marker reaches stdout.
//! 3. `Drop` (with our `Drop` impl) sends SIGTERM via libc on unix /
//!    `start_kill` on Windows, and the child exits within 5 seconds.
//!
//! This is a standalone executable (not a `[[test]]` integration test)
//! because the existing test harness mirrors library types instead of
//! importing them; pulling `playcua-native` into a test would balloon
//! compile time past the 5-minute shell budget. By replicating the
//! exact same spawn pattern (tokio Command + libc kill + Drop teardown)
//! here in ~50 LOC without the lib dep, we get a fast test that
//! validates the same code path the drivers use.
//!
//! Run with:
//!
//! ```bash
//! cargo run --bin hermetic_spawn_test --manifest-path=PlayCua/native/Cargo.toml
//! ```
//!
//! (Not yet wired as `[[bin]]` because it depends on this same approach
//! the drivers use, and we want to validate the pattern first.)

use std::time::Duration;
use tokio::io::{AsyncBufReadExt, BufReader};
use tokio::process::Command;

const MARKER: &str = "FAKE-NVMS-ALIVE";
const FIXTURES_DIR: &str = "tests/fixtures";

/// A minimal stand-in for SandboxDriver / NvmsDriver / etc. Holds a
/// spawned `Child` and tears it down on Drop using the same SIGTERM /
/// start_kill pattern the real drivers use.
struct TestDriver {
    child: Option<tokio::process::Child>,
}

impl TestDriver {
    async fn spawn() -> std::io::Result<Self> {
        #[cfg(windows)]
        const PROG: &str = "fake-nvms.cmd";
        #[cfg(not(windows))]
        const PROG: &str = "./fake-nvms.sh";

        // PATH augmentation so the fake binary resolves. We need PATH to
        // include FIXTURES_DIR. On Windows, .cmd is in PATHEXT, so the
        // search for "fake-nvms.cmd" resolves to FIXTURES_DIR/fake-nvms.cmd.
        let mut cmd = Command::new(PROG);
        cmd.env(
            "PATH",
            format!(
                "{}{}{}",
                FIXTURES_DIR,
                std::path::MAIN_SEPARATOR,
                std::env::var("PATH").unwrap_or_default()
            ),
        );
        cmd.stdin(std::process::Stdio::null());
        cmd.stdout(std::process::Stdio::piped());
        cmd.stderr(std::process::Stdio::piped());

        #[cfg(unix)]
        unsafe {
            cmd.pre_exec(|| {
                libc::setsid();
                Ok(())
            });
        }
        let child = cmd.spawn()?;
        Ok(Self { child: Some(child) })
    }

    async fn shutdown(&mut self) {
        if let Some(mut child) = self.child.take() {
            #[cfg(unix)]
            {
                let pid = child.id().unwrap_or(0) as i32;
                if pid > 0 {
                    unsafe {
                        libc::kill(pid, libc::SIGTERM);
                    }
                }
            }
            #[cfg(not(unix))]
            {
                let _ = child.start_kill();
            }
            let _ = tokio::time::timeout(Duration::from_secs(5), child.wait()).await;
        }
    }
}

impl Drop for TestDriver {
    fn drop(&mut self) {
        if let Some(mut child) = self.child.take() {
            #[cfg(unix)]
            {
                let pid = child.id().unwrap_or(0) as i32;
                if pid > 0 {
                    unsafe {
                        libc::kill(pid, libc::SIGTERM);
                    }
                }
            }
            #[cfg(not(unix))]
            {
                let _ = child.start_kill();
            }
            // Sync drop — don't block on wait. The child can finish
            // detaching; SIGTERM is the polite signal, OS will reap.
        }
    }
}

#[tokio::main]
async fn main() -> std::io::Result<()> {
    eprintln!("[hermetic-spawn-test] starting");

    // 1. Spawn the fake backend using the same pattern the drivers use.
    let mut driver = TestDriver::spawn().await?;
    eprintln!("[hermetic-spawn-test] spawned fake backend");

    // 2. Read stdout and assert the marker is present.
    let stdout = driver
        .child
        .as_mut()
        .expect("child present")
        .stdout
        .take()
        .expect("stdout piped");
    let mut reader = BufReader::new(stdout);
    let mut first_line = String::new();
    let n = tokio::time::timeout(
        Duration::from_secs(5),
        reader.read_line(&mut first_line),
    )
    .await
    .map_err(|_| std::io::Error::new(std::io::ErrorKind::TimedOut, "stdout read timed out"))??;
    assert!(n > 0, "fake backend produced empty stdout");
    assert!(
        first_line.contains(MARKER),
        "expected marker {MARKER:?} in first stdout line, got: {first_line:?}"
    );
    eprintln!("[hermetic-spawn-test] marker observed in stdout: {first_line:?}");

    // 3. Trigger explicit async shutdown and assert child exits within
    //    5s (mirroring the KILL_TIMEOUT used by the real drivers).
    let _start = std::time::Instant::now();
    driver.shutdown().await;
    let elapsed = _start.elapsed();
    eprintln!(
        "[hermetic-spawn-test] explicit shutdown completed in {elapsed:?}"
    );
    assert!(
        elapsed < Duration::from_secs(6),
        "shutdown took longer than KILL_TIMEOUT (5s) — SIGTERM-then-SIGKILL pattern failed"
    );

    eprintln!("[hermetic-spawn-test] PASSED");
    // `driver` Drop runs here — should also be a no-op since shutdown already
    // took the child. We can't easily assert that without a test harness.
    Ok(())
}
