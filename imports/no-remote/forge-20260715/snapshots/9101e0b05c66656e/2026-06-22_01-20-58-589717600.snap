//! phenotype-event-store
//!
//! Durable SQLite-backed event store with outbox + DLQ + JSON schema registry
//! + read-model projections. Absorbed from `KooshaPari/phenoEvents` on
//! 2026-06-21.
//!
//! ## Modules
//!
//! - [`bus`]     ‚Äî `SqliteBus` (durable outbox + DLQ) and `InMemoryBus`
//!                 (compatibility shim delegating to `phenotype-event-bus`).
//! - [`core`]    ‚Äî `EventEnvelope` (UUIDv7 id, causation/correlation,
//!                 schema version, JSON payload).
//! - [`schema`]  ‚Äî Additive JSON schema registry with version lookups.
//! - [`projection`] ‚Äî SQL read-model projection with checkpointing.
//!                 Observability hooks go through the standard `tracing`
//!                 crate (no re-export needed).
//!
//! ## Quick start
//!
//! ```no_run
//! use phenotype_event_store::prelude::*;
//!
//! # async fn run() -> Result<(), Box<dyn std::error::Error>> {
//! let bus = SqliteBus::connect("sqlite::memory:").await?;
//! let envelope = EventEnvelope::new(
//!     "orders.created",
//!     serde_json::json!({"order_id": "o-1"}),
//! );
//! bus.publish(envelope).await?;
//! # Ok(()) }
//! ```

pub mod bus;
pub mod core;
pub mod projection;
pub mod schema;

pub mod prelude {
    //! Convenience re-exports for downstream crates.
    pub use crate::bus::{InMemoryBus, SqliteBus};
    pub use crate::core::{EventEnvelope, EventId};
    pub use crate::projection::{OrderProjection, ProjectionCheckpoint, ProjectionError};
    pub use crate::schema::{SchemaError, SchemaId, SchemaRecord, SchemaRegistry};
}
