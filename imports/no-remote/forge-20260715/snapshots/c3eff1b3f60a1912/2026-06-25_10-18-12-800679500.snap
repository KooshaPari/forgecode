# =============================================================================
#  OmniRoute — Kubernetes deployment for the OTel Collector sidecar
# =============================================================================
#  Apply with:
#    kubectl apply -f deploy/k8s/omniroute-collector-config.yaml
#
#  What this bundle provides:
#    1. ConfigMap carrying the collector.yaml (mounted at /etc/otelcol-contrib)
#    2. Deployment running 2 replicas of the contrib image (HPA-friendly)
#    3. Service exposing OTLP gRPC/HTTP + the health endpoint
#    4. ServiceMonitor so Prometheus Operator scrapes the collector self-metrics
# =============================================================================

---
apiVersion: v1
kind: ConfigMap
metadata:
  name: omniroute-collector-config
  namespace: omniroute
  labels:
    app.kubernetes.io/name: omniroute-collector
    app.kubernetes.io/part-of: omniroute
data:
  collector.yaml: |
    # Auto-generated from deploy/otel-collector/collector.yaml — keep in sync
    # via `kubectl create configmap ... --from-file=...` or your GitOps tool.
    extensions:
      health_check:
        endpoint: 0.0.0.0:13133
      pprof:
        endpoint: 0.0.0.0:1777
      zpages:
        endpoint: 0.0.0.0:55679
      bearertokenauth:
        token: ${env:OTEL_AUTH_TOKEN}

    receivers:
      otlp:
        protocols:
          grpc:
            endpoint: 0.0.0.0:4317
          http:
            endpoint: 0.0.0.0:4318
      prometheus:
        config:
          scrape_configs:
            - job_name: omniroute
              static_configs:
                - targets: ["omniroute.omniroute.svc:20128"]
      hostmetrics:
        collection_interval: 30s
        scrapers: [cpu, memory, disk, filesystem, network]
      filelog:
        include: [/var/log/omniroute/*.log]
        operators:
          - type: json_parser

    processors:
      memory_limiter:
        check_interval: 2s
        limit_percentage: 80
        spike_limit_percentage: 25
      resourcedetection:
        detectors: [env, system, gcp, ec2, azure]
      batch:
        timeout: 5s
        send_batch_size: 1024
      attributes/cost:
        actions:
          - key: omniroute.tenant.id
            from_attribute: http.request.header.x-tenant-id
            action: insert
      filter/health:
        traces:
          span: ['name == "omniroute.health.check"']

    exporters:
      prometheusremotewrite:
        endpoint: http://prometheus.monitoring.svc:9090/api/v1/write
        tls: {insecure: true}
      otlp/backend:
        endpoint: jaeger.observability.svc:4317
        tls: {insecure: true}
      logging:
        loglevel: info

    service:
      extensions: [health_check, pprof, zpages, bearertokenauth]
      telemetry:
        logs: {level: info}
        metrics: {address: 0.0.0.0:8888}
      pipelines:
        traces:
          receivers: [otlp]
          processors: [memory_limiter, resourcedetection, attributes/cost, filter/health, batch]
          exporters: [otlp/backend, logging]
        metrics:
          receivers: [otlp, prometheus, hostmetrics]
          processors: [memory_limiter, resourcedetection, batch]
          exporters: [prometheusremotewrite, logging]
        logs:
          receivers: [otlp, filelog]
          processors: [memory_limiter, resourcedetection, batch]
          exporters: [logging]

---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: omniroute-collector
  namespace: omniroute
  labels:
    app.kubernetes.io/name: omniroute-collector
    app.kubernetes.io/part-of: omniroute
spec:
  replicas: 2
  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxSurge: 1
      maxUnavailable: 0
  selector:
    matchLabels:
      app.kubernetes.io/name: omniroute-collector
  template:
    metadata:
      labels:
        app.kubernetes.io/name: omniroute-collector
        app.kubernetes.io/part-of: omniroute
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "8888"
        prometheus.io/path: /metrics
    spec:
      serviceAccountName: omniroute-collector
      securityContext:
        runAsNonRoot: true
        runAsUser: 10001
        runAsGroup: 10001
        fsGroup: 10001
      containers:
        - name: collector
          image: omniroute/otel-collector:0.96.0
          imagePullPolicy: IfNotPresent
          args:
            - "--config=/etc/otelcol-contrib/config.yaml"
          env:
            - name: OTEL_AUTH_TOKEN
              valueFrom:
                secretKeyRef:
                  name: omniroute-collector-secret
                  key: token
          ports:
            - name: otlp-grpc
              containerPort: 4317
            - name: otlp-http
              containerPort: 4318
            - name: health
              containerPort: 13133
            - name: pprof
              containerPort: 1777
            - name: zpages
              containerPort: 55679
            - name: self-metrics
              containerPort: 8888
          resources:
            requests:
              cpu: 200m
              memory: 256Mi
            limits:
              cpu: 1000m
              memory: 1Gi
          livenessProbe:
            httpGet:
              path: /
              port: health
            initialDelaySeconds: 15
            periodSeconds: 15
            timeoutSeconds: 3
            failureThreshold: 3
          readinessProbe:
            httpGet:
              path: /
              port: health
            initialDelaySeconds: 5
            periodSeconds: 10
            timeoutSeconds: 3
            failureThreshold: 3
          volumeMounts:
            - name: config
              mountPath: /etc/otelcol-contrib
              readOnly: true
            - name: logs
              mountPath: /var/log/omniroute
      volumes:
        - name: config
          configMap:
            name: omniroute-collector-config
        - name: logs
          emptyDir: {}

---
apiVersion: v1
kind: Service
metadata:
  name: omniroute-collector
  namespace: omniroute
  labels:
    app.kubernetes.io/name: omniroute-collector
spec:
  type: ClusterIP
  ports:
    - name: otlp-grpc
      port: 4317
      targetPort: otlp-grpc
    - name: otlp-http
      port: 4318
      targetPort: otlp-http
    - name: health
      port: 13133
      targetPort: health
    - name: self-metrics
      port: 8888
      targetPort: self-metrics
  selector:
    app.kubernetes.io/name: omniroute-collector

---
# ServiceMonitor — consumed by Prometheus Operator (kube-prometheus-stack).
apiVersion: monitoring.coreos.com/v1
kind: ServiceMonitor
metadata:
  name: omniroute-collector
  namespace: omniroute
  labels:
    app.kubernetes.io/name: omniroute-collector
    release: prometheus
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: omniroute-collector
  endpoints:
    - port: self-metrics
      path: /metrics
      interval: 30s
      scrapeTimeout: 10s

---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: omniroute-collector
  namespace: omniroute

---
# Bearer token used by `bearertokenauth` extension in the collector.yaml.
# Replace before applying; in production pull from your secrets backend.
apiVersion: v1
kind: Secret
metadata:
  name: omniroute-collector-secret
  namespace: omniroute
type: Opaque
stringData:
  token: "changeme-otel-token"