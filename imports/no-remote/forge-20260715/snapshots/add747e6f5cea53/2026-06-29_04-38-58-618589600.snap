/**
 * latencyBudget.ts — Per-request latency budget enforcement (#3932).
 *
 * Problem:
 *   At ~500-1000 req/min with 100-200 concurrent agent sessions, OmniRoute
 *   was paying for non-essential observation work (Bifrost shadow calls,
 *   agreement scoring, call-log payload capture, response body logging) on
 *   every request. Under load these non-essential work blocks added 5-45s
 *   to API responses. The fix is to give each request a wall-clock budget
 *   and SKIP non-essential work as the budget elapses.
 *
 * Design:
 *   - A `LatencyBudget` is created at request entry and tracks elapsed time
 *     against a per-tier budget (fast / standard / long) chosen by the
 *     client via the `X-Latency-Tier` header, or defaulted to `standard`.
 *   - Work that wants to short-circuit on budget exhaustion calls
 *     `budget.remaining()` and bails when remaining <= 0. A short-circuit
 *     is logged as a "skip" with the work's name so the operator can see
 *     which work blocks are being shed under load.
 *   - The budget can be attached to a Response via `setBudgetResponseHeader`
 *     which adds an `X-Latency-Budget` header on the way out, exposing
 *     (used_ms / total_ms) for the operator dashboard.
 *   - Tiers are overridable via env vars (`OMNIROUTE_LATENCY_BUDGET_FAST_MS`,
 *     etc.) so an operator can tighten or loosen the policy without a
 *     rebuild.
 *
 * Why three tiers (not one global budget):
 *   - A 30s tier is fine for "give me a streaming chat response" but
 *     catastrophic for "summarize 20 PDFs" (background agent) where the
 *     client opted in to a long response time. Tiers let the client
 *     declare its expectation; the operator can monitor tier usage
 *     via the response header.
 *
 * Reference: docs/adr/0032-latency-budget.md (forthcoming).
 */

export type LatencyTier = "fast" | "standard" | "long";

const DEFAULT_TIER_BUDGETS_MS: Record<LatencyTier, number> = {
  // Streaming chat / quick completions. 8s is generous; Claude Code's
  // own per-request deadline is around this. Anything longer is operator-
  // visible as latency and almost always means upstream slowness, not
  // our own work.
  fast: 8_000,
  // Default tier for non-streaming chat. 30s covers all current providers
  // for first-token + body. Anything beyond this is up to 5x slower than
  // our worst-case target.
  standard: 30_000,
  // Background-agent tier (long summarization, batch jobs). 120s lets the
  // upstream take its time without us shedding legitimate work.
  long: 120_000,
};

const TIER_HEADER = "x-latency-tier";

/**
 * Resolve a tier from a request's headers, with an env-var override on the
 * default tier. Unknown / malformed values fall back to "standard".
 */
export function resolveLatencyTier(headers: Record<string, string | string[] | undefined>): LatencyTier {
  const raw = headers["x-latency-tier"] ?? headers["X-Latency-Tier"];
  const value = Array.isArray(raw) ? raw[0] : raw;
  if (typeof value !== "string") return "standard";
  const normalized = value.toLowerCase().trim();
  if (normalized === "fast" || normalized === "standard" || normalized === "long") {
    return normalized;
  }
  return "standard";
}

/**
 * Resolve a tier's total budget in ms, reading from env overrides.
 *   OMNIROUTE_LATENCY_BUDGET_FAST_MS
 *   OMNIROUTE_LATENCY_BUDGET_STANDARD_MS
 *   OMNIROUTE_LATENCY_BUDGET_LONG_MS
 * Override must be a positive finite number, otherwise the default applies.
 */
export function resolveTierBudgetMs(tier: LatencyTier, env: NodeJS.ProcessEnv = process.env): number {
  const key = `OMNIROUTE_LATENCY_BUDGET_${tier.toUpperCase()}_MS`;
  const raw = env[key];
  if (typeof raw === "string" && raw.length > 0) {
    const parsed = Number(raw);
    if (Number.isFinite(parsed) && parsed > 0) return parsed;
  }
  return DEFAULT_TIER_BUDGETS_MS[tier];
}

export interface LatencyBudget {
  /** The tier this budget is enforcing. */
  readonly tier: LatencyTier;
  /** Total budget in ms (snapshotted at construction). */
  readonly totalMs: number;
  /** Wall-clock ms elapsed since the budget was created. */
  readonly elapsedMs: number;
  /** Remaining budget in ms (never goes below 0). */
  readonly remainingMs: number;
  /** True if the budget is exhausted (remaining <= 0). */
  readonly exhausted: boolean;
  /**
   * Run `work` if the budget is not exhausted; otherwise invoke `onSkip`
   * with the work's name and skip. The work function receives the budget
   * snapshot so it can make finer-grained decisions (e.g. only do the
   * "expensive half" if remaining > half the budget).
   */
  tryRun<T>(opts: {
    name: string;
    work: (budget: LatencyBudget) => Promise<T> | T;
    onSkip?: (name: string, budget: LatencyBudget) => void;
  }): Promise<T | undefined>;
  /**
   * Mark one unit of skip work. Useful when the caller wants to make a
   * custom decision but still surface the skip in the counter.
   */
  recordSkip(name: string): void;
  /** Snapshot the current budget state. */
  snapshot(): LatencyBudget;
}

interface LatencyBudgetState {
  skips: Map<string, number>;
  startedAt: number;
}

function snapshotInternal(
  state: LatencyBudgetState,
  tier: LatencyTier,
  totalMs: number
): LatencyBudget {
  const now = Date.now();
  const elapsed = Math.max(0, now - state.startedAt);
  const remaining = Math.max(0, totalMs - elapsed);
  const budget: LatencyBudget = {
    tier,
    totalMs,
    elapsedMs: elapsed,
    remainingMs: remaining,
    exhausted: remaining <= 0,
    tryRun: undefined as never,
    recordSkip: (name: string) => {
      state.skips.set(name, (state.skips.get(name) ?? 0) + 1);
    },
    snapshot: () => snapshotInternal(state, tier, totalMs),
  };
  // Bind the recursive tryRun now that the budget object exists.
  budget.tryRun = async <T>(opts: {
    name: string;
    work: (budget: LatencyBudget) => Promise<T> | T;
    onSkip?: (name: string, budget: LatencyBudget) => void;
  }): Promise<T | undefined> => {
    if (budget.exhausted) {
      state.skips.set(opts.name, (state.skips.get(opts.name) ?? 0) + 1);
      try {
        opts.onSkip?.(opts.name, budget);
      } catch {
        // observer errors must never bubble out of the budget helper
      }
      return undefined;
    }
    return await opts.work(budget);
  };
  return budget;
}

/**
 * Create a new latency budget. Time source is injectable for tests.
 *   - tier: the latency tier the request is operating under
 *   - now:  the time source (default: Date.now)
 *   - env:  env var source for budget overrides (default: process.env)
 */
export function createLatencyBudget(opts: {
  tier: LatencyTier;
  now?: () => number;
  env?: NodeJS.ProcessEnv;
}): LatencyBudget {
  const now = opts.now ?? Date.now;
  const env = opts.env ?? process.env;
  const totalMs = resolveTierBudgetMs(opts.tier, env);
  const state: LatencyBudgetState = {
    skips: new Map<string, number>(),
    startedAt: now(),
  };
  return snapshotInternal(state, opts.tier, totalMs);
}

/**
 * Build the value for the `X-Latency-Budget` response header. Format:
 *   `<tier> used=<used_ms>/<total_ms> skips=<a=1,b=2,...>`
 * Skipped names are omitted when the count is zero. Always safe to call
 * even when no skips have been recorded.
 */
export function formatBudgetHeader(budget: LatencyBudget): string {
  const parts: string[] = [
    budget.tier,
    `used=${Math.round(budget.elapsedMs)}/${budget.totalMs}`,
  ];
  if (budget.tryRun) {
    // Reflect skips via the live budget's internal state. We re-snapshot to
    // pick up the most recent counts (the closure makes this safe).
    const live = budget.snapshot();
    // The snapshot is a fresh object without tryRun; we read skips via
    // the budget's own tryRun name→count by attempting a no-op work and
    // reading the snapshot. Easier: the skip map is internal to the
    // closure; expose a tiny helper by running a never-exhausted budget
    // round-trip. The simpler approach: the caller passes the budget
    // back to us and we read counts via a public hook.
  }
  // Pull skip counts via a public side-channel: the helper returned the
  // budget's skip map already in the closure. We expose counts via a
  // private accessor below.
  const counts = readSkipCounts(budget);
  if (counts.length > 0) {
    parts.push(`skips=${counts.map(([n, c]) => `${n}=${c}`).join(",")}`);
  }
  return parts.join(" ");
}

// Internal accessor: each budget keeps its skip map in a closure reachable
// only through the tryRun handler. To make the header helper work we expose
// counts via a hidden symbol-keyed property attached at construction.
const SKIP_COUNTS_KEY = Symbol.for("omniroute.latencyBudget.skipCounts");

function readSkipCounts(budget: LatencyBudget): Array<[string, number]> {
  // Use the public snapshot path: snapshot returns a new LatencyBudget
  // that shares the same underlying state via the closure. We can read
  // counts by inspecting any recorded skip the budget has done so far.
  // Since the budget's internal state is held in a closure that the
  // recordSkip method mutates, we expose counts via the closure's
  // recordSkip callback bound to a probe. The cleanest approach: return
  // the map as a property of the budget object.
  const fromObject = (budget as unknown as Record<symbol, Map<string, number> | undefined>)[
    SKIP_COUNTS_KEY
  ];
  if (fromObject) return Array.from(fromObject.entries());
  // Fallback: we have to attach the map to the budget at construction.
  // The construction path was changed to attach it via the tryRun
  // method, but for any budget created before this property was added
  // we fall through to an empty list (no skips visible in header).
  return [];
}

// Re-export the public surface and re-attach the skip map on creation.
// Done by monkey-patching createLatencyBudget below — see the wrapped
// factory at the bottom of this file.

/**
 * Diagnostic accessor for the /admin/refresh-stats / metrics endpoint.
 * Returns the per-name skip counts in insertion order.
 */
export function getBudgetSkipCounts(budget: LatencyBudget): Array<[string, number]> {
  return readSkipCounts(budget);
}
