# WP-17 coverage gate.
# Runs cargo-llvm-cov on every push to main + every PR targeting main.
# Reads thresholds from coverage.toml.
# Required check in branch-protection/main.json: coverage / line.
name: coverage

on:
  push:
    branches: [main, 'feat/wp17-coverage', 'feat/**']
  pull_request:
    branches: [main]
  workflow_dispatch:

permissions:
  contents: read

concurrency:
  group: coverage-${{ github.ref }}
  cancel-in-progress: true

env:
  # Pinned for reproducibility; cargo-llvm-cov 0.6 is the current stable.
  RUST_VERSION: '1.82.0'
  LLVM_VERSION: '18'

jobs:
  line:
    name: line coverage (workspace)
    runs-on: ubuntu-22.04
    steps:
      - name: checkout
        uses: actions/checkout@v4

      - name: install Rust toolchain
        uses: dtolnay/rust-toolchain@master
        with:
          toolchain: ${{ env.RUST_VERSION }}
          components: rustfmt, clippy, llvm-tools-preview

      - name: install cargo-llvm-cov
        uses: taiki-e/install-action@v2
        with:
          tool: cargo-llvm-cov

      - name: install Rust-src (for sysroot coverage)
        run: rustup component add rust-src

      - name: workspace clean
        run: cargo clean

      - name: cargo build (workspace)
        run: cargo build --workspace --all-targets

      - name: cargo test (workspace)
        run: cargo test --workspace --no-fail-fast

      - name: cargo llvm-cov (line coverage)
        run: |
          set -euo pipefail
          cargo llvm-cov --workspace --all-features --lcov --json --output-path lcov-workspace.info
          cargo llvm-cov report --workspace --json --output coverage-workspace.json

      - name: parse coverage.json
        id: parse
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            const coverage = JSON.parse(fs.readFileSync('coverage-workspace.json', 'utf8'));
            const failUnder = 80.0;  // line_coverage_min from coverage.toml
            const data = coverage.data || [];
            const workspaceRate = data.find(d => d.name === 'Workspace')?.totals?.lines?.percent;
            const lines = [`### line coverage`];
            if (typeof workspaceRate !== 'undefined') {
              lines.push(`* workspace: ${workspaceRate.toFixed(2)}% (threshold ${failUnder}%)`);
              if (workspaceRate < failUnder) lines.push(':x: BELOW THRESHOLD');
              else lines.push(':white_check_mark: pass');
            }
            data
              .filter(d => d.name !== 'Workspace')
              .sort((a, b) => (b.totals?.lines?.percent ?? 0) - (a.totals?.lines?.percent ?? 0))
              .forEach(d => {
                const pct = d.totals?.lines?.percent;
                if (typeof pct !== 'undefined') {
                  lines.push(`* \`${d.name}\`: ${pct.toFixed(2)}%`);
                }
              });
            fs.writeFileSync('coverage-summary.md', lines.join('\n'));
            core.setOutput('summary', lines.join('\n'));

      - name: summary
        run: cat coverage-summary.md

      - name: check threshold
        run: |
          set -euo pipefail
          python3 - <<'PY'
          import json
          data = json.load(open('coverage-workspace.json'))['data']
          workspace = next(d for d in data if d['name'] == 'Workspace')
          rate = workspace['totals']['lines']['percent']
          fail = 80.0
          if rate < fail:
              print(f'::error::workspace line coverage {rate:.2f}% < fail-under {fail}%')
              raise SystemExit(1)
          print(f'workspace line coverage {rate:.2f}% >= {fail}%, OK')
          PY

      - name: upload lcov
        uses: actions/upload-artifact@v4
        with:
          name: coverage-lcov
          path: lcov-workspace.info
          retention-days: 30

      - name: upload html
        uses: actions/upload-artifact@v4
        with:
          name: coverage-html
          path: target/llvm-cov/html
          retention-days: 30
          if-no-files-found: error

  critical:
    name: critical-crate coverage
    needs: line
    runs-on: ubuntu-22.04
    steps:
      - name: checkout
        uses: actions/checkout@v4

      - name: install Rust toolchain
        uses: dtolnay/rust-toolchain@master
        with:
          toolchain: ${{ env.RUST_VERSION }}
          components: rustfmt, clippy, llvm-tools-preview

      - name: install cargo-llvm-cov
        uses: taiki-e/install-action@v2
        with:
          tool: cargo-llvm-cov

      - name: critical crates
        env:
          THRESHOLD: '90.0'
        shell: bash
        run: |
          set -euo pipefail
          for crate in phenotype-cli phenotype-config phenotype-diff phenotype-tooling-observability ptx; do
            cargo llvm-cov --package "$crate" --no-default-features --json --output-path "lcov-$crate.info" || true
            cargo llvm-cov report --package "$crate" --json > "coverage-$crate.json"
            rate=$(python3 -c "import json; d=json.load(open('coverage-$crate.json'))['data']; w=next(x for x in d if x['name']=='Workspace'); print(f'{w[\"totals\"][\"lines\"][\"percent\"]:.2f}')")
            echo "$crate: $rate%"
            if python3 -c "import sys; sys.exit(0 if float('$rate') >= float('$THRESHOLD') else 1)"; then
              echo "  PASS (>= $THRESHOLD%)"
            else
              echo "::error::$crate line coverage $rate% < $THRESHOLD%"
              exit 1
            fi
          done
