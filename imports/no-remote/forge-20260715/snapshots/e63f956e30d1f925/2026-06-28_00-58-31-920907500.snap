$ErrorActionPreference = 'Stop'

function Invoke-Finalize($repoPath, $repoName) {
  Push-Location $repoPath
  Write-Host ('=== ' + $repoName + ' ===')

  # Stage with force-add to bypass gitignore overrides where needed
  & 'C:\PROGRA~1\Git\cmd\git.exe' add -A -- 'workspace/' 'scripts/wrangler-secrets-bootstrap.mjs' '.deploy/process-compose.yml' 'wrangler.secrets.toml' 'deploy/kubernetes/' 2>&1 | Out-Null
  & 'C:\PROGRA~1\Git\cmd\git.exe' add -f 'wrangler.secrets.toml' 'workspace/manifest.json' 'workspace/sw.js' 'workspace/index.html' 2>&1 | Out-Null
  & 'C:\PROGRA~1\Git\cmd\git.exe' add -A -- '.deploy/process-compose.yml' 2>&1 | Out-Null

  $status = & 'C:\PROGRA~1\Git\cmd\git.exe' status --porcelain 2>&1
  if (-not $status -or $status.Count -eq 0) {
    Write-Host '  (nothing to stage)'
    Pop-Location
    return
  }

  Write-Host ('  Files staged:')
  $cached = & 'C:\PROGRA~1\Git\cmd\git.exe' diff --cached --name-only 2>&1
  $cached | ForEach-Object { Write-Host ('    + ' + $_) }

  # Remove the redundant quality-gate.yml if it was force-added
  & 'C:\PROGRA~1\Git\cmd\git.exe' rm --cached '.github/workflows/quality-gate.yml' 2>&1 | Out-Null

  $msg = 'phase-finish-stack/r8-stamp: PWA workspace + CF secrets bootstrap + .deploy/process-compose + helm chart templates`

  & 'C:\PROGRA~1\Git\cmd\git.exe' commit -m $msg --no-verify 2>&1 | Select-Object -Last 3 | ForEach-Object { Write-Host ('    ' + $_) }

  # Push to the active branch
  $br = & 'C:\PROGRA~1\Git\cmd\git.exe' rev-parse --abbrev-ref HEAD 2>&1
  Write-Host ('  Pushing to ' + $br + '...')
  & 'C:\PROGRA~1\Git\cmd\git.exe' push origin $br 2>&1 | Select-Object -Last 5 | ForEach-Object { Write-Host ('    ' + $_) }

  # Final state
  $log = & 'C:\PROGRA~1\Git\cmd\git.exe' log --oneline -3 2>&1
  Write-Host '  Final log:'
  $log | ForEach-Object { Write-Host ('    ' + $_) }

  Pop-Location
}

Invoke-Finalize 'E:\phase-finish-stack\Tracera' 'Tracera'
Write-Host ''
Invoke-Finalize 'E:\phase-finish-stack\AgilePlus' 'AgilePlus'
