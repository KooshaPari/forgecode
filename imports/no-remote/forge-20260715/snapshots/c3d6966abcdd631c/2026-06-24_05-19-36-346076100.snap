import json, subprocess
repos = ["eyetracker", "Eventra", "Configra", "Benchora", "Authvault", "Quillr"]
expected = {"eyetracker": 74, "Eventra": 48, "Configra": 70, "Benchora": 42, "Authvault": 92, "Quillr": None}
for r in repos:
    p = subprocess.run(["gh", "pr", "list", "--repo", f"kooshapari/{r}", "--state", "open", "--json", "number,title"],
                       capture_output=True, text=True)
    prs = json.loads(p.stdout) if p.returncode == 0 else []
    titles = [pr["title"] for pr in prs if "ci:" in pr["title"] or "ci(" in pr["title"]]
    print(f"{r:12} open={len(prs):3} rustfmt/ci: {titles[:3]}")
