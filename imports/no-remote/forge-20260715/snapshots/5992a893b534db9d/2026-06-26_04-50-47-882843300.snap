[package]
name = "settly"
version.workspace = true
edition.workspace = true
description = "Settings management with validation, versioning, and migration support"
repository = "https://github.com/KooshaPari/Configra"
documentation = "https://docs.rs/settly"
keywords = ["settings", "config", "validation", "migration"]
categories = ["config", "validation"]
rust-version.workspace = true
license = "MIT OR Apache-2.0"
authors = ["kooshapari"]

[dependencies]
# Async runtime
tokio = { workspace = true }
async-trait = { workspace = true }

# Serialization
serde = { workspace = true }
serde_json = { workspace = true }
serde_yaml = "0.9"  # not in workspace; standalone
toml = { workspace = true }

# Error handling
thiserror = { workspace = true }
anyhow = { workspace = true }

# Utilities
uuid = { workspace = true }
chrono = { workspace = true }
validator = { version = "0.18", features = ["derive"] }  # not in workspace

# Database — not in workspace; standalone
tokio-postgres = "0.7"
sqlx = { version = "0.8", features = ["runtime-tokio", "postgres", "chrono", "uuid"] }

# Cache — not in workspace; standalone
redis = { version = "1.2", features = ["tokio-comp", "connection-manager"] }

# Logging
tracing = { workspace = true }

[dev-dependencies]
tempfile = { workspace = true }
criterion = { workspace = true }

[[bench]]
name = "perf"
harness = false
