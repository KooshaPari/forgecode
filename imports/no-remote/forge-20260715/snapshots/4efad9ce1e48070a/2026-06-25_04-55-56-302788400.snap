#!/usr/bin/env python3
"""Strip any path containing ANSI escape sequences from git history.

One-time corruption remediation for KooshaPari/Eidolon where a file with
literal ANSI color codes in its name got committed via a botched
`git add` of terminal output. The corruption blocks ALL Windows
checkouts of the repo.
"""
import sys
import re

ANSI_RE = re.compile(rb"\x1b\[|\\033\[")
# Match either raw ESC[ or the literal text "\033[" (which is what `git status`
# shows when terminal escape codes have been stored as the 5-char sequence
# backslash-zero-three-three-leftbracket). Some clients store the ESC char
# as the literal 4-char backslash escape; both must be handled.

from git_filter_repo import FilterRepo


def is_bad_blob(blob, metadata):
    if ANSI_RE.search(blob.path):
        blob.data = b""  # mark for deletion
        return True
    return False


def annotate_commit(commit, metadata):
    if not commit.message.endswith(b"filter-an: strip ANSI-escape paths\n"):
        commit.message += b"\nfilter-an: strip ANSI-escape paths\n"


target = sys.argv[1] if len(sys.argv) > 1 else "."
fr = FilterRepo(
    target,
    blob_callback=is_bad_blob,
    commit_callback=annotate_commit,
    force=True,
)
