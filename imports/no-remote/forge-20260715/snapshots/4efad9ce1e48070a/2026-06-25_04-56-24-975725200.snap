#!/usr/bin/env python3
"""Strip any path containing ANSI escape sequences from git history.

One-time corruption remediation for KooshaPari/Eidolon where a file with
literal ANSI color codes in its name got committed via a botched
`git add` of terminal output. The corruption blocks ALL Windows
checkouts of the repo.
"""
import re
import subprocess
import sys

# Use git-filter-repo with --blob-callback and --commit-callback.
ANSI_RE = re.compile(rb"\x1b\[|\\033\[")

blob_cb = (
    "if __import__('re').search(rb'\\x1b\\[|\\\\033\\[', blob.path):\n"
    "    blob.data = b''\n"
    "    return None\n"
    "return None\n"
)
commit_cb = (
    "if not commit.message.endswith(b'filter-an: strip ANSI-escape paths\\n'):\n"
    "    commit.message += b'\\nfilter-an: strip ANSI-escape paths\\n'\n"
    "return None\n"
)

result = subprocess.run(
    [
        r"C:\Python314\Scripts\git-filter-repo.exe",
        "--force",
        f"--blob-callback={blob_cb}",
        f"--commit-callback={commit_cb}",
    ],
    capture_output=True,
    text=True,
)
print("STDOUT:", result.stdout)
print("STDERR:", result.stderr)
print("RC:", result.returncode)
sys.exit(result.returncode)
