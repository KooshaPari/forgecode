# -- AgilePlus stack Helm values (default; override per environment) --

# Frontend (public-facing)
frontend:
tracera:
  replicaCount: 1
  autoscaling:
    enabled: false
    minReplicas: 1
    maxReplicas: 5
    targetCPUUtilizationPercentage: 80
  image:
    repository: kooshapari/tracera
    tag: ""
    pullPolicy: IfNotPresent
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 500m
      memory: 512Mi
  nodeSelector: {}
  service:
    type: ClusterIP
    port: 8080
  ingress:
    enabled: false
    className: ""
    hosts: []
  persistence:
    enabled: true
    storageClass: ""
    size: 8Gi
    accessModes:
      - ReadWriteOnce
frontend:
  enabled: true
  replicaCount: 1
  image:
    repository: kooshapari/agileplus-frontend
    tag: ""
    pullPolicy: IfNotPresent
  service:
    type: ClusterIP
    port: 3000
  resources:
    requests:
      cpu: 50m
      memory: 64Mi
    limits:
      cpu: 300m
      memory: 256Mi
  autoscaling:
    enabled: false
    minReplicas: 1
    maxReplicas: 3
    targetCPUUtilizationPercentage: 80
  persistence:
    enabled: false
    storageClass: ""
    size: 1Gi
api:
  enabled: true
  replicaCount: 1
  autoscaling:
    enabled: false
    minReplicas: 1
    maxReplicas: 3
    targetCPUUtilizationPercentage: 80
  service:
    type: ClusterIP
    port: 8000
mcp:
  enabled: true
  replicaCount: 1
  service:
    type: ClusterIP
    port: 9000
nats:
  enabled: true
  replicaCount: 1
  service:
    type: ClusterIP
    port: 4222
dragonfly:
  enabled: true
  replicaCount: 1
  service:
    type: ClusterIP
    port: 6379
neo4j:
  enabled: true
  replicaCount: 1
  service:
    type: ClusterIP
    port: 7687
minio:
  enabled: true
  replicaCount: 1
  service:
    type: ClusterIP
    port: 9000
      memory: 128Mi
  env:
    - name: API_URL
      value: http://api:8081
    - name: MCP_URL
      value: http://mcp:8082

# API service
api:
  replicaCount: 2
  image:
    repository: ghcr.io/kooshapari/agileplus-api
    pullPolicy: IfNotPresent
    tag: "latest"
  service:
    type: ClusterIP
    port: 8081
    targetPort: 8081
  resources:
    limits:
      cpu: 1500m
      memory: 1Gi
    requests:
      cpu: 500m
      memory: 512Mi
  env:
    - name: DATABASE_URL
      valueFrom:
        secretKeyRef:
          name: agileplus-secrets
          key: database-url
    - name: REDIS_URL
      valueFrom:
        secretKeyRef:
          name: agileplus-secrets
          key: redis-url

mcp:
  replicaCount: 1
  image:
    repository: ghcr.io/kooshapari/agileplus-mcp
    pullPolicy: IfNotPresent
    tag: "latest"
  service:
    type: ClusterIP
    port: 8082
    targetPort: 8082
  env:
    - name: API_URL
      value: http://api:8081

nats:
  enabled: true
  replicas: 3
  image:
    repository: nats:2.10-alpine
    tag: "2.10"
  auth:
    enabled: true
  persistence:
    size: 5Gi

dragonfly:
  enabled: true
  image:
    repository: docker.dragonflydb.dragonfly.io/dragonflydb/dragonfly
    tag: "v1.13"
  persistence:
    size: 5Gi

neo4j:
  enabled: true
  image:
    repository: neo4j:5.20-community
    tag: "5.20"
  persistence:
    size: 10Gi
  auth:
    enabled: true

minio:
  enabled: true
  image:
    repository: minio/minio
    tag: "RELEASE.2024-08-17T01-24-54Z"
  persistence:
    size: 20Gi

ingress:
  enabled: false
  className: ""
  annotations: {}
  hosts:
    - host: agileplus.local
      paths:
        - path: /
          pathType: Prefix
  tls: []

resources:
  defaults:
    limits:
      cpu: 500m
      memory: 512Mi
    requests:
      cpu: 100m
      memory: 128Mi

nodeSelector: {}
tolerations: []
affinity: {}

# Desktop-as-backend-server: bind to host network namespace for low-latency
hostNetwork: false
dnsPolicy: ClusterFirst

podAnnotations:
  prometheus.io/scrape: "true"
