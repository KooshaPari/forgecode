#!/usr/bin/env python3
"""Update PR #365 body via GitHub GraphQL API."""
import json, subprocess, sys, os

# Read the body file
body_path = r"C:\Users\koosh\infra-research\phenotype-registry\.forge\FORGE_PR_DESCRIPTION_p365.md"
with open(body_path, "r", encoding="utf-8") as f:
    new_body = f.read()

# Get PR node ID via gh CLI
result = subprocess.run(
    ["gh", "pr", "view", "365", "--json", "id", "--jq", ".id"],
    cwd=r"C:\Users\koosh\infra-research\phenotype-registry",
    capture_output=True, text=True, shell=True
)
pr_node_id = result.stdout.strip()
print(f"PR node ID: {pr_node_id}", file=sys.stderr)

# Build GraphQL mutation
mutation = """
mutation UpdatePR($pullRequestId: ID!, $body: String!) {
  updatePullRequest(input: {pullRequestId: $pullRequestId, body: $body}) {
    pullRequest { number body }
  }
}
""".strip()

# Write mutation to file (to avoid quoting issues)
with open(r"C:\Users\koosh\AppData\Local\Temp\mut.graphql", "w", encoding="utf-8") as f:
    f.write(mutation)

# Write body to file
with open(r"C:\Users\koosh\AppData\Local\Temp\body.json", "w", encoding="utf-8") as f:
    json.dump({"pullRequestId": pr_node_id, "body": new_body}, f)

# Run gh api graphql with file inputs
result = subprocess.run(
    ["gh", "api", "graphql",
     "-F", "pullRequestId=" + pr_node_id,
     "-F", f"body=@{r'C:\Users\koosh\AppData\Local\Temp\body.json'}",
     "-f", f"query=@{r'C:\Users\koosh\AppData\Local\Temp\mut.graphql'}"],
    cwd=r"C:\Users\koosh\infra-research\phenotype-registry",
    capture_output=True, text=True, shell=True
)
print("STDOUT:", result.stdout[:2000], file=sys.stderr)
print("STDERR:", result.stderr[:500], file=sys.stderr)
print("EXIT:", result.returncode, file=sys.stderr)