[package]
name = "phenotype-event-bus"
version.workspace = true
edition.workspace = true
license.workspace = true
repository.workspace = true
description = "Event bus abstractions for the Phenotype ecosystem"

[lib]
path = "src/lib.rs"

[dependencies]
thiserror = { workspace = true }
serde = { workspace = true }
serde_json = { workspace = true }
async-trait = { workspace = true }
tokio = { workspace = true, features = ["sync", "time", "rt", "macros"] }
ulid = { workspace = true }
dashmap = { workspace = true }
phenotype-error-core = { workspace = true }
chrono = { workspace = true }
tracing = { workspace = true }

[features]
default = []
# Postgres-backed OutboxStore (EVE-SOTA-002). Adds sqlx + tokio-postgres.
postgres = ["dep:sqlx"]
# SQLite-backed OutboxStore (EVE-SOTA-004) — placeholder.
#
# The `sqlite` feature was reserved for a SQLite adapter, but the
# adapter that shipped referenced undefined symbols and an outdated
# trait surface, so it was removed in commit-eventra-p3-remediation
# to keep the workspace buildable. PostgresOutbox is the supported
# database adapter today. A future SQLite adapter should target sqlx
# (matching the Postgres impl) and re-enable this feature flag.
sqlite = []

[dependencies.sqlx]
version = "0.8"
default-features = false
features = ["runtime-tokio-rustls", "macros", "chrono", "json"]
optional = true

[dev-dependencies]
tokio = { workspace = true, features = ["full"] }
