root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.{yaml,yml}]
indent_size = 2

[*.{rs,py}]
indent_size = 4

[*.rs]
indent_size = 4

[*.py]
indent_size = 4

[*.toml]
indent_size = 2

[*.mojo]
indent_size = 2

[*.zig]
indent_size = 4
