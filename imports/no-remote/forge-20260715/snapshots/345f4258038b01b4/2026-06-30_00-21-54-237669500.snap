root = true
# EditorConfig — Phenotype org canonical
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{rs}]  # Rust
indent_size = 4
max_line_length = 100

[*.{rs,py,zig}]
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 100

[*.go]
indent_style = tab
indent_size = 4

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

[*.{yaml,yml,toml,json,jsonc,mojo}]
indent_size = 2

[*.{zsh,sh,bash}]
indent_size = 2

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
max_line_length = off

[*.{diff,patch}]
trim_trailing_whitespace = false
