[workspace]
resolver = "2"
members = [
    "packages/*",
]

[workspace.package]
version = "0.2.0"
edition = "2021"
license = "MIT"
description = "Phenotype Rust SDK — core primitives for the Phenotype ecosystem"
authors = ["Phenotype Team"]
repository = "https://github.com/KooshaPari/phenotype-sdk"

[workspace.dependencies]
serde = { version = "1", features = ["derive"] }
serde_json = "1"
thiserror = "2"
regex = "1"
zstd = { version = "0.13", default-features = false }
unicode-normalization = "0.1"
async-trait = "0.1"
futures = "0.3"
tokio = { version = "1", features = ["sync", "rt", "macros"] }
parking_lot = "0.12"
chrono = { version = "0.4", features = ["serde"] }
rand = "0.8"
uuid = { version = "1", features = ["v4"] }
tracing = "0.1"
