$ErrorActionPreference = 'Continue'
$base = 'C:/Users/koosh/Civis_fresh'

function Run-Ck($pkg, $label) {
    Write-Host "  --- $pkg ---"
    $tmpout = [System.IO.Path]::GetTempFileName()
    $tmperr = [System.IO.Path]::GetTempFileName()
    $p = Start-Process -FilePath "cargo" -ArgumentList @("check","-p",$pkg,"--offline","--color=never") `
                       -RedirectStandardOutput $tmpout `
                       -RedirectStandardError $tmperr `
                       -WorkingDirectory $base `
                       -NoNewWindow -Wait -PassThru
    $ec = $p.ExitCode
    $stdout = Get-Content $tmpout -Raw -ErrorAction SilentlyContinue
    $stderr = Get-Content $tmperr -Raw -ErrorAction SilentlyContinue
    Remove-Item $tmpout,$tmperr -ErrorAction SilentlyContinue
    $out = ($stdout + "`n" + $stderr) -split "`r?`n"
    if ($ec -eq 0) {
        $tail = ($out | Where-Object { $_ } | Select-Object -Last 3) -join ' | '
        Write-Host "    OK: $tail"
    } else {
        $errs = $out | Where-Object { $_ -match '^error\[' } | Select-Object -First 5
        $errs | ForEach-Object { Write-Host "    $_" }
        $summary = $out | Where-Object { $_ -match 'previous errors' } | Select-Object -First 1
        if ($summary) { Write-Host "    $summary" }
    }
}

function Check-Branch {
    param([string]$branch, [string]$label)
    Set-Location $base
    Write-Host ""
    Write-Host "===== $label ($branch) ====="
    git checkout $branch 2>&1 | Out-Null
    if ($LASTEXITCODE -ne 0) {
        git checkout -b $branch "origin/$branch" 2>&1 | Out-Null
    }
    if ($LASTEXITCODE -ne 0) { Write-Host "  checkout FAILED ($LASTEXITCODE)"; return }
    git log --oneline -1 | ForEach-Object { Write-Host "  $_" }
    Run-Ck 'civ-needs' 'civ-needs'
    Run-Ck 'civ-economy' 'civ-economy'
    Run-Ck 'civ-genetics' 'civ-genetics'
}

Check-Branch 'fix/workspace-bevy-ref-holocron-dep' 'BASELINE: workspace fix'
Check-Branch 'chore/governance-forge-agents' 'PR-gov: governance file'
Check-Branch 'feat/fr-civ-life-classifiers-tick' 'PR1: lifecycle classifiers'
Check-Branch 'feat/fr-civ-life-reproduction-params' 'PR2: reproduction params'
Check-Branch 'feat/fr-civ-life-labor-economy' 'PR3: labor-economy'
Check-Branch 'feat/fr-civ-life-trace-matrix' 'PR4: trace matrix'

git checkout main 2>&1 | Out-Null
Write-Host ""
Write-Host "===== verification complete ====="