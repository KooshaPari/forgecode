module github.com/kooshapari/nanovms

go 1.23.0

toolchain go1.23.4

require (
	github.com/kooshapari/pheno-go-ctxkit v0.0.0
	go.uber.org/mock v0.6.0
	gopkg.in/yaml.v3 v3.0.1
)

// `go.uber.org/mock` was previously vendored via a `replace` directive to
// `./third_party/go.uber.org/mock` (an in-tree copy). The upstream module
// is stable and the in-tree copy has not been modified, so we now use the
// upstream module directly. The third_party copy is preserved (in
// `third_party/`) for reproducible offline builds via `GOFLAGS=-mod=vendor`
// if needed in the future.
