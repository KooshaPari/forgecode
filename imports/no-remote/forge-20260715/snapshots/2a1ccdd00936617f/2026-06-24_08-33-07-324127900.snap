[package]
name = "credential-manager"
version = "0.1.0"
edition = "2021"
description = "Credential manager — absorbed from KVirtualStage credential_manager crate"
license = "MIT OR Apache-2.0"
repository = "https://github.com/KooshaPari/phenotype-infra"
authors = ["kooshapari"]
publish = false

[lib]
name = "credential_manager"
path = "src/lib.rs"

[dependencies]
# Core
tokio = { workspace = true, features = ["full"] }
serde = { workspace = true, features = ["derive"] }
serde_json = { workspace = true }
uuid = { workspace = true, features = ["v4", "serde"] }
chrono = { workspace = true, features = ["serde"] }
thiserror = { workspace = true }
anyhow = { workspace = true }
url = { workspace = true }

# Cryptography
ring = "0.16"
argon2 = "0.5"
chacha20poly1305 = "0.10"
rand = { workspace = true }
base64 = "0.22"

# HTTP/OAuth
reqwest = { workspace = true, features = ["json", "rustls-tls"] }
oauth2 = "4.4"
async-trait = { workspace = true }
hex = { workspace = true }

# Storage
sled = "0.34"
sqlx = { version = "0.7", features = ["runtime-tokio-rustls", "sqlite"] }

# Security
zeroize = "1.6"
secrecy = "0.8"
totp-rs = "5.0"
qrcode = "0.14"

# Configuration
config = "0.13"
clap = { workspace = true }

# Logging
tracing = { workspace = true }
tracing-subscriber = { workspace = true }
futures = { workspace = true }

[dev-dependencies]
tokio-test = "0.4"
tempfile = "3"
