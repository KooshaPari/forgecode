import os

wfdir = '.github/workflows'

# sbom.yml
with open(os.path.join(wfdir, 'sbom.yml'), 'w') as f:
    f.write('name: SBOM\n')
    f.write('on:\n')
    f.write('  pull_request:\n')
    f.write('    branches: [main]\n')
    f.write('  push:\n')
    f.write('    branches: [main]\n')
    f.write('\n')
    f.write('permissions:\n')
    f.write('  contents: read\n')
    f.write('\n')
    f.write('concurrency:\n')
    f.write('  group: ${{ github.workflow }}-${{ github.ref }}\n')
    f.write('  cancel-in-progress: true\n')
    f.write('\n')
    f.write('jobs:\n')
    f.write('  sbom:\n')
    f.write('    runs-on: ubuntu-24.04\n')
    f.write('    steps:\n')
    f.write('      - uses: actions/checkout@v4\n')
    f.write('      - name: Generate SBOM (Syft)\n')
    f.write('        uses: anchore/sbom-action@v0\n')
    f.write('        with:\n')
    f.write('          path: ./\n')
    f.write('          format: cyclonedx-json\n')
    f.write('          artifact-name: sbom.cyclonedx.json\n')
    f.write('      - name: Upload SBOM\n')
    f.write('        uses: actions/upload-artifact@v4\n')
    f.write('        with:\n')
    f.write('          name: sbom\n')
    f.write('          path: sbom.cyclonedx.json\n')

# license-check.yml
with open(os.path.join(wfdir, 'license-check.yml'), 'w') as f:
    f.write('name: License Check\n')
    f.write('on:\n')
    f.write('  pull_request:\n')
    f.write('    branches: [main]\n')
    f.write('  push:\n')
    f.write('    branches: [main]\n')
    f.write('\n')
    f.write('permissions:\n')
    f.write('  contents: read\n')
    f.write('\n')
    f.write('concurrency:\n')
    f.write('  group: ${{ github.workflow }}-${{ github.ref }}\n')
    f.write('  cancel-in-progress: true\n')
    f.write('\n')
    f.write('jobs:\n')
    f.write('  license-check:\n')
    f.write('    runs-on: ubuntu-24.04\n')
    f.write('    steps:\n')
    f.write('      - uses: actions/checkout@v4\n')
    f.write('      - name: Check top-level LICENSE files exist\n')
    f.write("        run: |\n")
    f.write("          for f in LICENSE LICENSE-APACHE LICENSE-MIT; do\n")
    f.write('            if [ ! -f "$f" ]; then\n')
    f.write('              echo "::error file=$f::Missing license file: $f"\n')
    f.write("              exit 1\n")
    f.write("            fi\n")
    f.write('            echo "LICENSE $f found ($(wc -l < "$f") lines)"\n')
    f.write("          done\n")
    f.write("      - name: Check Rust workspace license declaration\n")
    f.write("        run: |\n")
    f.write("          LICENSE_DECL=$(grep -E '^license\\s*=' iac/Cargo.toml | head -1)\n")
    f.write('          if echo "$LICENSE_DECL" | grep -qiE "MIT|Apache"; then\n')
    f.write('            echo "Cargo workspace license: $LICENSE_DECL"\n')
    f.write("          else\n")
    f.write('            echo "::warning::Workspace license declaration may be missing or non-standard: $LICENSE_DECL"\n')
    f.write("          fi\n")

# changelog-check.yml
with open(os.path.join(wfdir, 'changelog-check.yml'), 'w') as f:
    f.write('name: Changelog Check\n')
    f.write('on:\n')
    f.write('  pull_request:\n')
    f.write('    branches: [main]\n')
    f.write('    types: [opened, synchronize, reopened, labeled, unlabeled]\n')
    f.write('\n')
    f.write('permissions:\n')
    f.write('  contents: read\n')
    f.write('  pull-requests: write\n')
    f.write('\n')
    f.write('concurrency:\n')
    f.write('  group: ${{ github.workflow }}-${{ github.ref }}\n')
    f.write('  cancel-in-progress: true\n')
    f.write('\n')
    f.write('jobs:\n')
    f.write('  changelog:\n')
    f.write('    runs-on: ubuntu-24.04\n')
    f.write('    steps:\n')
    f.write('      - uses: actions/checkout@v4\n')
    f.write('        with:\n')
    f.write('          fetch-depth: 0\n')
    f.write('      - name: Check CHANGELOG.md exists\n')
    f.write("        run: |\n")
    f.write("          if [ ! -f CHANGELOG.md ]; then\n")
    f.write('            echo "::error::CHANGELOG.md is missing from the repository root"\n')
    f.write("            exit 1\n")
    f.write("          fi\n")
    f.write('          echo "CHANGELOG.md found"\n')
    f.write("      - name: Check CHANGELOG was modified\n")
    f.write("        uses: dorny/paths-filter@v3\n")
    f.write("        id: changelog\n")
    f.write("        with:\n")
    f.write("          filters: |\n")
    f.write("            updated:\n")
    f.write("              - 'CHANGELOG.md'\n")
    f.write("      - name: Warn if CHANGELOG not updated\n")
    f.write("        if: steps.changelog.outputs.updated == 'false'\n")
    f.write("        run: |\n")
    f.write('          echo "::warning::CHANGELOG.md was not modified in this PR. Please add a changelog entry."\n')

print('All 3 workflow files created successfully')
