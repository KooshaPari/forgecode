$repos = @(
    "KooshaPari/kvirtualstage",
    "KooshaPari/kmobile",
    "KooshaPari/mobile-cli",
    "KooshaPari/Eidolon",
    "KooshaPari/playcua",
    "KooshaPari/phenotype-journeys",
    "kooshapari/agileplus",
    "KooshaPari/Dino-fork"
)
foreach ($r in $repos) {
    $raw = (gh api "repos/$r/commits/HEAD" 2>&1) -join "`n"
    try {
        $j = $raw | ConvertFrom-Json
        $msg = ($j.commit.message -split "`n")[0]
        Write-Output "$r`t$($j.sha)`t$($j.commit.author.date)`t$msg"
    } catch {
        Write-Output "$r`tPARSEERR`t$($_.Exception.Message)"
    }
}
