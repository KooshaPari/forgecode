$repos = @(
    "KooshaPari/kvirtualstage",
    "KooshaPari/kmobile",
    "KooshaPari/mobile-cli",
    "KooshaPari/Eidolon",
    "KooshaPari/playcua",
    "KooshaPari/phenotype-journeys",
    "kooshapari/agileplus",
    "KooshaPari/Dino-fork"
)
foreach ($r in $repos) {
    $output = & gh api "repos/$r/commits/HEAD" 2>&1
    $raw = ($output -join "`n").Trim()
    try {
        $j = $raw | ConvertFrom-Json
        # First line of commit message (handle CRLF properly)
        $lines = $j.commit.message -split "[`r`n]+"
        $msg = $lines[0]
        Write-Output "REPO=$r|SHA=$($j.sha)|DATE=$($j.commit.author.date)|MSG=$msg"
    } catch {
        Write-Output "REPO=$r|ERROR=$($_.Exception.Message)"
    }
}
