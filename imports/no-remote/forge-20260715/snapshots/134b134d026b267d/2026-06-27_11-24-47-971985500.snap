[package]
name = "pheno-compose-driver"
version = "0.1.0"
edition = "2021"
description = "PhenoCompose NVMS Driver - Rust interface to NVMS 3-tier isolation"
license = "MIT OR Apache-2.0"
repository = "https://github.com/KooshaPari/phenotype-infra"
documentation = "https://docs.rs/pheno-compose-driver"
keywords = ["phenotype", "pheno-compose"]
categories = ["development-tools"]
authors = ["kooshapari"]
serde_json = { workspace = true }

# Note: no [dev-dependencies] here - tests are pure sync via the mock backend.
# But the inline #[cfg(test)] module in src/health.rs uses serde_json::to_string
# and serde_json::from_str directly, so it needs to be in regular [dependencies]
# (not [dev-dependencies]) for the inline test module to compile.
pheno-config = { path = "../pheno-config" }
serde = { workspace = true }
[features]
default = ["nvms"]
nvms = []  # Enable NVMS backend (nvms-ffi is always a dep for error types)
mock = []  # Use mock backend for testing
# Note: no [dev-dependencies] here - tests are pure sync via the mock backend.
