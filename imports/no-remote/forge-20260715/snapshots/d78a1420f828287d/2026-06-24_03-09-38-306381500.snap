"""Audit each compute/infra repo for state. Writes C:\\Users\\koosh\\_infra_recon.json incrementally."""
import json
import os
import subprocess
import sys
from pathlib import Path

REPOS = [
    r"C:\Users\koosh\phenotype-infra",
    r"C:\Users\koosh\nanovms",
    r"C:\Users\koosh\PhenoCompose",
    r"C:\Users\koosh\BytePort",
    r"C:\Users\koosh\heliosBench",
    r"C:\Users\koosh\helioslab-bootstrap",
    r"C:\Users\koosh\phenotype-journeys",
    r"C:\Users\koosh\phenotype-registry",
    r"C:\Users\koosh\phenotype-voxel",
    r"C:\Users\koosh\phenotype-infra-ci-fix",
]

OUT = r"C:\Users\koosh\_infra_recon.json"
LOG = r"C:\Users\koosh\_infra_audit.log"

def log(msg):
    with open(LOG, "a", encoding="utf-8") as f:
        f.write(msg + "\n")
    print(msg, flush=True)

def run(cmd, cwd, timeout=45):
    try:
        r = subprocess.run(
            cmd, cwd=cwd, capture_output=True, text=True,
            shell=True, timeout=timeout, encoding="utf-8", errors="replace",
        )
        return r.stdout, r.stderr, r.returncode
    except subprocess.TimeoutExpired:
        return "", "timeout", -1
    except Exception as e:
        return "", str(e), -1

def git_one(args, cwd):
    out, _, _ = run(f"git {args}", cwd)
    return out.strip()

def audit_repo(path):
    name = os.path.basename(path.rstrip("\\/"))
    log(f"--- {name} ---")
    rec = {
        "name": name,
        "path": path,
        "exists": os.path.isdir(path),
        "is_git": False,
        "head_sha": None,
        "head_short": None,
        "current_branch": None,
        "dirty_count": 0,
        "dirty_files_sample": [],
        "local_branches": [],
        "branches_ahead_of_origin": [],
        "stashes_count": 0,
        "stashes_first_lines": [],
        "worktrees_count": 0,
        "worktrees": [],
        "readme_first_line": None,
        "primary_language": None,
        "languages": {},
        "packages": {
            "Cargo.toml": False,
            "package.json": False,
            "pyproject.toml": False,
            "go.mod": False,
        },
        "remote_origin_url": None,
        "upstream_branch": None,
        "last_fetch": None,
        "last_commit_ts": None,
        "last_commit_subject": None,
        "recent_commits": [],
    }
    if not rec["exists"]:
        return rec

    git_dir = os.path.join(path, ".git")
    rec["is_git"] = os.path.isdir(git_dir)

    for f in ("Cargo.toml", "package.json", "pyproject.toml", "go.mod"):
        rec["packages"][f] = os.path.isfile(os.path.join(path, f))

    for cand in ("README.md", "README.MD", "readme.md", "Readme.md", "README.rst", "README.txt", "README"):
        fp = os.path.join(path, cand)
        if os.path.isfile(fp):
            try:
                with open(fp, "r", encoding="utf-8", errors="replace") as f:
                    line = f.readline().strip()
                    rec["readme_first_line"] = line[:200] if line else None
            except Exception:
                pass
            break

    ext_count = {}
    skip_dirs = {".git", "node_modules", "target", "dist", "build", "__pycache__", ".venv", "venv", ".next"}
    file_limit = 5000
    scanned = 0
    try:
        for root, dirs, files in os.walk(path):
            dirs[:] = [d for d in dirs if d not in skip_dirs and not d.startswith(".")]
            for f in files:
                if scanned >= file_limit:
                    break
                ext = os.path.splitext(f)[1].lower()
                if not ext:
                    continue
                ext_count[ext] = ext_count.get(ext, 0) + 1
                scanned += 1
            if scanned >= file_limit:
                break
    except Exception:
        pass
    lang_map = {
        ".rs": "Rust", ".py": "Python", ".js": "JavaScript", ".ts": "TypeScript",
        ".tsx": "TypeScript", ".jsx": "JavaScript", ".go": "Go", ".java": "Java",
        ".cs": "C#", ".cpp": "C++", ".c": "C", ".h": "C", ".hpp": "C++",
        ".rb": "Ruby", ".php": "PHP", ".sh": "Shell", ".ps1": "PowerShell",
        ".md": "Markdown", ".yaml": "YAML", ".yml": "YAML", ".toml": "TOML",
        ".json": "JSON", ".html": "HTML", ".css": "CSS", ".scss": "SCSS",
        ".swift": "Swift", ".kt": "Kotlin", ".dart": "Dart", ".lua": "Lua",
    }
    for ext, cnt in sorted(ext_count.items(), key=lambda x: -x[1])[:15]:
        lang = lang_map.get(ext, ext.lstrip("."))
        rec["languages"][lang] = rec["languages"].get(lang, 0) + cnt
    if rec["languages"]:
        rec["primary_language"] = max(rec["languages"].items(), key=lambda x: x[1])[0]

    if not rec["is_git"]:
        return rec

    rec["head_sha"] = git_one("rev-parse HEAD", path)
    rec["head_short"] = git_one("rev-parse --short HEAD", path)

    cb, _, _ = run("git symbolic-ref --short -q HEAD 2>nul || git rev-parse --short HEAD", path)
    rec["current_branch"] = cb.strip() if cb else None

    up, _, _ = run("git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>nul", path)
    rec["upstream_branch"] = up.strip() if up else None

    rec["remote_origin_url"] = git_one("config --get remote.origin.url", path)

    dirty_out, _, _ = run("git status --porcelain", path)
    if dirty_out:
        lines = [l for l in dirty_out.splitlines() if l.strip()]
        rec["dirty_count"] = len(lines)
        rec["dirty_files_sample"] = lines[:20]

    fmt = "%(refname:short)|%(upstream:short)|%(upstream:track)|%(objectname:short)|%(committerdate:iso)"
    branch_out, _, _ = run(f'git for-each-ref --format="{fmt}" refs/heads', path)
    if branch_out:
        import re
        for ln in branch_out.splitlines():
            parts = ln.split("|")
            if len(parts) < 5:
                continue
            br, upn, track, sha, cdate = parts[0], parts[1], parts[2], parts[3], parts[4]
            rec["local_branches"].append({
                "branch": br,
                "upstream": upn if upn else None,
                "tracking": track,
                "sha": sha,
                "commit_date": cdate,
            })
            ma = re.search(r"ahead\s+(\d+)", track)
            mb = re.search(r"behind\s+(\d+)", track)
            if ma or mb:
                ahead = int(ma.group(1)) if ma else 0
                behind = int(mb.group(1)) if mb else 0
                if ahead > 0 or behind > 0:
                    rec["branches_ahead_of_origin"].append({
                        "branch": br,
                        "upstream": upn,
                        "ahead": ahead,
                        "behind": behind,
                    })

    stash_out, _, _ = run("git stash list --format='%gd|%s'", path)
    if stash_out:
        slines = [l for l in stash_out.splitlines() if l.strip()]
        rec["stashes_count"] = len(slines)
        for s in slines:
            parts = s.split("|", 1)
            if len(parts) == 2:
                rec["stashes_first_lines"].append({"ref": parts[0], "subject": parts[1][:200]})
            else:
                rec["stashes_first_lines"].append({"ref": s, "subject": ""})

    wt_out, _, _ = run("git worktree list --porcelain", path)
    if wt_out:
        wts = []
        cur = {}
        for ln in wt_out.splitlines():
            if ln.startswith("worktree "):
                if cur:
                    wts.append(cur)
                cur = {"path": ln[len("worktree "):]}
            elif ln.startswith("HEAD "):
                cur["head"] = ln[len("HEAD "):]
            elif ln.startswith("branch "):
                cur["branch"] = ln[len("branch "):]
            elif ln == "detached":
                cur["detached"] = True
        if cur:
            wts.append(cur)
        rec["worktrees"] = wts
        rec["worktrees_count"] = len(wts)

    log_out, _, _ = run("git log --pretty=format:'%h|%ai|%s' -n 5", path)
    if log_out:
        for ln in log_out.splitlines():
            parts = ln.split("|", 2)
            if len(parts) >= 3:
                rec["recent_commits"].append({"sha": parts[0], "date": parts[1], "subject": parts[2][:200]})
                if rec["last_commit_ts"] is None:
                    rec["last_commit_ts"] = parts[1]
                    rec["last_commit_subject"] = parts[2][:200]

    fetch_head = os.path.join(path, ".git", "FETCH_HEAD")
    if os.path.isfile(fetch_head):
        try:
            import datetime
            mtime = os.path.getmtime(fetch_head)
            rec["last_fetch"] = datetime.datetime.fromtimestamp(mtime).isoformat()
        except Exception:
            pass

    return rec


def main():
    open(LOG, "w").close()
    results = []
    for path in REPOS:
        try:
            rec = audit_repo(path)
        except Exception as e:
            rec = {"name": os.path.basename(path), "path": path, "error": str(e)}
        results.append(rec)
        with open(OUT, "w", encoding="utf-8") as f:
            json.dump(results, f, indent=2, ensure_ascii=False)
        log(f"wrote {len(results)} records -> {OUT}")
    log(f"DONE: {len(results)} repos")


if __name__ == "__main__":
    main()