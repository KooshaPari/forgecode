import subprocess, json, sys, re
from datetime import datetime, timezone

repo = r'C:\Users\koosh\phenotype-infra-ci-fix'

# Use --no-color to avoid ANSI escape codes
result = subprocess.run(['git', 'branch', '-r', '--no-color'], capture_output=True, text=True, cwd=repo)
branches = [b.strip() for b in result.stdout.strip().split('\n') if b.strip()]

all_branches = []
for b in branches:
    if b.startswith('origin/HEAD'):
        continue
    log = subprocess.run(['git', 'log', '-1', '--format=%H|%aI|%cI|%an|%s', b], capture_output=True, text=True, cwd=repo)
    parts = log.stdout.strip().split('|', 4)
    entry = {
        'ref': b.replace('origin/', ''),
        'sha': parts[0] if len(parts) > 0 else 'unknown',
        'author_date': parts[1] if len(parts) > 1 else 'unknown',
        'committer_date': parts[2] if len(parts) > 2 else 'unknown',
        'author': parts[3] if len(parts) > 3 else 'unknown',
        'subject': parts[4] if len(parts) > 4 else 'unknown'
    }
    try:
        dt = datetime.fromisoformat(entry['committer_date'])
        age = (datetime.now(timezone.utc) - dt).days
        entry['age_days'] = age
    except:
        entry['age_days'] = -1
    all_branches.append(entry)

print(json.dumps(all_branches, indent=2))
