# /Users/kooshapari/CodeProjects/Phenotype/repos/nanovms/.github/workflows/ci.yml
name: CI
on:
  pull_request:
    branches: [main]
  push:
    branches: [main]

permissions:
  contents: read


concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true
jobs:
  changes:
    runs-on: ubuntu-latest
    permissions: { pull-requests: read }
    outputs:
      go: ${{ steps.filter.outputs.go }}
      any: ${{ steps.filter.outputs.any }}
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd
        with: { fetch-depth: 50 }
      - uses: dorny/paths-filter@6852f92c20ea7fd3b0c25de3b5112db3a98da050
        id: filter
        with:
          filters: |
            go: ['**/*.go', 'go.mod', 'go.sum', '.github/workflows/ci.yml']
            any: ['**']

  test:
    needs: changes
    if: needs.changes.outputs.go == 'true'
    runs-on: ubuntu-latest
    strategy:
      fail-fast: false
      matrix:
        go: ['1.22', '1.23', '1.24']
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd
      - uses: actions/setup-go@78961f6f84d799cd858575bb931c3e51d3b13290
        with:
          go-version: ${{ matrix.go }}
          cache: true
      - run: go vet ./...
      - run: go test -race -shuffle=on ./...
      - name: Build all binaries
        run: |
          go build -o /tmp/nanovms ./cmd/nanovms
          go build -o /tmp/nvms ./cmd/nvms
          go build -o /tmp/nvms-cgo ./cmd/nvms-cgo

  lint:
    needs: changes
    if: needs.changes.outputs.go == 'true'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd
      - uses: actions/setup-go@78961f6f84d799cd858575bb931c3e51d3b13290
        with:
          go-version: '1.24'
          cache: true
      - uses: golangci/golangci-lint-action@aa6339a8b9e0e1c4b5e7c4e6f8d7c3a2b1e0d9f8
        with:
          version: v1.59

  security:
    needs: changes
    if: needs.changes.outputs.go == 'true'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@de0fac2e4500dabe0009e67214ff5f5447ce83dd
      - uses: actions/setup-go@78961f6f84d799cd858575bb931c3e51d3b13290
        with: { go-version: '1.24' }
      - run: |
          go install github.com/securego/gosec/v2/cmd/gosec@latest
          gosec ./...
      - run: |
          go install golang.org/x/vuln/cmd/govulncheck@latest
          govulncheck ./...
