#!/usr/bin/env python3
"""
Port the 22 upstream-port branches onto the consolidation branch.

For each upstream-port branch:
  - cherry-pick forward (main..tip) onto consolidation
  - rename commit messages to prefix with `upstream-port(<orig>):`
  - leave the original branch untouched (still pointing at diego's commits)

If a cherry-pick conflicts, the script aborts that branch and moves on,
recording it as `conflict` so we can re-attempt with rebase+drop later.
"""
import json
import os
import subprocess
import sys
from pathlib import Path

REPO = Path(r"C:\Users\koosh\OmniRoute-fresh2")
AUDIT = Path(r"C:\Users\koosh\_branch_audit.json")
WORK = REPO

PORT_BRANCHES = [
    # koosha/upstream-* (5)
    "koosha/upstream-backend-health-2026-06-21",
    "koosha/upstream-concurrency-4580-2026-06-21",
    "koosha/upstream-perf-observability-2026-06-21",
    "koosha/upstream-quota-4540-2026-06-21",
    "koosha/upstream-routing-stability-2026-06-21",
    # upstream-pr/* (17)
    "upstream-pr/antigravity-nvidia-fallback-2026-06-24",
    "upstream-pr/bifrost-docs",
    "upstream-pr/cherry-batch-2-2026-06-24",
    "upstream-pr/cherry-batch-2026-06-24",
    "upstream-pr/cherry-batch-3-clean-2026-06-25",
    "upstream-pr/diego-mimocode-fix",
    "upstream-pr/incident-response",
    "upstream-pr/kill-switch-extraction",
    "upstream-pr/l1a-dispatch-2026-06-27",
    "upstream-pr/log-buffer-cap-2026-06-24",
    "upstream-pr/openapi-redoc",
    "upstream-pr/perf-budgets",
    "upstream-pr/pr-template",
    "upstream-pr/refactor-apikey-providers",
    "upstream-pr/refactor-token-refresh",
    "upstream-pr/security-sweep-2026-06-24",
    "upstream-pr/threat-model",
]


def run(cmd, check=True, capture=True, env=None):
    """Run a command inside the repo."""
    full_env = os.environ.copy()
    if env:
        full_env.update(env)
    res = subprocess.run(
        cmd,
        cwd=str(REPO),
        shell=True,
        check=False,
        capture_output=capture,
        text=True,
        env=full_env,
    )
    if check and res.returncode != 0:
        sys.stderr.write(f"FAIL: {' '.join(cmd) if isinstance(cmd, list) else cmd}\n")
        sys.stderr.write(res.stdout)
        sys.stderr.write(res.stderr)
        sys.exit(res.returncode)
    return res


def git(*args, check=True, capture=True):
    return run(["git", *args], check=check, capture=capture)


def get_commits_to_pick(branch):
    """Return commits between main and branch (exclusive main, inclusive tip)."""
    res = git(
        "log",
        "--reverse",
        "--pretty=format:%H %s",
        f"main..origin/{branch}",
        capture=True,
    )
    lines = [l for l in res.stdout.splitlines() if l.strip()]
    return [tuple(l.split(maxsplit=1)) for l in lines]


def port_branch(branch):
    """Cherry-pick each commit of `branch` onto consolidation, prefixing messages."""
    commits = get_commits_to_pick(branch)
    if not commits:
        return {"branch": branch, "status": "noop", "commits": 0, "messages": []}

    picked = []
    for sha, _subject in commits:
        # Cherry-pick with --no-commit, then write a prefixed message
        res = git("cherry-pick", "-n", sha, check=False, capture=True)
        if res.returncode != 0:
            # Abort and skip
            git("cherry-pick", "--abort", check=False, capture=True)
            git("reset", "--hard", "HEAD", check=False, capture=True)
            return {
                "branch": branch,
                "status": "conflict",
                "commits": len(picked),
                "messages": picked,
                "failed_sha": sha,
            }
        # Stage and commit with the prefix
        prefix = f"upstream-port({branch}): "
        res2 = git(
            "commit",
            "-m",
            prefix + _subject,
            "--author",
            "upstream-port <noreply@omniroute.local>",
            check=False,
            capture=True,
        )
        if res2.returncode != 0:
            # Sometimes there is nothing to commit (empty merge). Try amend-equivalent:
            git("reset", "--hard", "HEAD", check=False, capture=True)
            return {
                "branch": branch,
                "status": "empty-cherrypick",
                "commits": len(picked),
                "messages": picked,
                "failed_sha": sha,
            }
        picked.append(prefix + _subject)

    return {"branch": branch, "status": "ok", "commits": len(picked), "messages": picked}


def main():
    results = []
    for branch in PORT_BRANCHES:
        print(f"--- porting {branch} ---", flush=True)
        result = port_branch(branch)
        results.append(result)
        print(f"    -> {result['status']} ({result['commits']} commits)", flush=True)
        # Commit any leftover in case of failure modes
        git("reset", "--hard", "HEAD", check=False, capture=True)

    out_path = Path(r"C:\Users\koosh\_upstream_port_results.json")
    out_path.write_text(json.dumps(results, indent=2))
    print(f"\nWrote {out_path}")

    ok = sum(1 for r in results if r["status"] == "ok")
    conflict = sum(1 for r in results if r["status"] == "conflict")
    noop = sum(1 for r in results if r["status"] == "noop")
    print(f"\nSummary: {ok} ok, {conflict} conflict, {noop} noop")


if __name__ == "__main__":
    main()