[package]
name = "pheno-compose-driver"
version = "0.1.0"
edition = "2021"
description = "PhenoCompose NVMS Driver - Rust interface to NVMS 3-tier isolation"
license = "MIT OR Apache-2.0"
repository = "https://github.com/KooshaPari/PhenoCompose"
documentation = "https://docs.rs/pheno-compose-driver"
keywords = ["phenotype", "pheno-compose"]
categories = ["development-tools"]
authors = ["kooshapari"]

[dependencies]
nvms-ffi = { path = "../bindings/rust-ffi", optional = true }
pheno-config = { path = "../crates/pheno-config" }

[features]
default = ["nvms"]
nvms = ["nvms-ffi"]  # Enable NVMS backend
mock = []            # Use mock backend for testing

[lib]
name = "pheno_compose_driver"
crate-type = ["lib", "staticlib", "cdylib"]
