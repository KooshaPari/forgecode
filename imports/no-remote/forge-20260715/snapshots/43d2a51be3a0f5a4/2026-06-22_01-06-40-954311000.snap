use chrono::{DateTime, Utc};
use serde::{Deserialize, Serialize};
use uuid::Uuid;

/// Strongly-typed identifier for an `EventEnvelope`.
///
/// Backed by UUIDv7 so IDs are lexicographically sortable by creation time.
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]
#[serde(transparent)]
pub struct EventId(pub Uuid);

impl EventId {
    /// Generate a new UUIDv7 event id.
    pub fn new() -> Self {
        Self(Uuid::now_v7())
    }
}

impl Default for EventId {
    fn default() -> Self {
        Self::new()
    }
}

impl std::fmt::Display for EventId {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        self.0.fmt(f)
    }
}

/// Wire envelope for events flowing through the durable event store.
///
/// Distinct from `phenotype_event_bus::EventEnvelope` which uses a generic
/// typed payload and ULID. This envelope carries a JSON payload plus
/// causation / correlation ids for tracing across boundaries.
#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
pub struct EventEnvelope {
    pub id: EventId,
    pub event_type: String,
    pub schema_version: u32,
    pub causation_id: Option<EventId>,
    pub correlation_id: Option<EventId>,
    pub payload: serde_json::Value,
    #[serde(with = "chrono::serde::ts_milliseconds")]
    pub occurred_at: DateTime<Utc>,
}

impl EventEnvelope {
    /// Construct a new envelope with the current timestamp, schema version 1,
    /// and fresh UUIDv7 id.
    pub fn new(event_type: impl Into<String>, payload: serde_json::Value) -> Self {
        Self {
            id: EventId::new(),
            event_type: event_type.into(),
            schema_version: 1,
            causation_id: None,
            correlation_id: None,
            payload,
            occurred_at: Utc::now(),
        }
    }

    /// Override the schema version for this envelope.
    pub fn with_schema_version(mut self, version: u32) -> Self {
        self.schema_version = version;
        self
    }

    /// Attach a causation id (the event that caused this event).
    pub fn caused_by(mut self, id: EventId) -> Self {
        self.causation_id = Some(id);
        self
    }

    /// Attach a correlation id (groups events in the same logical workflow).
    pub fn correlated_with(mut self, id: EventId) -> Self {
        self.correlation_id = Some(id);
        self
    }
}