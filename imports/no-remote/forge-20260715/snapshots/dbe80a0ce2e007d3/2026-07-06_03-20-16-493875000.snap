$ErrorActionPreference = 'Stop'

# Find existing proxy
$conn = Get-NetTCPConnection -LocalPort 20130 -ErrorAction SilentlyContinue
if ($conn) {
    foreach ($c in $conn) {
        $proc = Get-Process -Id $c.OwningProcess -ErrorAction SilentlyContinue
        if ($proc) {
            Write-Host "Stopping existing proxy PID $($proc.Id) ($($proc.ProcessName))"
            try { Stop-Process -Id $proc.Id -Force } catch {}
        }
    }
    Start-Sleep -Milliseconds 500
}

# Launch new proxy detached
$logPath = 'C:\Users\koosh\AppData\Local\Temp\sse-cleanup-proxy.log'
$errPath = 'C:\Users\koosh\AppData\Local\Temp\sse-cleanup-proxy.err'
$proxyPath = 'C:\Users\koosh\.omniroute\bin\sse-cleanup-proxy.mjs'

$psi = New-Object System.Diagnostics.ProcessStartInfo
$psi.FileName = 'node.exe'
$psi.Arguments = "`"$proxyPath`" 20130"
$psi.RedirectStandardOutput = $true
$psi.RedirectStandardError = $true
$psi.UseShellExecute = $false
$psi.CreateNoWindow = $true

$p = [System.Diagnostics.Process]::Start($psi)
Write-Host "Started new proxy PID $($p.Id)"
$p.Id | Out-File -FilePath 'C:\Users\koosh\.omniroute\bin\.sse-cleanup-proxy.pid' -Encoding ascii

Start-Sleep -Seconds 1

# Verify it's up
$conn = Get-NetTCPConnection -LocalPort 20130 -ErrorAction SilentlyContinue
if ($conn) {
    $proc = Get-Process -Id $conn[0].OwningProcess -ErrorAction SilentlyContinue
    Write-Host "Proxy listening on :20130 (PID $($proc.Id), $($proc.ProcessName))"
} else {
    Write-Host "Proxy not listening — check log: $logPath"
}

# Health probe
try {
    $r = Invoke-WebRequest -Uri 'http://127.0.0.1:20130/health' -TimeoutSec 3 -UseBasicParsing
    Write-Host "Health: $($r.StatusCode) $($r.Content)"
} catch {
    Write-Host "Health probe failed: $($_.Exception.Message)"
}