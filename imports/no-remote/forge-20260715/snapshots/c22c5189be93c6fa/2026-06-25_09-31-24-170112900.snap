/**
 * DAG status types for the Phenotype Epic F live status renderer.
 *
 * F26 — DAG renderer: live status (consumes from F9 events)
 */

/** All possible states a DAG unit node can be in. */
export type DagNodeStatus =
  | "pending"
  | "in-progress"
  | "completed"
  | "failed"
  | "blocked";

/** A single node in the DAG graph. */
export interface DagNode {
  id: string;
  label: string;
  status: DagNodeStatus;
  unitType?: string;
  estimatedHours?: number | null;
  actualHours?: number | null;
  lastUpdated: string | null; // ISO-8601 timestamp; null = never updated
}

/** A directed edge between two nodes (from → to). */
export interface DagEdge {
  from: string;
  to: string;
}

export interface UnitTypeDef {
  label: string;
  defaultHours: number;
}

/** Top-level DAG document (matches dag-data.json). */
export interface DagData {
  title: string;
  description: string;
  unitTypes?: Record<string, UnitTypeDef>;
  nodes: DagNode[];
  edges: DagEdge[];
}

// ─── Event stream types ────────────────────────────────────────────

/** Event type emitted by the status event stream (simulating F9). */
export type DagStatusEventType = "status-change" | "heartbeat" | "reset";

/** Payload for a status-change event. */
export interface DagStatusChangePayload {
  nodeId: string;
  newStatus: DagNodeStatus;
  timestamp: string; // ISO-8601
}

/** A single status event from the stream. */
export interface DagStatusEvent {
  type: DagStatusEventType;
  payload: DagStatusChangePayload | null;
}

// ─── View mode ─────────────────────────────────────────────────────

export type DagViewMode = "live" | "static";

// ─── Store state ───────────────────────────────────────────────────

export interface DagStoreState {
  data: DagData;
  viewMode: DagViewMode;
  isPolling: boolean;
  lastPollAt: string | null; // ISO-8601
  error: string | null;
}

// ─── Status display config ─────────────────────────────────────────

export interface StatusBadgeConfig {
  label: string;
  color: string;
  bg: string;
}

// ─── Bucket / parallel-schedule types (F29) ───────────────────────

export interface BucketNode {
  id: string;
  label: string;
  status: DagNodeStatus;
  duration: number;
  isCritical: boolean;
  estimatedHours?: number | null;
}

export interface Bucket {
  index: number;
  nodes: BucketNode[];
  wallClock: number; // max duration in this bucket
}

export interface BucketSchedule {
  buckets: Bucket[];
  criticalPath: string[];
  totalWallClock: number;
  criticalPathTime: number;
}

// ─── Cost summary types (F28) ──────────────────────────────────────

export interface CostByType {
  label: string;
  count: number;
  estimatedHours: number;
  actualHours: number;
  actualCount: number;
}

export interface CostSummary {
  byUnitType: Record<string, CostByType>;
  byStatus: Record<string, CostByType>;
  totals: {
    nodes: number;
    estimatedNodes: number;
    actualNodes: number;
    totalEstimatedHours: number;
    totalActualHours: number;
    variance: number | null;
  };
}

export const STATUS_BADGE: Record<DagNodeStatus, StatusBadgeConfig> = {
  pending:       { label: "pending",     color: "#8a8a93", bg: "rgba(138,138,147,0.15)" },
  "in-progress": { label: "in-prog",     color: "#7ebab5", bg: "rgba(126,186,181,0.15)" },
  completed:     { label: "completed",   color: "#22c55e", bg: "rgba(34,197,94,0.15)" },
  failed:        { label: "failed",      color: "#ef4444", bg: "rgba(239,68,68,0.15)" },
  blocked:       { label: "blocked",     color: "#eab308", bg: "rgba(234,179,8,0.15)" },
};
