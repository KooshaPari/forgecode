name: gitleaks

on:
  push:
    branches: ["**"]
  pull_request:
    branches: ["**"]
  schedule:
    - cron: "0 6 * * 1"

permissions:
  contents: read
  pull-requests: read
  security-events: write

env:
  GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
  GITLEAKS_CONFIG: gitleaks.toml

jobs:
  scan:
    name: gitleaks scan
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0 # v7.0.0
        with:
          fetch-depth: 0

      - name: Run gitleaks
        # Empirical fix (eco-044-gate-triage): pin to a real SHA. Floating `@v2`
        # was resolving to a placeholder SHA in some runner contexts and failing
        # with "Unable to resolve action gitleaks/gitleaks-action@1c4d3b6...".
        uses: gitleaks/gitleaks-action@1cabd6b4e4506eb8681e3726d0c9dddbf0bb1b51 # v2.3.0
        env:
          GITHUB_TOKEN: ${{ env.GITHUB_TOKEN }}
          GITLEAKS_CONFIG: ${{ env.GITLEAKS_CONFIG }}
