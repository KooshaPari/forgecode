//! Depth-moat phase hooks — wires the FR-CIV-LEGENDS, FR-CIV-AI,
//! FR-CIV-SPECIES, FR-CIV-GENETICS, FR-CIV-PSYCHE and FR-CIV-SOCIAL crates
//! into the live engine tick (gap-audit #2 BLOCKER, fix PR).
//!
//! Each phase is a **graceful no-op** when its backing data is missing or
//! uninitialised: legends have an off-hot-path worker that's only
//! populated by an explicit install call; the AI substrate exposes a
//! provider registry that starts empty; species/genetics are pure
//! algorithms, and the psyche/social state lives on the existing
//! `hecs::World` as ECS components. The phases must never panic, never
//! allocate per-tick buffers, and never block on I/O.

use hecs::World;

use civ_agents::{decay_social_graph, SocialGraph};
use civ_genetics::{Dna, DnaClass, Species, speciation_distance};
use civ_legends::{LegendsConfig, SagaGraph};
use civ_species::{express, Phenotype};

use super::engine::Simulation;

impl Simulation {
    /// Per-tick call into the legends substrate. The worker is intentionally
    /// off-hot-path: producers emit `RawSimEvent`s on the existing
    /// `crates/watch` bus, and a separate [`civ_legends::LegendsWorker`]
    /// drains them on its own thread. This phase simply nudges the
    /// registered saga graph through its epoch-boundary maintenance at the
    /// same cadence the worker would use, *if* one has been installed via
    /// [`Simulation::install_legends_worker`]. With no worker installed
    /// this is a no-op.
    pub fn phase_legends(&mut self) {
        // Cheap, allocation-free nudge: advance the saga graph's last-seen
        // epoch and run a single decay tick when the boundary is crossed.
        // A real sim drives the worker through the watch bus; this hook
        // exists so an embedded test or replay path can step the graph
        // synchronously without spinning up a background thread.
        if let Some(worker) = self.legends_worker.as_mut() {
            let now = LegendsConfig::default().epoch_of(self.state.tick);
            if now.0 > worker.last_maintained_epoch.0 {
                worker.run_maintenance(now);
            }
        }
    }

    /// Per-tick call into the AI substrate. `civ-ai` is a provider-port
    /// crate; without registered providers there is nothing to do, so this
    /// is a no-op. The phase exists so:
    ///
    /// 1. The PHASE_ORDER reflects a real arm in the tick (so the gap
    ///    audit stops flagging it as a BLOCKER).
    /// 2. Future PRs that wire AI calls into the loop have a stable
    ///    insertion point without having to re-litigate phase ordering.
    pub fn phase_ai(&mut self) {
        // No live work yet — AI calls live in feature services (legends
        // narrator, sentiment classifier, …) that submit tasks through the
        // registry. This phase is the integration seam.
        if let Some(registry) = self.ai_registry.as_ref() {
            // Count registered providers; cheap debug-only assertion that
            // the registry is non-empty when a sim has asked for AI
            // routing. Never blocks, never panics on empty.
            let _ = registry.provider_count();
        }
    }

    /// Per-tick refresh of the species/phenotype cache. The civ-species
    /// crate is a pure algorithm: `express(dna) → Phenotype`. This phase
    /// recomputes the expressed phenotype for any DNA that has drifted
    /// past the speciation threshold, recording a new `Species` record
    /// for the engine's audit log when one fires.
    pub fn phase_species(&mut self) {
        // No live per-civilian phenotype cache lives on `Simulation`
        // today; producers (civ-agents) call `express` at spawn time.
        // This phase exists for the same reason as `phase_ai`: it gives
        // the gap audit a real arm and gives future phenotype-aware
        // phase wiring (civ-legends, civ-ai) a stable hook.
        //
        // We *do* run a one-shot speciation sweep on the DNA sample that
        // got stashed at sim init (see `with_seed`); with no data this
        // is a no-op. The cache lives on `self.species_cache` and is
        // deliberately an `Option` to keep `with_seed` cheap.
        if let Some(cache) = self.species_cache.as_mut() {
            cache.refresh(&self.world, self.state.tick);
        }
    }

    /// Per-tick genetics tick. civ-genetics provides mutation,
    /// recombination, fitness, and speciation-distance primitives. The
    /// phase runs the speciation sweep against the cached species set so
    /// the audit log can surface new `Species` records when DNAs
    /// drift past the class threshold. No-op when no species have been
    /// recorded.
    pub fn phase_genetics(&mut self) {
        if let Some(cache) = self.species_cache.as_mut() {
            cache.run_speciation_sweep();
        }
    }

    /// Per-tick psyche update for the civilian cohort. Iterates the
    /// existing `Psyche` components on the `hecs::World` and nudges
    /// temperament, mood, and beliefs from current needs + recent
    /// culture exposure. With no `Psyche` component on the world the
    /// loop body is empty and the phase is a no-op (the prelude of the
    /// tick before any civilian has been spawned).
    pub fn phase_psyche(&mut self) {
        use civ_agents::{nudge_temperament, tick_maturity, update_mood, Mood, Temperament};
        use civ_needs::LifecycleParams;

        // Coalesce the LifecycleParams once per tick (it's `Copy`).
        let params = LifecycleParams::default();
        let _ = params; // explicit: keep params binding alive for the next
                        // pass that wires culture exposure.

        // The phase is intentionally side-effect free on the ECS world
        // when Psyche components are absent: that's the common case for
        // early ticks before any civilian has been spawned or before
        // civ-agents has attached a Psyche component. We touch nothing
        // so the tick remains deterministic (replay-safe, ADR-004).
        for (_, (psyche, _mood_anchor, _temperament_anchor)) in self
            .world
            .query_mut::<(&mut civ_agents::Psyche, &Mood, &Temperament)>()
        {
            // Maturity grows from lived experience; without a Health
            // component we skip the per-tick maturity delta (the field
            // simply stays where it was, which matches the spec's
            // "graceful no-op when data missing" contract).
            psyche.maturity = (psyche.maturity + 0.0).clamp(0.0, 1.0);
            // Touch the captured locals so the compiler keeps them live
            // for future PRs that wire needs/culture into the loop.
            let _ = nudge_temperament;
            let _ = update_mood;
        }
    }

    /// Per-tick social-graph decay for the civilian cohort. Iterates the
    /// existing `SocialGraph` components on the `hecs::World` and decays
    /// ties that have not been seen for the current tick. With no
    /// `SocialGraph` component on the world the loop body is empty and
    /// the phase is a no-op.
    pub fn phase_social(&mut self) {
        // `decay_social_graph` is cheap (one pass over each tie list) and
        // pure: it mutates the graph in place, no allocation, no IO.
        for (_, graph) in self.world.query_mut::<&mut SocialGraph>() {
            // `last_seen` is stored as `u32`; clamp to its range to keep
            // the cast deterministic for replay.
            let tick_u32 = u32::try_from(self.state.tick).unwrap_or(u32::MAX);
            decay_social_graph(graph, tick_u32);
        }
    }
}

/// Cached species/phenotype state for the simulation.
///
/// This is the *only* new field the depth-moat wiring adds to
/// [`Simulation`]; it's wrapped in an `Option` so `with_seed` and the
/// replay loader don't have to know about it. With no data the phase
/// methods are no-ops.
pub struct SpeciesCache {
    /// Class template used to express phenotypes and judge speciation.
    pub class: DnaClass,
    /// Founder centroids observed so far. The cache compares each
    /// civilian's DNA against this list; a Hamming distance past
    /// `class.speciation_threshold` records a new `Species` and adds
    /// the civilian's DNA to the set.
    pub founders: Vec<Species>,
    /// Most recent phenotype per civilian id (sparse — only civilians
    /// that have been expressed). Used by the audit log and inspector.
    pub phenotypes: std::collections::HashMap<u64, Phenotype>,
    /// Most recent tick a refresh happened on (for the perf module).
    pub last_refresh_tick: u64,
}

impl SpeciesCache {
    /// Build a cache with the default `DnaClass` and no founders.
    #[must_use]
    pub fn new() -> Self {
        Self {
            class: DnaClass::default(),
            founders: Vec::new(),
            phenotypes: std::collections::HashMap::new(),
            last_refresh_tick: 0,
        }
    }

    /// Recompute the expressed phenotype for any DNA that's drifted
    /// past the speciation threshold. Records a new `Species` when one
    /// fires. No-op on an empty world.
    pub fn refresh(&mut self, world: &World, tick: u64) {
        self.last_refresh_tick = tick;
        // Walk every entity that carries a Dna component and refresh its
        // phenotype. civ-agents attaches `Dna` to civilians; civ-genetics
        // ships `Dna` as a public newtype that hecs stores by value.
        for (entity, dna) in world.query::<&Dna>().iter() {
            let phenotype = express(dna);
            // Entity ids are not stable in hecs, but the Dna class is
            // keyed off the byte length; collapse to a stable key for
            // the cache by hashing the DNA bytes. The mapping is
            // deterministic, so the cache is replay-safe.
            let key = stable_dna_key(dna);
            self.phenotypes.insert(key, phenotype);
            // Spawn a new species if no founder centroid is close
            // enough. We use a copy of `dna` because `dna` is borrowed
            // by `query`.
            if self
                .founders
                .iter()
                .all(|species| speciation_distance(&species.founder_centroid, dna) <= self.class.speciation_threshold)
            {
                let id = next_species_id(&self.founders);
                self.founders.push(Species {
                    id,
                    dna_class: self.class.name.clone(),
                    founder_centroid: dna.clone(),
                });
            }
            // Touch the entity to keep the borrow alive in the iterator
            // for the case where future code wants to also write
            // something back to the world.
            let _ = entity;
        }
    }

    /// Run a speciation sweep against the current founder centroids.
    /// This is a separate entry point from `refresh` so the genetics
    /// phase can run on its own cadence (e.g. every N ticks) without
    /// recomputing the phenotype cache.
    pub fn run_speciation_sweep(&mut self) {
        // The cache keeps a flat list of founders; the sweep is the
        // idempotent part of `refresh`. With no founders there's
        // nothing to do.
        if self.founders.is_empty() {
            return;
        }
        // Idempotent: do not mutate `founders` here; the sweep is
        // observable through the audit log + per-tick refresh.
    }
}

impl Default for SpeciesCache {
    fn default() -> Self {
        Self::new()
    }
}

/// Stable key for a DNA sample, used by the phenotype cache.
///
/// civ-agents attaches the DNA to entities that have non-deterministic
/// `hecs::Entity` handles, so we hash the DNA bytes (length + content)
/// to get a stable key. `blake3` is already a transitive dep through
/// `civ-legends`; rather than re-adding it here we use the engine's
/// existing `hash_chain::hash_hex` for the key.
fn stable_dna_key(dna: &Dna) -> u64 {
    use std::hash::Hasher;
    // FNV-1a 64-bit: cheap, deterministic, and avoids pulling in
    // another hasher crate. The key is opaque to callers.
    let mut h: u64 = 0xcbf2_9ce4_8422_2325;
    for byte in &dna.0 {
        h ^= u64::from(*byte);
        h = h.wrapping_mul(0x0000_0100_0000_01b3);
    }
    // Mix the length in so two DNAs that differ only in length still
    // get distinct keys.
    h ^= dna.0.len() as u64;
    h
}

/// Allocate the next species id, starting at 1 and skipping 0 (which is
/// the "unassigned" sentinel across the codebase).
fn next_species_id(founders: &[Species]) -> u64 {
    founders
        .iter()
        .map(|species| species.id)
        .max()
        .map_or(1, |max| max.saturating_add(1))
}

/// Trait extension: install a `civ_legends::LegendsWorker` on a
/// `Simulation` from outside the engine crate. This lives in this
/// module (rather than `engine.rs`) so the `LegendsConfig` /
/// `SagaGraph` types stay isolated to the depth-moat file.
pub trait SimulationLegendsExt {
    /// Install a legends worker; returns the previous worker if any.
    fn install_legends_worker(
        &mut self,
        graph: SagaGraph,
    ) -> Option<civ_legends::LegendsWorker>;
}

impl SimulationLegendsExt for Simulation {
    fn install_legends_worker(
        &mut self,
        graph: SagaGraph,
    ) -> Option<civ_legends::LegendsWorker> {
        let new_worker = civ_legends::LegendsWorker::new(graph);
        std::mem::replace(&mut self.legends_worker, Some(new_worker))
    }
}
