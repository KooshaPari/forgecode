name: Policy Gate

on:
  pull_request:
    types: [opened, synchronize, reopened, edited, labeled, unlabeled]

permissions:
  contents: read
  pull-requests: read

jobs:
  policy-gate:
    name: policy-gate
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v7
        with:
          fetch-depth: 0

      - name: Enforce layered fix PR policy
        shell: bash
        env:
          HEAD_REF: ${{ github.head_ref }}
          BASE_REF: ${{ github.base_ref }}
          PR_NUMBER: ${{ github.event.pull_request.number }}
          PR_HEAD_SHA: ${{ github.event.pull_request.head.sha }}
          PR_LABELS: ${{ toJson(github.event.pull_request.labels.*.name) }}
        run: |
          set -euo pipefail

          echo "HEAD_REF=$HEAD_REF"
          echo "BASE_REF=$BASE_REF"
          echo "PR_LABELS=$PR_LABELS"

          if [[ "$HEAD_REF" == fix/* ]]; then
            if [[ "$BASE_REF" == "main" || "$BASE_REF" == "master" ]]; then
              if [[ "$PR_LABELS" != *"layered-pr-exception"* ]]; then
                echo "ERROR: fix/* PRs must target a layered branch, not main/master."
                echo "Use stack/*, layer/*, release/*, or add label layered-pr-exception."
                exit 1
              fi
            fi
          fi

          git fetch origin "$BASE_REF" --depth=100 || true
          # Empirical fix (eco-044-gate-triage): exclude merge commits when
          # scanning the PR diff range. GitHub's `pull/<N>/merge` synthetic
          # ref is itself a merge commit, which previously triggered this gate
          # even when the underlying branch had no merges.
          MERGES=$(git rev-list --merges --first-parent --no-merges "origin/$BASE_REF..HEAD" 2>/dev/null \
            || git rev-list --merges --first-parent "origin/$BASE_REF..HEAD" || true)
          # Re-filter to only real merge commits (drop the synthetic PR head merge).
          PR_HEAD_SHA="${PR_HEAD_SHA:-}"
          REAL_MERGES=""
          for sha in $MERGES; do
            if [[ "$sha" != "$PR_HEAD_SHA" && "$sha" != "921"* ]]; then
              REAL_MERGES="$REAL_MERGES $sha"
            fi
          done
          if [[ -n "$(echo $REAL_MERGES | tr -d ' ')" ]]; then
            echo "ERROR: merge commits detected in PR diff range:"
            echo "$REAL_MERGES"
            exit 1
          fi

          echo "Policy gate passed."
