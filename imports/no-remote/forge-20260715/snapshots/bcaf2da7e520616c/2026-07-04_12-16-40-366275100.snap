# cargo-deny configuration for the PlayCua workspace.
#
# L2 #34 / orch-v12-s2-010 — tier-0 governance baseline.
#
# Consumed by:
#   - `just deny`           (local, see justfile:55-56)
#   - `cargo deny check`    (CI, see .github/workflows/deny.yml)
#
# Policy summary:
#   * [advisories]  : fail on known RustSec advisories; `yanked = "warn"`
#                     surfaces yanked-crate usage without breaking the build.
#   * [licenses]    : allowlist of permissive + copyleft-OK licenses; the
#                     `confidence-threshold = 0.8` lets us keep moving on
#                     low-confidence license detections while flagging the
#                     long tail of SPDX unknowns.
#   * [bans]        : `multiple-versions = "warn"` so the workspace surfaces
#                     duplicated transitive deps but does not block on them;
#                     `wildcards = "deny"` keeps dependency specs explicit.
#   * [sources]     : only crates.io is allowed; git deps are warnings so we
#                     notice drift without hard-failing during bootstrapping.
#
# If you need to mute a specific advisory, add a `reason` string to its
# `ignore` entry — do not blanket-skip a `db-path` or `db-urls`.

[graph]
# Default: each crate is evaluated using only its declared features.
# Setting `all-features = true` is *much* slower and rarely needed; we leave
# it off so `cargo deny check` stays in the sub-minute regime on CI.
all-features = false

[advisories]
db-path = "~/.cargo/advisory-db"
db-urls = ["https://github.com/rustsec/advisory-db"]
yanked = "warn"
ignore = []
# `notice` is the default; promoting it to `warn` would surface
# informational advisories in CI output, which is not useful here.

[licenses]
version = 2
allow = [
    "MIT",
    "Apache-2.0",
    "Apache-2.0 WITH LLVM-exception",
    "BSD-2-Clause",
    "BSD-3-Clause",
    "ISC",
    "Zlib",
    "Unicode-DFS-2016",
    "Unicode-3.0",
    "CC0-1.0",
    "OpenSSL",
    "MPL-2.0",
    "BSL-1.0",
    "0BSD",
    "Unlicense",
    "NCSA",
    # Note: "Zlib-Acknowledgement" is **not** a valid SPDX identifier
    # (cargo-deny 0.19 fails to deserialize this config with
    # `error[custom]: unknown term`). It was added speculatively; the
    # `Zlib` SPDX identifier above is the canonical short form and is
    # what `zlib-acknowledgement` crates actually resolve to in the
    # askalono / clearlydefined database. Removed by sapanw-A.
]
# `confidence-threshold = 0.8` matches the upstream recommended default:
# a license must be detected with >=80% SPDX-similarity to count as
# authoritative. Lower-confidence matches still appear in the report
# as `confidence` notes so we can review them manually.
confidence-threshold = 0.8

[bans]
# Surface duplicate versions of the same crate across the dep graph,
# but do not hard-fail — duplicated minor versions are usually safe and
# pinning everything to a single version is more disruptive than useful.
multiple-versions = "warn"
# Wildcard version requirements are a foot-gun (transitive breakage,
# unreviewable updates). Force every spec to be a concrete semver bound.
wildcards = "deny"
# Highlight the entire crate chain in violation reports so the offending
# crate path is obvious in CI logs.
highlight = "all"
deny = []
# `skip`/`skip-tree` are intentionally left empty — the right way to
# suppress a specific ban is to add a `skip` entry *with a reason* here,
# not to flip the global policy.
skip = []
skip-tree = []

[sources]
unknown-registry = "deny"
unknown-git = "warn"
allow-registry = ["https://github.com/rust-lang/crates.io-index"]
allow-git = []
