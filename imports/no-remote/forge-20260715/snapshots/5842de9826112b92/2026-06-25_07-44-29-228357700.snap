    data["edges"].append({"from": f, "to": t})

path = r"C:\Users\koosh\phenotype-landing\sites\projects-landing\data\dag-data.json"
with open(path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2, ensure_ascii=False)

repos = sorted(set(n["repo"] for n in data["nodes"]))
epics = sorted(set(n["epic"] for n in data["nodes"]))
print(f"Written: {len(data['nodes'])} nodes, {len(data['edges'])} edges")
print(f"Repos ({len(repos)}): {repos}")
print(f"Epics ({len(epics)}): {epics}")
