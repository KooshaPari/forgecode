{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "files": [
    "./shared_stub.ts",
    "./clinepass-flat.ts",
    "./apikey-gateways-stub.ts",
    "./usagesupported-stub.ts"
  ]
}
