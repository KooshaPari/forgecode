<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.5.1" />
    <PackageReference Include="xunit" Version="2.9.3" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.5" />
    <PackageReference Include="FluentAssertions" Version="8.10.0" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="coverlet.collector" Version="6.0.2">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="coverlet.msbuild" Version="6.0.2">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <!--
      Only the Unity-free WorldSphereAPI assembly is referenced. The main mod
      pulls in WorldBox/Unity DLLs that aren't available on CI runners.
      SavedSettings + JSON helpers are compile-linked from the mod tree for fuzz tests.
    -->
    <ProjectReference Include="..\..\WorldSphereAPI.csproj" />
    <Compile Include="..\..\WorldSphereMod\Code\SavedSettings.cs" Link="Mod\SavedSettings.cs" />
    <Compile Include="..\..\WorldSphereMod\Code\SavedSettingsJson.cs" Link="Mod\SavedSettingsJson.cs" />
    <Compile Include="..\..\WorldSphereMod\Code\Bridge\BridgeSettingParser.cs" Link="Mod\BridgeSettingParser.cs" />
    <Compile Include="..\..\WorldSphereMod\Code\Constants.cs" Link="Mod\Constants.cs" />
    <Compile Include="..\..\WorldSphereMod\Code\Import\TexturePackRegistry.cs" Link="Mod/TexturePackRegistry.cs" />
    <Compile Include="..\..\WorldSphereMod\Code\Import\TexturePackImporter.cs" Link="Mod/TexturePackImporter.cs" />
    <Compile Include="..\..\WorldSphereMod\Code\Texture\McPackManifestIO.cs" Link="Mod/McPackManifestIO.cs" />
  </ItemGroup>

</Project>
