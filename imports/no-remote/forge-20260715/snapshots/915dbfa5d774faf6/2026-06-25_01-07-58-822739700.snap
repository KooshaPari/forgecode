#!/usr/bin/env bash
# Re-grade all 7 owned repos using the registry's grade.sh.
# Captures Stack/Grade/Per-Check to /c/Users/koosh/_grade_v3/.

set -e

GRADER=/c/Users/koosh/phenotype-registry/grade.sh
OUTDIR=/c/Users/koosh/_grade_v3
mkdir -p "$OUTDIR"

REPOS=(
  "eyetracker:/c/Users/koosh/Dev/eyetracker"
  "Eventra:/c/Users/koosh/Dev/Eventra"
  "Configra:/c/Users/koosh/Dev/Configra"
  "Benchora:/c/Users/koosh/Dev/Benchora"
  "Authvault:/c/Users/koosh/Dev/Authvault"
  "Quillr:/c/Users/koosh/Dev/Quillr"
  "AuthKit:/c/Users/koosh/Dev/AuthKit"
)

SUMMARY="$OUTDIR/SUMMARY.md"
{
  echo "# Owned Scope Grade Sweep v3 (2026-06-24)"
  echo ""
  echo "Generated by \`_grade_v3.sh\`. Pre-fix: \`_grade_owned/{name}.txt\`. Post-fix: this run."
  echo ""
  echo "| Repo | Stack | Score | Grade | Key failures |"
  echo "|---|---|---|---|---|"
} > "$SUMMARY"

for ENTRY in "${REPOS[@]}"; do
  NAME="${ENTRY%%:*}"
  DIR="${ENTRY#*:}"
  echo "=== grading $NAME ==="
  LOG="$OUTDIR/${NAME}.txt"
  pushd "$DIR" >/dev/null
  bash "$GRADER" --fast 2>&1 > "$LOG" || true
  popd >/dev/null

  STACK=$(grep -m1 "^Stack:" "$LOG" 2>/dev/null | head -1 | sed 's/Stack: *//')
  GRADE=$(grep -m1 "^GRADE:" "$LOG" 2>/dev/null | head -1 | sed 's/GRADE: *//')
  SCORE=$(grep -m1 "^SCORE:" "$LOG" 2>/dev/null | head -1 | sed 's/SCORE: *//')
  FAILS=$(grep -E "^\s*\[FAIL\]" "$LOG" 2>/dev/null | sed 's/^[[:space:]]*//' | head -3 | tr '\n' '; ' | sed 's/;$//')

  STACK=${STACK:-"?"}
  GRADE=${GRADE:-"?"}
  SCORE=${SCORE:-"?"}
  FAILS=${FAILS:-"-"}

  echo "| $NAME | $STACK | $SCORE | $GRADE | $FAILS |" >> "$SUMMARY"
done

echo ""
echo "=== DONE ==="
echo "Report: $SUMMARY"