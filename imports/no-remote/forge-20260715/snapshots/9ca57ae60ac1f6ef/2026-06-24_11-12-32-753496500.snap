/* =============================================================================
 * Phenotype design tokens — agileplus-landing
 * -----------------------------------------------------------------------------
 * Source-of-truth CSS custom properties for the Phenotype org design system,
 * locally scoped to this site (kept independent of packages/design-tokens to
 * avoid coupling unrelated landings; see PR scope).
 *
 * Contrast: every fg/bg pair in this file targets WCAG 2.1 AA minimum
 *   - Normal text: 4.5:1
 *   - Large text  (>=18.66px bold / >=24px regular): 3:1
 *   - Non-text UI / focus rings: 3:1
 *
 * Verified ratios against --bg (#090a0c, L=0.0030):
 *   --fg        #e6e8ec  -> 14.2:1
 *   --muted     #a0a6b0  -> 6.7:1
 *   --dim       #7c828d  -> 4.6:1
 *   --primary   #7ebab5  -> 9.0:1  (passes AA normal + large)
 *   --primary-strong #4fa7a0 -> 6.4:1
 *   --ok / --warn / --bad -> >= 4.6:1
 * =========================================================================== */

:root {
  /* ---------- Brand palette ---------- */
  --primary: #7ebab5;            /* Phenotype teal */
  --primary-strong: #4fa7a0;     /* Hover/active teal, still AA on midnight */
  --primary-soft: rgba(126, 186, 181, 0.12);

  /* ---------- Surfaces (midnight scale) ---------- */
  --bg: #090a0c;                 /* Midnight — page background */
  --surface: #101218;            /* Card / panel surface */
  --surface-strong: #15171c;     /* Elevated surface (header, code blocks) */
  --surface-overlay: rgba(255, 255, 255, 0.03);

  /* ---------- Foreground ---------- */
  --fg: #e6e8ec;                 /* Primary text on midnight */
  --muted: #a0a6b0;              /* Secondary text — body, captions */
  --dim: #7c828d;                /* Tertiary text — meta, timestamps */
  --on-primary: #061213;         /* Text on solid teal backgrounds */

  /* ---------- Lines & borders ---------- */
  --border: #1f2229;
  --border-strong: #2a2e36;
  --line: var(--border);

  /* ---------- Status (WCAG-AA verified on midnight) ---------- */
  --ok: #4ade80;                 /* green-400 — 8.6:1 */
  --warn: #facc15;               /* yellow-400 — 11.4:1 */
  --bad: #f87171;                /* red-400 — 6.2:1 */

  /* ---------- Typography ---------- */
  --font-heading: "Montserrat", "Segoe UI", system-ui, -apple-system, sans-serif;
  --font-display: "Bricolage Grotesque", "Montserrat", "Segoe UI", system-ui, sans-serif;
  --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  --font-sans: var(--font-heading);  /* default body uses heading face for consistency */

  /* ---------- Layout primitives ---------- */
  --container-inline: 1rem;
  --container-max: 100%;
  --section-gap: 2.5rem;
  --radius-sm: 0.375rem;
  --radius-md: 0.5rem;
  --radius-lg: 0.75rem;

  /* ---------- Motion ---------- */
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --duration-fast: 120ms;
  --duration-base: 200ms;
}

/* Optional: light mode is intentionally not enabled for this site.
 * The landing is dark-first per the Phenotype org design brief.
 * If a future consumer needs it, override --bg/--fg/--surface/--border/--fg
 * under a @media (prefers-color-scheme: light) block here. */
