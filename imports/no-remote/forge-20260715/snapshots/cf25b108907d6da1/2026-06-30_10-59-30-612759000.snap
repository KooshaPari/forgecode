[package]
name = "civis-mesh"
version.workspace = true
edition.workspace = true
license.workspace = true
rust-version.workspace = true
description = "Quorum + CRDT mesh sync with encrypted envelope transport for offline-first governance dossiers."

[lib]
path = "src/lib.rs"

[dependencies]
# --- Crypto: signatures ---
# ed25519-dalek is already used elsewhere in the workspace (crates/watch,
# crates/mod-host), so this is not a new dep.
ed25519-dalek = { version = "2", features = ["rand_core"] }

# --- Crypto: AEAD ---
# chacha20poly1305 was NOT previously in the workspace's direct dep graph; it
# is pulled transitively only through other crates. Flagged as a NEW workspace
# dep per the "never add new ones without flagging" rule.
chacha20poly1305 = "0.10"

# --- Crypto: X25519 ---
# x25519-dalek is NEW to this workspace's direct dep graph; flagged per the
# "never add new ones without flagging" rule. The underlying curve25519-dalek
# crate is already in the lockfile (via ed25519-dalek).
x25519-dalek = { version = "2", features = ["static_secrets"] }

# --- Hashing / encoding ---
blake3 = "1"
sha2 = "0.10"
base64 = "0.22"
rand_core = { version = "0.6", features = ["std"] }

# --- Serialization ---
serde = { version = "1", features = ["derive"] }
serde_json = "1"

[dev-dependencies]
rand = "0.8"
hex = "0.4"
