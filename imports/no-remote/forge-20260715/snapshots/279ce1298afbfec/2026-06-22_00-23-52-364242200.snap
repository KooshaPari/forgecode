d = json.load(open(SRC, encoding="utf-8"))
rows = d["rows"]

# 3 new disposition rows
new_rows = [
    {
        "id": "repo-phenoRouterMonitor",
        "path": "KooshaPari/phenoRouterMonitor",
        "disposition": "ABSORBED",
        "target": "KooshaPari/phenoAI/crates/llm-router",
        "wave": "P5-4",
        "fsm": "done",
        "adr": "ADR-ECO-014-phenoroutermonitor-absorption",
        "relocated_date": "2026-06-21",
        "note": "Router + Streamlit absorbed to phenoAI/crates/llm-router; repo archived 2026-06-21 per docs/operations/p5-4-phenoroutermonitor-absorption-2026-06-20.md",
    },
    {
        "id": "repo-PhenoProject",
        "path": "KooshaPari/PhenoProject",
        "disposition": "ARCHIVED",
        "target": "KooshaPari/phenotype-registry",
        "wave": "P5-4",
        "fsm": "done",
        "adr": "ADR-ECO-014-surface-reduction",
        "relocated_date": "2026-06-21",
        "note": "Dependabot-only activity, no PRs since 2026-04; boundary docs migrated to phenotype-registry/registry/; archived 2026-06-21",
    },
    {
        "id": "repo-thegent-sharecli",
        "path": "KooshaPari/thegent-sharecli",
        "disposition": "DEPRECATED-MERGED",
        "target": "KooshaPari/sharecli",
        "wave": "P5-4",
        "fsm": "done",
        "adr": "ADR-ECO-014-sharecli-canonical",
        "relocated_date": "2026-06-21",
        "note": "DEPRECATED duplicate of sharecli (per repo description); content (SPEC, PLAN, GEMINI, TEST_COVERAGE_MATRIX) superseded by sharecli 27-file strict superset; repo archived 2026-06-21",
    },
    {
        "id": "gate-thegent-sharecli",
        "path": "KooshaPari/thegent-sharecli",
        "disposition": "DELETE-eligible",
        "target": "KooshaPari/sharecli",
        "wave": "P5-4",
        "fsm": "done",
        "relocated_date": "2026-06-21",
        "note": "3 open PRs (GEMINI.md mirror, phase3 spec, orch-v12 governance) closed obsolete 2026-06-21; sharecli is canonical",
