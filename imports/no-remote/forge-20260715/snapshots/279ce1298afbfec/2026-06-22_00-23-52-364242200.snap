d["_paperwork_audit"] = {
    "session": "consolidation-2026-06-21",
    "added": [r["id"] for r in new_rows],
    "repos_archived": [
        "KooshaPari/thegent-sharecli",
        "KooshaPari/phenoRouterMonitor",
        "KooshaPari/PhenoProject",
    ],
