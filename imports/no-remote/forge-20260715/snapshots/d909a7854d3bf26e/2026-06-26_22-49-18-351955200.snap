DATA_DIR=C:\Users\koosh\AppData\Roaming\omniroute
OMNIROUTE_MEMORY_MB=16384
REQUEST_TIMEOUT_MS=600000
OMNIROUTE_DEFAULT_FETCH_TIMEOUT_MS=480000
RATE_LIMIT_MAX_WAIT_MS=10000
FETCH_KEEPALIVE_TIMEOUT_MS=60000
DEFAULT_REQUEST_TIMEOUT_MS=120000
# Live-WS sidecar (port 20129) is not running in this single-port deployment.
# The lazy-backoff helper in open-sse/handlers/chatCore/telemetryHelpers.ts already
# throttles forwardDashboardEventToLiveWs after 3 failures (60s cooldown), but the
# [ProxyFetch] Undici dispatcher failed warning is emitted by proxyFetch.ts BEFORE
# the caller can swallow the error. Until the sidecar is launched (see PR
# draft) we patch proxyFetch to skip the warning for loopback targets where
# the failure is always sidecar-not-listening.
OMNIROUTE_DISABLE_LIVE_WS_BRIDGE_WARN=true

# === Per-user triage overrides ===
# Cap per-provider rate-limit queue wait so a stuck provider doesnt stall the whole combo.
# Upstream default is 120000ms (2min). User experiences "hyper slow -> fail every time"
# because Main's 25+ candidate targets each queue for 2min before timing out.
RATE_LIMIT_MAX_WAIT_MS=10000
# Synthesize prompt_cache_key from request fingerprint when client omits it.
# Anthropic-compatible providers like minimax/MiniMax-M3 + kiro need it for cache affinity.
OMNIROUTE_PROMPT_CACHE_KEY_FINGERPRINT=1
