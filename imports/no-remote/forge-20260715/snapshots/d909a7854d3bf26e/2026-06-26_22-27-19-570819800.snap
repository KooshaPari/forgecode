# Live-WS sidecar (port 20129) is not running in this single-port deployment.
# The lazy-backoff helper in open-sse/handlers/chatCore/telemetryHelpers.ts already
# throttles forwardDashboardEventToLiveWs after 3 failures (60s cooldown), but the
# [ProxyFetch] Undici dispatcher failed warning is emitted by proxyFetch.ts BEFORE
# the caller can swallow the error. Until the sidecar is launched (see PR
# draft) we patch proxyFetch to skip the warning for loopback targets where
# the failure is always sidecar-not-listening.
OMNIROUTE_DISABLE_LIVE_WS_BRIDGE_WARN=true
