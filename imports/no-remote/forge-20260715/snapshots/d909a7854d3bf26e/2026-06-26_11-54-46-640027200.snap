# Live-WS sidecar (port 20129) is not running in this single-port deployment.
# Without this, every dashboard event POSTs to 20129 → ECONNREFUSED → [ProxyFetch] flood.
# Upstream fix tracked in upstream issue #4604 (deployed build 3.8.37 already has the
# lazy backoff helper; setting this avoids the fetch path entirely).
OMNIROUTE_DISABLE_LIVE_WS=true
OMNIROUTE_DISABLE_DASHBOARD_BRIDGE=true
