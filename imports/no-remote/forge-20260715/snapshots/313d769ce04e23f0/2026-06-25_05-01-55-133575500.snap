[package]
name = "byteport-cli"
version = "0.1.0"
edition = "2021"
license = "MIT OR Apache-2.0"
description = "BytePort tools CLI — transport, port, codec, and UI CLI bindings"
publish = false

[dependencies]
byteport-transport = { path = "../byteport-transport" }
clap = { version = "4", features = ["derive"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }
anyhow = "1"
thiserror = "2"
