@echo off
cd /d "E:\lanes\AgilePlus-verify"
echo === HEAD ===
git rev-parse HEAD
git log -1 --format='%%H %%ai %%s' HEAD
echo.
echo === Total commits ===
git rev-list --count HEAD
echo.
echo === Earliest 5 ===
git log --all --reverse --format='%%H %%ai %%s' | more +1 | head -5
echo.
echo === Latest 10 ===
git log --all --format='%%H %%ai %%s' | head -10
