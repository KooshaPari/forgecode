[package]
name = "authkit"
version = "0.1.0"
edition = "2021"
description = "AuthKit: canonical Rust auth boundary. OAuth2/OIDC/JWT/RBAC/ABAC/PKCE. Successor to the archived Authvault repo; absorbs FR-AUTHV-018 (PKCE state session binding)."
license = "MIT OR Apache-2.0"
repository = "https://github.com/KooshaPari/AuthKit"
rust-version = "1.75"

[dependencies]
chrono = { version = "0.4", features = ["serde"] }
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
thiserror = "2.0"
axum = "0.7"
tower = "0.5"
tokio = { version = "1.0", features = ["full"] }
jsonwebtoken = { version = "9", optional = true }

[features]
default = []
oidc = ["dep:reqwest", "dep:url"]
jwt = ["dep:jsonwebtoken"]
webauthn = ["dep:sha2", "dep:base64", "dep:serde_json", "dep:thiserror", "dep:getrandom", "dep:chrono"]

[dev-dependencies]
tower = { version = "0.5", features = ["util"] }
tokio = { version = "1.0", features = ["macros", "rt", "time"] }

[dependencies.sha2]
version = "0.10"
optional = true

[dependencies.base64]
version = "0.22"
optional = true

[dependencies.getrandom]
version = "0.2"
optional = true

[dependencies.reqwest]
version = "0.12"
optional = true
default-features = false
features = ["rustls-tls", "json"]

[dependencies.url]
version = "2"
optional = true
