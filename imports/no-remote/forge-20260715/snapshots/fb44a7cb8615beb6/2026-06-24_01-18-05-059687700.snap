$skip = @('\node_modules\','\.git\','\.venv\','\.tox\','\__pycache__\','\target\','\build\','\dist\','\vendor\')

$results = New-Object System.Collections.Generic.List[object]
$seen = @{}

function Walk($dir, $depth) {
  if ($depth -le 0) { return }
  if ($seen[$dir]) { return }
  $seen[$dir] = $true
  foreach ($s in $skip) { if ($dir -like "*$s*") { return } }
  $items = Get-ChildItem -LiteralPath $dir -Force -ErrorAction SilentlyContinue
  foreach ($it in $items) {
    if ($it.PSIsContainer) {
      Walk -dir $it.FullName -depth ($depth - 1)
    } else {
      $ext = $it.Extension.ToLowerInvariant()
      if ($exts[$ext]) {
        try {
          $lineNo = 0
          $reader = [System.IO.StreamReader]::new($it.FullName)
          while ($null -ne ($line = $reader.ReadLine())) {
            $lineNo++
            if ($line.ToLower().Contains('nippon')) {
              $results.Add([pscustomobject]@{
                Path = $it.FullName
                Line = $lineNo
                Text = $line.Trim()
              })
              if ($results.Count -ge 500) { $reader.Close(); return }
            }
          }
          $reader.Close()
        } catch {}
      }
    }
  }
}

foreach ($c in $candidates) {
  if (Test-Path -LiteralPath $c) {
    Walk -dir $c -depth $maxDepth
  }
}

# Also scan root-level *.md, *.txt, *.json, *.toml, *.yaml, *.yml files at C:\Users\koosh
$rootFiles = Get-ChildItem -LiteralPath 'C:\Users\koosh' -File -Force -ErrorAction SilentlyContinue | Where-Object {
  $exts[$_.Extension.ToLowerInvariant()]
}
foreach ($f in $rootFiles) {
  try {
    $lineNo = 0
    $reader = [System.IO.StreamReader]::new($f.FullName)
    while ($null -ne ($line = $reader.ReadLine())) {
      $lineNo++
      if ($line.ToLower().Contains('nippon')) {
        $results.Add([pscustomobject]@{
          Path = $f.FullName
          Line = $lineNo
          Text = $line.Trim()
        })
      }
    }
    $reader.Close()
  } catch {}
}

# Group results by file
$grouped = $results | Group-Object Path | Sort-Object Name
"=== FILES WITH HITS: $($grouped.Count) ==="
$grouped | ForEach-Object {
  $file = $_.Name
  $count = $_.Count
  Write-Host ""
  Write-Host "FILE: $file ($count hit(s))"
  $_.Group | Select-Object -First 5 | ForEach-Object {
    Write-Host ("  L{0}: {1}" -f $_.Line, $_.Text)
  }
}
"=== TOTAL MATCH LINES: $($results.Count) ==="