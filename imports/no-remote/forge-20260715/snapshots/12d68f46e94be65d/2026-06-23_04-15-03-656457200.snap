#!/usr/bin/env python3
"""List KooshaPari repos matching compute/infra/obs patterns."""
import json
import os
import subprocess

env = os.environ.copy()
# Load token from .env
try:
    with open(r"C:\Users\koosh\.env", "r", encoding="utf-8") as f:
        for line in f:
            if line.startswith("GITHUB_TOKEN="):
                env["GH_TOKEN"] = line.split("=", 1)[1].strip()
                env["GITHUB_TOKEN"] = env["GH_TOKEN"]
                break
except Exception as e:
    print(f"env load err: {e}", flush=True)

patterns = [
    "nano", "byteport", "compose", "pheno", "infra", "observ",
    "kit", "spine", "registry", "kits", "specs", "otel", "forge",
    "sdk", "dag", "journey", "harness", "absorb",
    "mcp", "cli", "agent", "phenokits", "phenoproc", "phenorouter",
    "phenodocs", "phenofastmcp", "phenodag", "phenohub",
    "phenoforge", "phenoshared", "phenocli", "phenospecs",
    "phenomcp", "phenoflow", "phenobyte",
]

all_repos = []
for page in range(1, 6):
    try:
        r = subprocess.run(
            ["gh", "api", f"user/repos?per_page=100&page={page}&sort=updated"],
            capture_output=True, env=env, timeout=60, encoding="utf-8",
        )
        print(f"page {page} rc={r.returncode} stdout_len={len(r.stdout)} stderr={r.stderr[:300] if r.stderr else ''}", flush=True)
        print(f"  STDOUT preview: {r.stdout[:500]}", flush=True)
        if r.returncode != 0 or not r.stdout.strip():
            break
        try:
            page_data = json.loads(r.stdout)
        except Exception as e:
            print(f"  JSON err: {e}", flush=True)
            break
        if not page_data:
            break
        all_repos.extend(page_data)
        print(f"  loaded {len(page_data)} repos", flush=True)
    except Exception as e:
        print(f"err: {e}", flush=True)
        break

print(f"\ntotal repos: {len(all_repos)}", flush=True)

seen = set()
matching = []
for r in all_repos:
    name = r.get("name", "")
    name_l = name.lower()
    if name in seen:
        continue
    for p in patterns:
        if p in name_l:
            matching.append(r)
            seen.add(name)
            break

print(f"\n=== {len(matching)} MATCHING REPOS ===\n", flush=True)
for r in sorted(matching, key=lambda x: x.get("name", "").lower()):
    fork = "F" if r.get("fork") else " "
    arch = "A" if r.get("archived") else " "
    priv = "P" if r.get("private") else " "
    print(f"[{fork}{arch}{priv}] {r.get('full_name'):55s} | {(r.get('description') or '')[:75]}", flush=True)

# Save for later
with open(r"C:\Users\koosh\_all_repos.json", "w", encoding="utf-8") as f:
    json.dump(all_repos, f, indent=2)
with open(r"C:\Users\koosh\_all_repos_match.json", "w", encoding="utf-8") as f:
    json.dump(matching, f, indent=2)
print(f"\nsaved _all_repos.json + _all_repos_match.json", flush=True)
