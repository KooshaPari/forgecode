[package]
name = "phenotype-event-bus"
version.workspace = true
edition.workspace = true
license.workspace = true
repository.workspace = true
description = "Event bus abstractions for the Phenotype ecosystem"

[lib]
path = "src/lib.rs"

[dependencies]
thiserror = { workspace = true }
serde = { workspace = true }
serde_json = { workspace = true }
async-trait = { workspace = true }
tokio = { workspace = true, features = ["sync", "time", "rt", "macros"] }
ulid = { workspace = true }
dashmap = { workspace = true }
phenotype-error-core = { workspace = true }
chrono = { workspace = true }
tracing = { workspace = true }

[features]
default = []
# Postgres-backed OutboxStore (EVE-SOTA-002). Adds sqlx + tokio-postgres.
postgres = ["dep:sqlx"]
# SQLite-backed OutboxStore (EVE-SOTA-004). Adds sqlx (sqlite feature)
# for embedded/dev/test usage. Mirrors the Postgres adapter contract
# (OutboxStore trait impl + transactional helper + MIGRATION_SQL).
sqlite = ["dep:sqlx"]

[dependencies.sqlx]
version = "0.8"
default-features = false
features = ["runtime-tokio-rustls", "macros", "chrono", "json", "postgres", "sqlite", "uuid"]
optional = true

[dependencies.futures]
version = "0.3"
default-features = false
features = ["std"]

[dev-dependencies]
tokio = { workspace = true, features = ["full"] }
futures = { workspace = true }
