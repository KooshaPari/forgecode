"""
DAG unit generator for owned scope:
  eyetracker, eventra, configra, benchora, authvault, quillr

Outputs:
  - C:/Users/koosh/_owned_dag.json   (machine-readable)
  - C:/Users/koosh/_owned_dag.md     (human-readable summary)

Per-repo DAG unit categories (~30 units each, no shrinking):
  REGISTRY  : registry SSOT sync (project entry, role mapping, docs/intent, docs/boundary, AGENTS, ADR)
  AUDIT     : 71+ grade pass + remediation + grade-reports artifact
  GIT       : git hygiene (stash reconcile, branch prune, push wip, worktree cleanup, dirty clean)
  CI        : L5-104.9 standard workflow set (ci/deny/sbom/trufflehog) + workflow sweep
  SPEC      : AgilePlus specify work-unit for non-trivial work (one per repo)
  SOTA      : SOTA feature work units (5-10 per repo, domain-specific)
  PERF      : performance hardening (2-4 per repo)
  SECURITY  : threat-model + secret-scan hardening
  DOCS      : README/SPEC/llms polish + boundary doc + intent doc + slsa
  XREPO     : cross-repo overlap / re-pointer / absorption-note

Spine-level (~30):
  REG        : registry SSOT maintain (tools/check-ecosystom drift, validate-ecosystem.sh)
  AUDIT      : fleet-grade sweep
  DAG        : ECOSYSTEM_DAG lane updates, SESSION_ARTIFACT_PROTOCOL compliance
  STDLIB     : phenokits-commons updates (CI templates, governance workflows)
  AGILEPLUS  : agileplus spec templates / work-unit protocol enhancements
"""

import json, os
