    WU("XRP-003", "phenotype-registry", "planned", "re-point matrix: Authvault AuditSink → Eventra event-store + Quillr forwarder", cat="XREPO", est="L"),
    WU("XRP-004", "phenotype-registry", "planned", "re-point matrix: Configra VaultStore secrets → Authvault KMS adapters", cat="XREPO", est="L"),
    WU("XRP-005", "phenotype-registry", "planned", "re-point matrix: Configra remote sync → Quillr fetcher", cat="XREPO", est="L"),
    WU("XRP-006", "phenotype-registry", "planned", "re-point matrix: Benchora baselines for all 5 owned repos (Eyetracker ≤30ms / Eventra projection / Authvault JWT / Configra hot-reload / Quillr CB)", cat="XREPO", est="L"),
