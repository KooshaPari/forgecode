]

# Standard work-unit protocol fields
def WU(uid, repo, lane, title, deps=None, est="M", cat="SOTA", notes="", spec_id=None):
    return {
        "id": uid,
        "repo": repo,
        "lane": lane,         # planned | in_progress | done | nb
        "category": cat,      # REGISTRY | AUDIT | GIT | CI | SPEC | SOTA | PERF | SECURITY | DOCS | XREPO | SPINE
        "title": title,
        "deps": deps or [],
        "est": est,           # S | M | L | XL
        "spec_id": spec_id,
        "notes": notes,
    }

dag = []

