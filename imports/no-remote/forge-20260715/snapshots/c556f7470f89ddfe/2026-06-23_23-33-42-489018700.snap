out_json = r"C:\Users\koosh\_owned_dag.json"
with open(out_json, "w") as f:
    json.dump({
        "version": "1.0.0",
        "generated": datetime.utcnow().isoformat() + "Z",
        "scope": [o["key"] for o in OWNED],
        "unit_count": len(dag),
        "categories": sorted(set(d["category"] for d in dag)),
        "per_repo_counts": {o["key"]: sum(1 for d in dag if d["repo"]==o["key"]) for o in OWNED},
        "units": dag,
    }, f, indent=2)

# Markdown summary
def fmt_md():
    lines = []
    lines.append("# Owned-Repo Multi-Hundred DAG — v1.0.0")
    lines.append("")
    lines.append(f"**Scope:** {', '.join(o['key'] for o in OWNED)}")
    lines.append(f"**Generated:** {datetime.utcnow().isoformat()}Z")
    lines.append(f"**Total units:** {len(dag)}")
    lines.append("")
    lines.append("## Per-Repo Counts")
    lines.append("")
    lines.append("| Repo | Units |")
    lines.append("|---|---|")
    counts = {o["key"]: sum(1 for d in dag if d["repo"]==o["key"]) for o in OWNED}
    for k, v in counts.items():
        lines.append(f"| {k} | {v} |")
    lines.append(f"| spine | {sum(1 for d in dag if d['repo']=='phenotype-registry' or d['repo']=='agileplus' or d['repo']=='phenokits-commons')} |")
    lines.append(f"| xrepo | {sum(1 for d in dag if d['category']=='XREPO' and d['repo']=='phenotype-registry')} |")
    lines.append("")
    lines.append("## Categories")
    lines.append("")
    cats = {}
    for d in dag:
        cats.setdefault(d["category"], 0)
        cats[d["category"]] += 1
    for c, n in sorted(cats.items()):
        lines.append(f"- **{c}**: {n}")
    lines.append("")
    lines.append("## Unit Protocol")
    lines.append("")
    lines.append("Each unit has:")
    lines.append("- `id` — unique work-unit ID")
    lines.append("- `repo` — target repo (or spine)")
    lines.append("- `lane` — `planned | in_progress | done | nb`")
    lines.append("- `category` — REGISTRY | AUDIT | GIT | CI | SPEC | SOTA | PERF | SECURITY | DOCS | XREPO | SPINE")
    lines.append("- `title` — work-unit title")
    lines.append("- `deps` — list of upstream unit IDs")
    lines.append("- `est` — size estimate (S/M/L/XL)")
    lines.append("- `spec_id` — AgilePlus spec ID (if non-trivial)")
    lines.append("- `notes` — context / rationale")
    lines.append("")
    lines.append("## Top Dependencies (chain roots)")
    lines.append("")
    lines.append("- **AUDIT** chains → pre-req for any other category")
    lines.append("- **GIT** chains → pre-req for CI/REGISTRY")
    lines.append("- **CI** chains → pre-req for SOTA merging")
    lines.append("- **REGISTRY** entries → enable XREPO cross-pointing")
    lines.append("- **SPEC** units → gate large SOTA/PERF work")
    lines.append("")
    lines.append("## Validation Strategy (Auditor/Validator Loop)")
    lines.append("")
    lines.append("- Weekly `grade.sh --fast` on all owned → results in `.grade-reports/`")
    lines.append("- CI red on any owned → auto-add new DAG unit (`SPN-AUDIT-001`)")
    lines.append("- Stale remote branch detection → auto-add prune unit (`*-GIT-*`)")
    lines.append("- SOTA gap drift detected via search → auto-add gap unit (`*-SOTA-*`)")
    lines.append("- Open PR age > 7d → auto-add merge-or-close unit (`*-AUD-*`)")
    lines.append("")
    lines.append("Full machine-readable: `C:\\Users\\_owned_dag.json`")
    return "\n".join(lines)

out_md = r"C:\Users\koosh\_owned_dag.md"
with open(out_md, "w") as f:
    f.write(fmt_md())

print(f"WROTE {out_json} ({len(dag)} units)")
print(f"WROTE {out_md}")
print()
print("Per-repo counts:")
counts = {o["key"]: sum(1 for d in dag if d["repo"]==o["key"]) for o in OWNED}
for k, v in counts.items():
    print(f"  {k}: {v}")
print(f"  spine: {sum(1 for d in dag if d['repo']=='phenotype-registry' or d['repo']=='agileplus' or d['repo']=='phenokits-commons')}")
print(f"  xrepo: {sum(1 for d in dag if d['category']=='XREPO' and d['repo']=='phenotype-registry')}")
print(f"  TOTAL: {len(dag)}")