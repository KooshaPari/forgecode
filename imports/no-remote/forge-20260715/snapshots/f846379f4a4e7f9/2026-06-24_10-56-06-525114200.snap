@import "tailwindcss";
@import "./tokens.css";

/* impeccable CSS baseline — github.com/pbakaus/impeccable */
*, *::before, *::after { box-sizing: border-box; }
html {
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  color-scheme: dark;
}
img, video { max-width: 100%; height: auto; }
input, button, textarea, select { font: inherit; }
p, h1, h2, h3, h4, h5, h6 { overflow-wrap: break-word; }

/* =============================================================================
 * Phenotype design system — token-driven base styles
 * Tokens are defined in tokens.css (midnight bg, teal primary, Montserrat +
 * Bricolage Grotesque + JetBrains Mono). All fg/bg pairs target WCAG 2.1 AA.
 * =========================================================================== */

html, body {
  background: var(--bg);
  color: var(--fg);
  font-family: var(--font-sans);
}

body {
  margin: 0;
  min-width: 320px;
  min-height: 100vh;
}

h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-heading);
  font-weight: 700;
  letter-spacing: -0.01em;
  color: var(--fg);
}

/* Display heading utility — Bricolage Grotesque for hero/landing titles */
.display {
  font-family: var(--font-display);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.05;
}

::selection {
::selection {
  background: var(--primary);
  color: var(--on-primary);
}
:focus-visible {
  outline: 2px solid var(--primary);
  outline-offset: 3px;
  border-radius: 4px;
}

/* =============================================================================
 * Phenotype design system — minimal component class hooks
 * =========================================================================== */

.surface          { background: var(--surface); }
.surface-strong   { background: var(--surface-strong); }
.surface-card     { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); }

.text-fg          { color: var(--fg); }
.text-muted       { color: var(--muted); }
.text-dim         { color: var(--dim); }
.text-primary     { color: var(--primary); }
.text-on-primary  { color: var(--on-primary); }

.bg-app           { background: var(--bg); }
.bg-primary       { background: var(--primary); color: var(--on-primary); }
.bg-primary-soft  { background: var(--primary-soft); color: var(--primary); }

.border-app       { border-color: var(--border); }
.border-strong    { border-color: var(--border-strong); }
.border-primary   { border-color: var(--primary); }

.divider          { border-top: 1px solid var(--border); }

.mono             { font-family: var(--font-mono); }

.ring-primary     { box-shadow: 0 0 0 1px var(--primary); }

/* Status pills */
.badge-ok   { background: color-mix(in srgb, var(--ok) 15%, transparent);   color: var(--ok); }
.badge-warn { background: color-mix(in srgb, var(--warn) 15%, transparent); color: var(--warn); }
.badge-bad  { background: color-mix(in srgb, var(--bad) 15%, transparent);  color: var(--bad); }

/* Button: primary CTA */
.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--primary);
  color: var(--on-primary);
  padding: 0.75rem 1.25rem;
  border-radius: var(--radius-md);
  font-weight: 600;
  text-decoration: none;
  border: 1px solid transparent;
  transition: background var(--duration-fast) var(--ease-out),
              transform var(--duration-fast) var(--ease-out);
}
.btn-primary:hover  { background: var(--primary-strong); }
.btn-primary:active { transform: translateY(1px); }

/* Button: secondary / ghost */
.btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: transparent;
  color: var(--fg);
  padding: 0.75rem 1.25rem;
  border-radius: var(--radius-md);
  font-weight: 600;
  text-decoration: none;
  border: 1px solid var(--border-strong);
  transition: border-color var(--duration-fast) var(--ease-out),
              color var(--duration-fast) var(--ease-out);
}
.btn-secondary:hover { border-color: var(--primary); color: var(--primary); }

/* Responsive shell */
.site-shell {
  width: min(100% - (var(--container-inline) * 2), var(--container-max));
  margin-inline: auto;
  padding-inline: var(--container-inline);
}

/* Standard breakpoints: 640px, 768px, 1024px */
@media (min-width: 640px) {
  :root {
    --container-inline: 1.25rem;
    --section-gap: 3rem;
    --container-max: 640px;
  }
}

@media (min-width: 768px) {
  :root {
    --container-inline: 1.5rem;
    --section-gap: 4rem;
    --container-max: 768px;
  }
}

@media (min-width: 1024px) {
  :root {
    --container-inline: 2rem;
    --section-gap: 5rem;
    --container-max: 1024px;
  }
}

.mono { font-family: var(--font-mono); }

.responsive-actions {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

@media (min-width: 640px) {
  .responsive-actions {
    flex-direction: row;
    flex-wrap: wrap;
  }
}

.responsive-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}

@media (min-width: 768px) {
  .responsive-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (min-width: 1024px) {
  .responsive-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

.readme-prose {
  max-width: min(100%, 72ch);
}

/* Honor reduced-motion preference. */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}
