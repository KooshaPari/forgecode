apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ include "phase-finish-stack.fullname" . }}-data
  labels:
    app.kubernetes.io/part-of: phase-finish-stack
spec:
spec:
  accessModes:
    - {{ .Values.persistence.accessModes | default "ReadWriteOnce" | quote }}
  resources:
    requests:
      storage: {{ .Values.persistence.size | default "10Gi" }}
  {{- if .Values.persistence.storageClass }}
  storageClassName: {{ .Values.persistence.storageClass | quote }}
  {{- end }}
    requests:
      storage: {{ .Values.persistence.data.size | default "50Gi" }}
