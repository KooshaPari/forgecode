#!/usr/bin/env python3
"""Registry accuracy sweep — diff GitHub repo list vs ECOSYSTEM_MAP.md"""
import json, re, sys

with open(r"C:\Users\koosh\AppData\Local\Temp\ko_all.json", "r", encoding="utf-8") as f:
    all_repos = json.load(f)

gh_names = {r["name"] for r in all_repos}
print(f"Total KooshaPari repos: {len(gh_names)}", file=sys.stderr)

with open(r"C:\Users\koosh\infra-research\phenotype-registry\ECOSYSTEM_MAP.md", "r", encoding="utf-8") as f:
    eco = f.read()

# Extract repo names mentioned in the ecosystem map (capitalized, no punctuation)
# Look for `KooshaPari/<name>` and bare names in tables
mentioned = set()

# Direct KooshaPari/<name> links
for m in re.finditer(r"KooshaPari/([A-Za-z0-9._\-]+)", eco):
    mentioned.add(m.group(1))

# Names in markdown tables that look like repo names
for m in re.finditer(r"\*\*([A-Z][A-Za-z0-9._\-]+)\*\*", eco):
    name = m.group(1)
    if name in gh_names:
        mentioned.add(name)

