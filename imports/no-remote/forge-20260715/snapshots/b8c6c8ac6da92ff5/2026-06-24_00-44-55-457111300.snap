"""Append validator A+B+C results into the canonical DAG."""
import json, re, datetime

DAG = r"C:/Users/koosh/_owned_dag.json"
with open(DAG) as f: dag = json.load(f)
existing = {u["id"] for u in dag["units"]}

def parse_unit(line):
    s = line.strip().lstrip("-").strip().strip("`").strip()
    m = re.match(
        r'^ID:\s*([A-Za-z0-9_.\-]+)\s*\|\s*title:\s*(.+?)\s*\|\s*est:\s*(\S+)\s*\|\s*category:\s*([A-Za-z_]+)\s*(?:\|\s*deps:\s*\[([^\]]*)\])?',
        s
    )
    if not m: return None
    uid, title, est, cat, deps = m.groups()
    deps_list = [d.strip() for d in (deps or "").split(",") if d.strip()]
    return {"id": uid, "title": title.strip(), "est": est, "category": cat.strip(),
            "deps": deps_list, "lane": "planned", "repo": "triage", "spec_id": None,
            "notes": "validator-extended"}

def repo_for(uid):
    if uid.startswith("EYE") or uid.startswith("SOTA-eye") or uid.startswith("REG-COHERENCE-eyetracker"): return "eyetracker"
    if uid.startswith("EVE") or uid.startswith("SOTA-eventra") or uid.startswith("REG-COHERENCE-eventra"): return "eventra"
    if uid.startswith("CFG") or uid.startswith("SOTA-configra") or uid.startswith("REG-COHERENCE-configra"): return "configra"
    if uid.startswith("BEN") or uid.startswith("SOTA-benchora") or uid.startswith("REG-COHERENCE-benchora"): return "benchora"
    if uid.startswith("AVL") or uid.startswith("SOTA-authvault") or uid.startswith("REG-COHERENCE-authvault"): return "authvault"
    if uid.startswith("QLR") or uid.startswith("SOTA-quillr") or uid.startswith("REG-COHERENCE-quillr"): return "quillr"
    if uid.startswith("REG-COHERENCE") or uid.startswith("SPN"): return "phenotype-registry"
    return "triage"

