"""
Append validator A+B+C results to DAG. Convert proposal lines into structured units.
"""

import json, re, datetime

DAG = r"C:/Users/koosh/_owned_dag.json"

with open(DAG) as f: dag = json.load(f)
existing = {u["id"] for u in dag["units"]}

def parse_unit(line):
def parse_unit(line):
    """Parse: ID: X | title: Y | est: Z | category: C | deps: [..]"""
    # Strip leading "- `" and trailing "`"
    s = line.strip().lstrip("-").strip().strip("`").strip()
    m = re.match(
        r'^ID:\s*([A-Za-z0-9_.\-]+)\s*\|\s*title:\s*(.+?)\s*\|\s*est:\s*(\S+)\s*\|\s*category:\s*([A-Za-z_]+)\s*(?:\|\s*deps:\s*\[([^\]]*)\])?',
        s
    )
    uid, title, est, cat, deps = m.groups()
    deps = [d.strip() for d in (deps or "").split(",") if d.strip()]
    return {"id": uid, "title": title.strip(), "est": est, "category": cat.strip(),
            "deps": deps, "lane": "planned", "repo": "triage", "spec_id": None,
            "notes": "validator-extended"}

