# Map repo from id prefix
def repo_for(uid):
    if uid.startswith("EYE") or uid.startswith("SOTA-eye") or uid.startswith("REG-COHERENCE-eyetracker"): return "eyetracker"
    if uid.startswith("EVE") or uid.startswith("SOTA-eventra") or uid.startswith("REG-COHERENCE-eventra"): return "eventra"
    if uid.startswith("CFG") or uid.startswith("SOTA-configra") or uid.startswith("REG-COHERENCE-configra"): return "configra"
    if uid.startswith("BEN") or uid.startswith("SOTA-benchora") or uid.startswith("REG-COHERENCE-benchora"): return "benchora"
    if uid.startswith("AVL") or uid.startswith("SOTA-authvault") or uid.startswith("REG-COHERENCE-authvault"): return "authvault"
    if uid.startswith("QLR") or uid.startswith("SOTA-quillr") or uid.startswith("REG-COHERENCE-quillr"): return "quillr"
    if uid.startswith("REG-COHERENCE") or uid.startswith("SPN"): return "phenotype-registry"
    return "triage"

added = 0
for line in (A + "\n" + B + "\n" + C).splitlines():
    u = parse_unit(line)
    if not u: continue
    if u["id"] in existing: continue
    u["repo"] = repo_for(u["id"])
    dag["units"].append(u)
    existing.add(u["id"])
    added += 1

dag["unit_count"] = len(dag["units"])
dag["version"] = "1.2.0"
dag["generated"] = datetime.datetime.utcnow().isoformat() + "Z"
dag["extension_history"] = dag.get("extension_history", []) + [{
    "merged_at": datetime.datetime.utcnow().isoformat() + "Z",
    "source": "validator-A+B+C",
    "added": added,
}]

with open(DAG, "w", encoding="utf-8") as f:
    json.dump(dag, f, indent=2)

print(f"MERGED {added} new units from validators A+B+C")
print(f"New DAG total: {dag['unit_count']}")
print(f"Categories:")
from collections import Counter
for c, n in sorted(Counter(u["category"] for u in dag["units"]).items()):
    print(f"  {c}: {n}")
print()
print("Per-repo final counts:")
for r in sorted({u["repo"] for u in dag["units"]}):
    n = sum(1 for u in dag["units"] if u["repo"]==r)
    print(f"  {r}: {n}")