[workspace]
resolver = "2"
members = [
    ".",
    "rust/phenotype-event-contracts",
    "rust/phenotype-event-bus",
    "rust/phenotype-event-sourcing",
    "rust/phenotype-error-core",
]

[workspace.package]
version = "0.1.0"
edition = "2021"
license = "MIT OR Apache-2.0"
repository = "https://github.com/KooshaPari/Eventra"
rust-version = "1.75"

[workspace.dependencies]
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
derive_more = { version = "1.0", features = ["from", "display"] }
thiserror = "2.0"
anyhow = "1.0"
async-trait = "0.1"
chrono = { version = "0.4", features = ["serde"] }
uuid = { version = "1.0", features = ["v4", "serde"] }
tokio = { version = "1.0", features = ["full"] }
ulid = { version = "1", features = ["serde"] }
dashmap = "6"
sha2 = "0.10"
hex = "0.4"
# The upstream `KooshaPari/phenotype-types` repo is no longer accessible (HTTP 404),
# so `phenotype-error-core` is now vendored as a workspace member. See
# `rust/phenotype-error-core/src/lib.rs` for the root-cause note and CI evidence.
phenotype-error-core = { path = "rust/phenotype-error-core" }
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter", "fmt"] }

[package]
name = "eventkit"
version.workspace = true
edition.workspace = true
description = "Event-driven architecture framework with CQRS and Event Sourcing"
license.workspace = true
repository.workspace = true
documentation = "https://docs.rs/eventkit"
keywords = ["phenotype", "pheno-proc"]
categories = ["development-tools"]
authors = ["kooshapari"]
rust-version.workspace = true

[dependencies]
serde = { workspace = true }
serde_json = { workspace = true }
derive_more = { workspace = true }
thiserror = { workspace = true }
anyhow = { workspace = true }
async-trait = { workspace = true }
parking_lot = "0.12"
chrono = { workspace = true }
uuid = { workspace = true }
tracing = { workspace = true }
tracing-subscriber = { workspace = true }

[dev-dependencies]
tokio = { workspace = true }
