#!/usr/bin/env python
"""Fetch public GitHub repo metadata for the 4 candidates."""
import json
import urllib.request

REPOS = [
    ("KooshaPari/thegent", "thegent"),
    ("KooshaPari/eyetracker", "eyetracker"),
    ("KooshaPari/phenotype-sdk", "phenotype-sdk"),
    ("KooshaPari/pheno-specs", "pheno-specs"),
]

def fetch(path):
    url = f"https://api.github.com/repos/{path}"
    req = urllib.request.Request(url, headers={"User-Agent": "forge-audit"})
    with urllib.request.urlopen(req, timeout=20) as r:
        return json.loads(r.read().decode())

results = {}
for path, key in REPOS:
    try:
        d = fetch(path)
        results[key] = {
            "path": path,
            "name": d.get("name"),
            "description": d.get("description") or "",
            "default_branch": d.get("default_branch"),
            "pushed_at": d.get("pushed_at"),
            "archived": d.get("archived"),
            "disabled": d.get("disabled"),
            "size_kb": d.get("size"),
            "stars": d.get("stargazers_count"),
            "forks": d.get("forks_count"),
            "open_issues": d.get("open_issues_count"),
            "license": (d.get("license") or {}).get("spdx_id"),
            "language": d.get("language"),
            "topics": d.get("topics", []),
            "created_at": d.get("created_at"),
        }
    except Exception as e:
        results[key] = {"path": path, "error": str(e)}

with open("_github_meta.json", "w") as f:
    json.dump(results, f, indent=2)

for k, v in results.items():
    if "error" in v:
        print(f"  {k:18s} ERROR: {v['error']}")
    else:
        print(f"  {k:18s} default={v['default_branch']:8s} size={v['size_kb']:>6d}KB pushed={v['pushed_at']} language={v.get('language')}")
