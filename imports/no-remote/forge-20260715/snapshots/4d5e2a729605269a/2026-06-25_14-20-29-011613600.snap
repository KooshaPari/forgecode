[package]
name = "byteport-dag"
version = "0.1.0"
edition = "2021"
license = "Apache-2.0"
description = "DAG foundation: topological sort, parallel-bucket scheduler, and status/event reporting for Phenotype compute/infra"
publish = false

[dependencies]
serde = { version = "1", features = ["derive"] }
serde_json = "1"
serde_yaml = "0.9"
thiserror = "2.0"
uuid = { version = "1", features = ["v4"] }
chrono = { version = "0.4", features = ["serde"] }
