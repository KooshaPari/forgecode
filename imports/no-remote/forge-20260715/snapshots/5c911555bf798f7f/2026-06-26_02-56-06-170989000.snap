$buildDir = 'C:\Users\koosh\.claude\lanes\substrate-feat-cloud-dispatch'
$outputFile = Join-Path $buildDir 'build_output.txt'

# Clean lock files
Remove-Item -Force 'E:\Dev\.cargo\.package-cache' -ErrorAction SilentlyContinue
Remove-Item -Force 'E:\Dev\.cargo\.package-cache-mutate' -ErrorAction SilentlyContinue

$job = Start-Job -Name 'CargoCheck' -ScriptBlock {
    param($dir, $outFile)
    Set-Location $dir
    $env:CARGO_HOME = 'E:\Dev\.cargo'
    $env:CARGO_TARGET_DIR = 'E:\civis-target'
    $output = cargo check -p substrate-core -p cloud-cursor -p cloud-kilo -p cloud-codex -p cloud-dispatch-conformance -p driver-cli 2>&1
    $output | Out-File $outFile -Encoding utf8
    "EXIT_CODE=$LASTEXITCODE" | Out-File $outFile -Encoding utf8 -Append
} -ArgumentList @($buildDir, $outputFile)

Write-Host "Job ID: $($job.Id)"
Write-Host "Job State: $($job.State)"
