import os
clean = r'C:\Users\koosh\OmniRoute-clean\open-sse\executors\codex.ts'
fresh = r'C:\Users\koosh\OmniRoute-fresh2\open-sse\executors\codex.ts'

for name, path in [('CLEAN', clean), ('FRESH2', fresh)]:
    with open(path, 'r', encoding='utf8', errors='replace') as fh:
        c = fh.read()
    print(f'\n== {name} local_shell conditional checks ==')
    idx = 0
    while True:
        idx = c.find('local_shell', idx)
        if idx < 0: break
        start = max(0, idx - 500)
        snippet = c[start:idx+100]
        tokens = []
        for tok in ['return', 'throw', 'reject', '400', 'no longer supported', 'remove', 'strip', 'drop', 'local_shell', 'hosted']:
            cnt = snippet.count(tok)
            if cnt: tokens.append(f'{tok}={cnt}')
        print(f'  idx={idx} context_tokens={tokens}')
        idx += 1