interface RawProvider {
  providerId: ProviderId;
  label: string;
  kind: ProviderKind;
  notes: string | undefined;
  status: ProviderStatus;
  /** The env var name that resolved (for user feedback). null if none. */
  sourceEnvVar: string | null;
  /** Length of the secret (we never echo the secret itself). null if not set. */
  secretLength: number | null;
  /** Optional: how long ago the env was set (epoch ms). null if unknown. */
  detectedAt: number;
}

function probeProvider(desc: ProviderDescriptor): RawProvider {
  // First non-empty env var wins. We treat empty string the same as unset.
  let resolved: string | null = null;
  let sourceEnvVar: string | null = null;
  for (const name of desc.envVars) {
    const v = Bun.env[name];
    if (typeof v === "string" && v.length > 0) {
      resolved = v;
      sourceEnvVar = name;
      break;
    }
  }

  let status: ProviderStatus;
  if (resolved == null) {
    status = "not-configured";
  } else {
    status = "configured";
  }

  return {
    providerId: desc.providerId,
    label: desc.label,
    kind: desc.kind,
    notes: desc.notes ?? undefined,
    status,
    sourceEnvVar,
    secretLength: resolved == null ? null : resolved.length,
    detectedAt: Date.now(),
  };
}

/** Cache for the 5-min dashboard render window. */
let cached: { report: ProviderReport; ts: number } | null = null;
const CACHE_MS = 5 * 60 * 1000;

export async function runDiscovery(opts?: { force?: boolean }): Promise<ProviderReport> {
  const now = Date.now();
  if (!opts?.force && cached && now - cached.ts < CACHE_MS) {
    return cached.report;
  }

  const providers = PROVIDER_CATALOG.map(probeProvider);
  const configured = providers.filter((p) => p.status === "configured");

  const report: ProviderReport = {
    generatedAt: now,
    totalCatalog: providers.length,
    configured: configured.length,
    notConfigured: providers.length - configured.length,
    byKind: {
      "web-cookie": providers.filter((p) => p.kind === "web-cookie" && p.status === "configured").length,
      "api-key": providers.filter((p) => p.kind === "api-key" && p.status === "configured").length,
      "oauth-device-code": providers.filter((p) => p.kind === "oauth-device-code" && p.status === "configured").length,
      "local-runtime": providers.filter((p) => p.kind === "local-runtime" && p.status === "configured").length,
    },
    providers,
  };

  cached = { report, ts: now };
  return report;
}