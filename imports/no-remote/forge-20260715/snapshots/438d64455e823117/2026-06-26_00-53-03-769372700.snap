// src/discovery/providers.ts — provider discovery for 16+ LLM access surfaces.
//
// Reads free-form env vars at runtime (no provider secrets baked in) and emits a
// normalized ProviderReport. Backed by WebCookies/email-password sources
// documented in docs/research/UNLIMITED_LLM_ACCESS.md.
//
// Each provider gets:
//   - a free-form `cookieEnv` or `apiKeyEnv` the user populates locally
//   - a stable `providerId` (matches @maximhq/bifrost IDs where available)
//   - `kind`: web-cookie | api-key | oauth-device-code | local-runtime
//   - `status`: detected | configured | not-configured
//
// This is the *replacement* for the ad-hoc "use `Bun.env.X`" scattered across
// the old Next.js codebase. It centralizes config probing in one place so the
// UI / CLI can render a single dashboard.

import type { ProviderId, ProviderReport, ProviderStatus, ProviderKind } from "./types";

interface ProviderDescriptor {
  /** Stable id; matches bifrost provider id where supported. */
  providerId: ProviderId;
  /** Display label. */
  label: string;
  /** Free-form env var names to probe (first non-empty wins). */
  envVars: string[];
  /** Discovery kind. */
  kind: ProviderKind;
  /** Optional: a longer blurb shown in the discovery UI. */
  notes: string | undefined;
}
// 16+ surfaces from UNLIMITED_LLM_ACCESS.md. Some are api-key, some web-cookie,
// some oauth-device-code, some local-runtime.
