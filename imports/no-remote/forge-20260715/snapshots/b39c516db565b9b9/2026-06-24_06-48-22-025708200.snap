	directory = C:/Users/koosh/migration-work/phenoUtils
	directory = C:/Users/koosh/.cursor/audit-tmp/phenotype-python-sdk
	directory = C:/Users/koosh/migration-work/PhenoLang
	directory = C:/Users/koosh/migration-work/HexaKit
	directory = C:/Users/koosh/migration-work/phenotype-registry
