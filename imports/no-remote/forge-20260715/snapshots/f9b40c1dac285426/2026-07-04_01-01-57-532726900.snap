name: Signed Release

on:
  release:
    types: [published]
  workflow_dispatch:
    inputs:
      tag:
        description: 'Tag to sign (e.g. v0.0.1). Required for manual dispatch.'
        required: false

permissions:
  contents: write
  id-token: write
  attestations: read

jobs:
  sign-artifacts:
    name: Build, upload, sign release artifacts (cosign keyless)
    runs-on: ubuntu-24.04
    permissions:
      contents: write
      id-token: write
      attestations: read
    steps:
      - name: Resolve release tag
        id: tag
        run: |
          if [ -n "${{ inputs.tag }}" ]; then
            echo "tag=${{ inputs.tag }}" >> "$GITHUB_OUTPUT"
          else
            echo "tag=${GITHUB_REF#refs/tags/}" >> "$GITHUB_OUTPUT"
          fi

      - name: Checkout source
        uses: actions/checkout@v4

      - name: Install Rust toolchain
        uses: dtolnay/rust-toolchain@stable

      - name: Cache cargo registry & target
        uses: Swatinem/rust-cache@v2
        with:
          workspaces: |
            .

      - name: Build release binaries (workspace)
        run: cargo build --release --workspace --bins --locked

      - name: Collect unsigned artifacts
        run: |
          mkdir -p unsigned
          # Workspace binaries (one binary per [[bin]] crate)
          find target/release -maxdepth 1 -type f -executable -not -name "*.d" -not -name "*.so*" -not -name "*.dylib" -print0 | xargs -0 -I {} cp {} unsigned/

      - name: Upload unsigned artifacts (for verification step + downstream jobs)
        uses: actions/upload-artifact@v4
        with:
          name: release-artifacts
          path: unsigned/
          if-no-files-found: error
          retention-days: 90

      - name: Install cosign
        uses: sigstore/cosign-installer@v3
        with:
          cosign-release: 'v2.4.1'

      - name: Set up keyless OIDC signing environment
        env:
          COSIGN_EXPERIMENTAL: '1'
        run: |
          # cosign picks up ACTIONS_ID_TOKEN_REQUEST_TOKEN automatically via OIDC
          echo "Using keyless signing via Sigstore OIDC"

      - name: Sign all unsigned artifacts
        env:
          COSIGN_EXPERIMENTAL: '1'
        run: |
          mkdir -p signed
          cd unsigned
          shopt -s nullglob
          for file in *; do
            if [ -f "$file" ]; then
              echo ">>> Signing $file"
              cosign sign-blob \
                --yes \
                --output-signature "../signed/${file}.sig" \
                --output-certificate "../signed/${file}.cert" \
                --bundle "../signed/${file}.bundle" \
                "$file"
            fi
          done
          cd ..
          echo "=== Signed artifacts ==="
          ls -la signed/

      - name: Upload signed artifacts
        uses: actions/upload-artifact@v4
        with:
          name: signed-release-artifacts
          path: signed/
          if-no-files-found: error
          retention-days: 90

  attach-to-release:
    name: Attach signatures + SBOM to release
    needs: sign-artifacts
    runs-on: ubuntu-24.04
    permissions:
      contents: write
    steps:
      - name: Resolve release tag
        id: tag
        run: |
          if [ -n "${{ inputs.tag }}" ]; then
            echo "tag=${{ inputs.tag }}" >> "$GITHUB_OUTPUT"
          else
            echo "tag=${GITHUB_REF#refs/tags/}" >> "$GITHUB_OUTPUT"
          fi

      - name: Checkout source
        uses: actions/checkout@v4

      - name: Download signed artifacts
        uses: actions/download-artifact@v4
        with:
          name: signed-release-artifacts
          path: signed/

      - name: Download unsigned artifacts (for verification)
        uses: actions/download-artifact@v4
        with:
          name: release-artifacts
          path: unsigned/

      - name: Install cosign (for verification step)
        uses: sigstore/cosign-installer@v3
        with:
          cosign-release: 'v2.4.1'

      - name: Attach .sig/.cert/.bundle to release
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          cd signed/
          shopt -s nullglob
          sig_files=(*.sig)
          cert_files=(*.cert)
          bundle_files=(*.bundle)
          if [ ${#sig_files[@]} -gt 0 ] && [ -e "${sig_files[0]}" ]; then
            echo "Uploading ${#sig_files[@]} signatures, ${#cert_files[@]} certs, ${#bundle_files[@]} bundles"
            gh release upload "${{ steps.tag.outputs.tag }}" \
              --clobber \
              "${sig_files[@]}" "${cert_files[@]}" "${bundle_files[@]}"
          else
            echo "No signatures to upload"
            exit 1
          fi

      - name: Verify a sample signature (sanity check)
        env:
          COSIGN_EXPERIMENTAL: '1'
        run: |
          echo "=== Verify signature on the first signed artifact ==="
          cd signed/
          first_sig=$(ls *.sig | head -1)
          base=${first_sig%.sig}
          echo "Verifying: $base"
          if [ -f "${base}.cert" ]; then
            cosign verify-blob \
              --certificate "${base}.cert" \
              --signature "${base}.sig" \
              --certificate-identity-regexp 'https://github.com/.*/.github/workflows/signed-release.yml' \
              --certificate-oidc-issuer-regexp 'https://token.actions.githubusercontent.com' \
              "../unsigned/${base}" && echo ">>> Signature VERIFIED for $base"
          else
            echo "(cert not found — skipping verification)"
          fi
