name: Signed Release

on:
  release:
    types: [published]
  workflow_dispatch:
    inputs:
      tag:
        description: 'Tag to sign (e.g. v0.0.1). Required for manual dispatch.'
        required: false

permissions:
  contents: write
  id-token: write
  attestations: read

jobs:
  sign-artifacts:
    name: Sign release artifacts (cosign keyless)
    runs-on: ubuntu-24.04
    permissions:
      contents: write
      id-token: write
      attestations: read
    steps:
      - name: Checkout source
        uses: actions/checkout@v4

      - name: Resolve release tag
        id: tag
        run: |
          if [ -n "${{ inputs.tag }}" ]; then
            echo "tag=${{ inputs.tag }}" >> "$GITHUB_OUTPUT"
          else
            echo "tag=${GITHUB_REF#refs/tags/}" >> "$GITHUB_OUTPUT"
          fi

      - name: Install cosign
        uses: sigstore/cosign-installer@9d0681fc99f7cb29e62bd65c4c4de2c1a14e2c31
        with:
          cosign-release: 'v2.4.1'

      - name: Download release-artifacts
        uses: actions/download-artifact@fa6e1069be6e9c0e44f2b3e9f38ea0168e9b0168
        with:
          name: release-artifacts
          path: unsigned/

      - name: Set up signing environment (keyless OIDC)
        env:
          COSIGN_EXPERIMENTAL: '1'
        run: |
          # cosign picks up ACTIONS_ID_TOKEN_REQUEST_TOKEN automatically via OIDC
          echo "Using keyless signing via Sigstore OIDC"

      - name: Sign all unsigned artifacts
        env:
          COSIGN_EXPERIMENTAL: '1'
        run: |
          mkdir -p signed
          cd unsigned
          shopt -s nullglob
          for file in *; do
            if [ -f "$file" ] && [ ! -f "../signed/${file}.sig" ]; then
              echo ">>> Signing $file"
              cosign sign-blob \
                --yes \
                --output-signature "../signed/${file}.sig" \
                --output-certificate "../signed/${file}.cert" \
                --bundle "../signed/${file}.bundle" \
                "$file"
            fi
          done
          cd ..
          echo "=== Signed artifacts ==="
          ls -la signed/

      - name: Upload signed artifacts
        uses: actions/upload-artifact@043fb46d1a93c77aae656e7c1c64a875d1fc6a0a
        with:
          name: signed-release-artifacts
          path: signed/
          if-no-files-found: error
          retention-days: 90

  attach-to-release:
    name: Attach signed artifacts + SBOM to release
    needs: sign-artifacts
    runs-on: ubuntu-24.04
    permissions:
      contents: write
    steps:
      - name: Resolve release tag
        id: tag
        run: |
          if [ -n "${{ inputs.tag }}" ]; then
            echo "tag=${{ inputs.tag }}" >> "$GITHUB_OUTPUT"
          else
            echo "tag=${GITHUB_REF#refs/tags/}" >> "$GITHUB_OUTPUT"
          fi

      - name: Download signed artifacts
        uses: actions/download-artifact@fa6e1069be6e9c0e44f2b3e9f38ea0168e9b0168
        with:
          name: signed-release-artifacts
          path: signed/

      - name: Attach .sig/.cert/.bundle to release
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          cd signed/
          files=(*.sig *.cert *.bundle)
          if [ ${#files[@]} -gt 0 ] && [ -e "${files[0]}" ]; then
            gh release upload "${{ steps.tag.outputs.tag }}" \
              --clobber \
              "${files[@]}"
          fi

      - name: Verify a sample signature (sanity check)
        env:
          COSIGN_EXPERIMENTAL: '1'
        run: |
          echo "=== Verify signature on any signed artifact ==="
          # Pick the first .sig + .cert + source pair
          cd signed/
          first_sig=$(ls *.sig | head -1)
          base=${first_sig%.sig}
          if [ -f "${base}.cert" ] && [ -f "$base" ] || [ -f "unsigned/$base" ]; then
            cosign verify-blob \
              --certificate "${base}.cert" \
              --signature "${base}.sig" \
              --certificate-identity-regexp 'https://github.com/.*/.github/workflows/signed-release.yml' \
              --certificate-oidc-issuer-regexp 'https://token.actions.githubusercontent.com' \
              "unsigned/$base" 2>/dev/null || echo "(unsigned dir not present locally — verify step is a no-op for this run)"
          fi
