const { execSync } = require('child_process');

const files = [
  'src/lib/benchmarks.ts',
  'src/lib/oneproxyRotator.ts',
  'src/lib/oneproxySync.ts',
  'src/lib/settingsCache.ts',
  'src/lib/toolPolicy.ts',
  'src/lib/acp/manager.ts',
  'src/lib/credentialHealth/scheduler.ts',
  'src/lib/inspector/secretMask.ts',
  'src/lib/jobs/reasoningCacheCleanupJob.ts',
  'src/lib/plugins/pluginWorker.ts',
  'src/lib/plugins/signing.ts',
  'src/lib/plugins/testRunner.ts',
  'src/lib/plugins/watcher.ts',
  'src/lib/skills/a2a.ts',
  'src/lib/skills/custom.ts',
  'src/lib/skills/hybrid.ts',
  'src/lib/oauth/utils/banner.ts',
  'src/lib/oauth/utils/ui.ts',
  'src/lib/skills/builtin/browser.ts'
];

const now = new Date();
const ninetyDaysAgo = new Date(now.getTime() - 90 * 24 * 60 * 60 * 1000);

console.log(`Now: ${now.toISOString()}`);
console.log(`90d cutoff: ${ninetyDaysAgo.toISOString()}`);
console.log('');

for (const f of files) {
  try {
    const out = execSync(`git log --format="%H %ai %s" -1 --follow -- "${f}"`, { encoding: 'utf8', cwd: 'C:/Users/koosh/OmniRoute-clean' });
    const line = out.trim();
    if (!line) {
      console.log(`-- ${f}: NO COMMITS (likely new untracked)`);
      continue;
    }
    // Parse the date from "YYYY-MM-DD HH:MM:SS Z ..."
    const parts = line.split(' ');
    const dateStr = parts.slice(1, 5).join(' ');
    const date = new Date(dateStr + ' UTC');
    const daysAgo = Math.floor((now - date) / (1000 * 60 * 60 * 24));
    const status = daysAgo > 90 ? 'OK (>90d)' : 'RECENT';
    console.log(`-- ${f}: ${line.slice(0, 80)}... [${daysAgo}d ago, ${status}]`);
  } catch (e) {
    console.log(`-- ${f}: ERROR - ${e.message}`);
  }
}
