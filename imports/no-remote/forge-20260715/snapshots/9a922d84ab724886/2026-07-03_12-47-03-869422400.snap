// v2: handle ALL actions/checkout calls including those with existing `with:`
// blocks that contain `token:` / `fetch-depth:` etc but no `persist-credentials`.
import fs from "node:fs";
import path from "node:path";
import { fileURLToPath } from "node:url";

const ROOT = path.resolve(path.dirname(fileURLToPath(import.meta.url)), ".github", "workflows");
const files = fs.readdirSync(ROOT).filter((f) => /\.(yml|yaml)$/.test(f)).map((f) => path.join(ROOT, f));

let totalFixed = 0;
const report = [];
for (const file of files) {
  const orig = fs.readFileSync(file, "utf8");
  const lines = orig.split(/\r?\n/);
  let fixedInFile = 0;

  for (let i = 0; i < lines.length; i++) {
    const line = lines[i];
    // Match either:
    //   "      - uses: actions/checkout@<ref>"
    //   "      - name: Foo\n        uses: actions/checkout@<ref>"
    let isCheckoutLine = /^\s*-\s*uses:\s*actions\/checkout@/.test(line);
    let nameOnPrevLine = false;
    if (!isCheckoutLine) {
      // Check if this line is a `uses:` continuation of a `- name:` step on the previous line
      const prev = i > 0 ? lines[i - 1] : "";
      const prevIsNameStep = /^\s*-\s*name:/.test(prev);
      const thisIsUses = /^\s+uses:\s*actions\/checkout@/.test(line);
      if (prevIsNameStep && thisIsUses) {
        isCheckoutLine = true;
        nameOnPrevLine = true;
      }
    }
    if (!isCheckoutLine) continue;
    const usesLineIdx = nameOnPrevLine ? i - 1 : i;
    let hasPersist = false;
    let withLineIdx = -1;
    let withIndent = "";
    let stepEndsAt = lines.length;
    for (let j = i + 1; j < Math.min(lines.length, i + 14); j++) {
      const fl = lines[j];
      const listItem = /^\s*-\s/.test(fl);
      if (listItem) { stepEndsAt = j; break; }
      const withMatch = /^(\s*)with:\s*$/.exec(fl);
      if (withMatch) { withLineIdx = j; withIndent = withMatch[1]; }
      if (/^\s*persist-credentials:\s/.test(fl)) hasPersist = true;
    }
    if (hasPersist) continue;

    if (withLineIdx >= 0) {
      // Insert into existing `with:` block, AFTER any known sibling keys (token/fetch-depth/ref/etc).
      let insertAt = withLineIdx + 1;
      for (let j = withLineIdx + 1; j < stepEndsAt; j++) {
        if (/^\s*(token|fetch-depth|ref|repository|path|ssh-key|github-token|clean|submodules|sparse-checkout|set-safe-directory|lfs|fetch-tags|show-progress|audit|ssh|github-app|filter):/.test(lines[j])) {
          insertAt = j + 1;
        } else if (lines[j].trim() === "") {
          continue;
        } else {
          break;
        }
      }
      const shift = insertAt - i;
      lines.splice(insertAt, 0, `${withIndent}persist-credentials: false`);
      i += shift;
      stepEndsAt += shift;
      fixedInFile++;
    } else {
      // No `with:` block. Determine indent from the `-` list-item marker.
      const stepLineMatch = /^(\s*)-/.exec(lines[i]);
      const baseIndent = stepLineMatch ? stepLineMatch[1] + "  " : "        ";
      lines.splice(i + 1, 0, `${baseIndent}with:`, `${baseIndent}  persist-credentials: false`);
      i += 2;
      stepEndsAt += 2;
      fixedInFile++;
    }
  }
  if (fixedInFile > 0) {
    fs.writeFileSync(file, lines.join("\n"));
    report.push(`${path.basename(file)}: ${fixedInFile}`);
    totalFixed += fixedInFile;
  }
}
console.log(`Fixed ${totalFixed} checkout steps in ${report.length} files`);
for (const r of report) console.log("  " + r);