# =============================================================================
#  OmniRoute — OpenTelemetry Collector (sidecar)
# =============================================================================
#  This file is consumed by the otel/opentelemetry-collector-contrib image.
#  Three signal pipelines are wired (traces / metrics / logs), all draining
#  into Prometheus + Jaeger via the contrib exporters. Self-monitoring is
#  exposed via the health_check / pprof / zpages extensions.
#
#  Receiver matrix:
#    - otlp       : 4317 (gRPC) + 4318 (HTTP) — primary ingest from OmniRoute
#    - prometheus : scrapes http://localhost:20128/api/metrics every 15s
#    - hostmetrics: default process / cpu / memory gauges
#    - filelog    : tails /var/log/omniroute/*.log (rotation-aware)
#
#  IMPORTANT — this config is parsed at runtime by the contrib collector, NOT
#  by OmniRoute. Errors here are caught by `validate_collector.sh` in CI
#  (`otelcol validate --config=collector.yaml`) which runs the same binary.
# =============================================================================

receivers:
  # --- OTLP (gRPC + HTTP) -----------------------------------------------------
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
        # max_recv_msg_size_mib: 16 — defaults to 4 MiB; raise so large
        # telemetry batches from busy proxies do not get rejected.
        max_recv_msg_size_mib: 16
        keepalive:
          server_parameters:
            max_connection_idle: 30s
            max_connection_age: 5m
            time: 30s
            timeout: 10s
      http:
        endpoint: 0.0.0.0:4318
        max_request_body_size: 16_777_216  # 16 MiB

  # --- Prometheus scrape (OmniRoute /api/metrics) ----------------------------
  prometheus:
    config:
      global:
        scrape_interval: 15s
        evaluation_interval: 15s
      scrape_configs:
        - job_name: omniroute
          metrics_path: /api/metrics
          scheme: http
          static_configs:
            - targets: ["localhost:20128"]
              labels:
                service: omniroute
                component: proxy
        - job_name: omniroute-internal
          metrics_path: /api/internal/metrics
          scheme: http
          static_configs:
            - targets: ["localhost:20128"]
              labels:
                service: omniroute
                component: internal

  # --- Host metrics (cpu, mem, disk, network) ---------------------------------
  hostmetrics:
    collection_interval: 30s
    scrapers:
      cpu:
      disk:
      load:
      filesystem:
      memory:
        metrics:
          system.memory.utilization:
            enabled: true
      network:
      paging:
      processes:
      processes_per_cpu:

  # --- filelog (rotation-aware JSONL tail) ------------------------------------
  filelog:
    include:
      - /var/log/omniroute/*.log
      - /var/log/omniroute/**/*.log
    exclude:
      - /var/log/omniroute/**/*.gz
    start_at: end
    retention: 24h
    operators:
      - type: json_parser
        parse_to: body
      - type: trace_parser
        if: body has "trace_id"
        trace_id:
          parse_from: body.trace_id
        span_id:
          parse_from: body.span_id
      - type: severity
        if: body has "level"
        parse_from: body.level

# =============================================================================
#  Processors — order matters! Each processor passes the result to the next.
# =============================================================================
processors:
  # --- Memory limiter — drop batches if the collector exceeds the budget. ---
  memory_limiter:
    # 25% of available RAM up to 1024 MiB; spike 256 MiB.
    check_interval: 2s
    limit_percentage: 80
    spike_limit_percentage: 25

  # --- Resource detection (cloud + env) -------------------------------------
  resourcedetection:
    detectors: [env, system, gcp, ec2, azure]
    timeout: 5s
    override: false

  # --- Cost attribution: tag spans with the caller's tenant id --------------
  attributes/cost:
    actions:
      - key: omniroute.tenant.id
        from_attribute: http.request.header.x-tenant-id
        action: insert
      - key: deployment.environment
        from_attribute: env.DEPLOYMENT_ENV
        action: insert
        default_value: production

  # --- Filter noisy probes (health checks) ----------------------------------
  filter/health:
    metrics:
      exclude:
        match_type: strict
        metric_names:
          - http.server.duration  # high cardinality, already covered by histogram
    traces:
      span:
        - 'name == "omniroute.health.check"'
        - 'attributes["http.route"] == "/api/health"'
    logs:
      log_record:
        - 'body == "health probe"'

  # --- Batch + compress before export ---------------------------------------
  batch:
    timeout: 5s
    send_batch_size: 1024
    send_batch_max_size: 2048

  # --- Tail-based sampling (keep slow / failed, sample 1% of the rest) ------
  tail_sampling:
    decision_wait: 10s
    num_traces: 50_000
    expected_new_traces_per_sec: 200
    policies:
      - name: errors
        type: status_code
        status_code:
          status_codes: [ERROR]
      - name: slow-traces
        type: latency
        latency:
          threshold_ms: 250
      - name: probabilistic
        type: probabilistic
        probabilistic:
          sampling_percentage: 1

  # --- Memory limiter duplicate at the END so it caps AFTER batching ------
  memory_limiter/egress:
    check_interval: 2s
    limit_mib: 1024
    spike_limit_mib: 256

# =============================================================================
#  Exporters
# =============================================================================
exporters:
  # --- Prometheus remote write ----------------------------------------------
  prometheusremotewrite:
    endpoint: http://prometheus:9090/api/v1/write
    tls:
      insecure: true
    timeout: 10s
    retry_on_failure:
      enabled: true
      initial_interval: 1s
      max_interval: 30s
      max_elapsed_time: 120s
    resource_to_telemetry_conversion:
      enabled: true

  # --- OTLP to Jaeger (the actual trace backend) ----------------------------
  otlp/backend:
    endpoint: otel-backend:4317
    tls:
      insecure: true
    sending_queue:
      enabled: true
      num_consumers: 4
      queue_size: 1000
      retry_on_failure:
        enabled: true
        initial_interval: 1s
        max_interval: 30s
        max_elapsed_time: 300s

  # --- Stdout debug (sample-and-then-quiet) ---------------------------------
  logging:
    loglevel: info
    sampling_initial: 5
    sampling_thereafter: 200

  # --- JSONL file exporter (rotation-aware) ---------------------------------
  file/traces:
    path: /var/log/omniroute/traces.jsonl
    rotation:
      max_megabytes: 100
      max_days: 7
      max_backups: 10

  # --- Debug (only used when OTEL_DEBUG=true) -------------------------------
  debug:
    verbosity: detailed
    sampling_initial: 5
    sampling_thereafter: 50

# =============================================================================
#  Extensions (non-pipeline services running inside the collector process)
# =============================================================================
extensions:
  health_check:
    endpoint: 0.0.0.0:13133
    check_collector_pipeline:
      enabled: true
      interval: 30s
      exporter_failure_threshold: 5

  pprof:
    endpoint: 0.0.0.0:1777
    block_profile_fraction: 0
    mutex_profile_fraction: 0

  zpages:
    endpoint: 0.0.0.0:55679

  # --- Bearer-token auth for the OTLP receivers (omni-only) -----------------
  bearertokenauth:
    token: ${env:OTEL_AUTH_TOKEN}

# =============================================================================
#  Service definition — wires pipelines + extensions together
# =============================================================================
service:
  extensions: [health_check, pprof, zpages, bearertokenauth]

  telemetry:
    logs:
      level: info
      development: false
      encoding: json
      error_output_paths:
        - stderr
      output_paths:
        - stderr
    metrics:
      address: 0.0.0.0:8888
      level: basic

  pipelines:
    traces:
      receivers: [otlp]
      processors: [memory_limiter, resourcedetection, attributes/cost, filter/health, tail_sampling, batch]
      exporters: [otlp/backend, file/traces, logging]

    metrics:
      receivers: [otlp, prometheus, hostmetrics]
      processors: [memory_limiter, resourcedetection, attributes/cost, batch, memory_limiter/egress]
      exporters: [prometheusremotewrite, logging]

    logs:
      receivers: [otlp, filelog]
      processors: [memory_limiter, resourcedetection, attributes/cost, filter/health, batch]
      exporters: [logging, file/traces]