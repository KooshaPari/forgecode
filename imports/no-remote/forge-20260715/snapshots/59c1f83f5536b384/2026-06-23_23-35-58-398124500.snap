name: Secret scan

on:
  push:
    branches: [main, master]
  pull_request:
    branches: [main, master]
  schedule:
    # Weekly Sunday 06:00 UTC (== 23:00 PDT Saturday / 22:00 PST).
    - cron: "0 6 * * 0"
  workflow_dispatch:

permissions:
  contents: read

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  gitleaks:
    name: gitleaks (secret scan)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@9c091bb21b7c1c1d1991bb908d89e4e9dddfe3e0
        with:
          # Full history is needed so we catch secrets that were added and
          # removed in prior commits.
          fetch-depth: 0
      - name: Run gitleaks
        uses: gitleaks/gitleaks-action@9f1417b65fbef36dd55a16f8a0308af9c90fbf2b
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          # Use the committed config; fall back to defaults if missing.
          GITLEAKS_CONFIG: .gitleaks.toml
          # Upload SARIF to the Security tab on push to main.
          GITLEAKS_ENABLE_UPLOAD_ARTIFACT: true
          GITLEAKS_ENABLE_SUMMARY: true