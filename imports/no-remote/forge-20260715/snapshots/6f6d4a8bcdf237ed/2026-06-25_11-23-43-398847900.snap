//! DAG unit types for the agileplus executor.
//!
//! Each unit in the DAG corresponds to one work-package-sized task that
//! can be dispatched to an agent or executed locally.

use serde::{Deserialize, Serialize};

// ---------------------------------------------------------------------------
// Error type
// ---------------------------------------------------------------------------

/// Errors that can occur during DAG parsing or execution.
#[derive(Debug)]
pub enum DagError {
    /// IO error reading the YAML file.
    Io(String),
    /// YAML parse error.
    Parse(String),
    /// Graph cycle detected.
    Cycle(String),
    /// Error during audit / grading phase.
    Audit(String),
}

impl std::fmt::Display for DagError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            DagError::Io(msg) => write!(f, "DAG I/O error: {msg}"),
            DagError::Parse(msg) => write!(f, "DAG parse error: {msg}"),
            DagError::Cycle(msg) => write!(f, "DAG cycle: {msg}"),
        }
    }
}

impl std::error::Error for DagError {}

// ---------------------------------------------------------------------------
// Status
// ---------------------------------------------------------------------------

/// Execution status of a single DAG unit.
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, Serialize, Deserialize)]
#[serde(rename_all = "snake_case")]
pub enum UnitStatus {
    Pending,
    Running,
    Done,
    Failed,
    Skipped,
}

// ---------------------------------------------------------------------------
// Unit type
// ---------------------------------------------------------------------------

/// The category of a DAG unit — controls how it is dispatched.
#[derive(Debug, Clone, PartialEq, Eq, Hash, Serialize, Deserialize)]
#[serde(rename_all = "snake_case")]
pub enum UnitType {
    Audit,
    BranchClean,
    Bridge,
    Config,
    Consolidate,
    Dag,
    Dashboard,
    Deadcode,
    Docs,
    Feature,
    Gate,
    Governance,
    Iac,
    Mojo,
    Ffi,
    Driver,
    Test,
    Obs,
    Cost,
    Perf,
    Adr,
    Recover,
    Feat,
    Cli,
    Dist,
    Dash,
    Cve,
    Slsa,
    Changelog,
    Sladge,
    Gov,
    Arch,
    Dev,
    Deps,
    Rel,
    Render,
    Hook,
    Validator,
    Wasm,
    Sbom,
    Oci,
    Ebpf,
    Tenant,
    Publish,
    Site,
    Roadmap,
    Bench,
    Pitch,
    #[serde(other)]
    Other,
}

impl From<&str> for UnitType {
    fn from(s: &str) -> Self {
        match s {
            "audit" => UnitType::Audit,
            "branch-clean" => UnitType::BranchClean,
            "bridge" => UnitType::Bridge,
            "config" => UnitType::Config,
            "consolidate" => UnitType::Consolidate,
            "dag" => UnitType::Dag,
            "dashboard" => UnitType::Dashboard,
            "deadcode" => UnitType::Deadcode,
            "docs" => UnitType::Docs,
            "feature" => UnitType::Feature,
            "gate" => UnitType::Gate,
            "governance" => UnitType::Governance,
            "iac" => UnitType::Iac,
            "mojo" => UnitType::Mojo,
            "ffi" => UnitType::Ffi,
            "driver" => UnitType::Driver,
            "test" => UnitType::Test,
            "obs" => UnitType::Obs,
            "cost" => UnitType::Cost,
            "perf" => UnitType::Perf,
            "adr" => UnitType::Adr,
            "recover" => UnitType::Recover,
            "feat" => UnitType::Feat,
            "cli" => UnitType::Cli,
            "dist" => UnitType::Dist,
            "dash" => UnitType::Dash,
            "cve" => UnitType::Cve,
            "slsa" => UnitType::Slsa,
            "changelog" => UnitType::Changelog,
            "sladge" => UnitType::Sladge,
            "gov" => UnitType::Gov,
            "arch" => UnitType::Arch,
            "dev" => UnitType::Dev,
            "deps" => UnitType::Deps,
            "rel" => UnitType::Rel,
            "render" => UnitType::Render,
            "hook" => UnitType::Hook,
            "validator" => UnitType::Validator,
            "wasm" => UnitType::Wasm,
            "sbom" => UnitType::Sbom,
            "oci" => UnitType::Oci,
            "ebpf" => UnitType::Ebpf,
            "tenant" => UnitType::Tenant,
            "publish" => UnitType::Publish,
            "site" => UnitType::Site,
            "roadmap" => UnitType::Roadmap,
            "bench" => UnitType::Bench,
            "pitch" => UnitType::Pitch,
            _ => UnitType::Other,
        }
    }
}

// ---------------------------------------------------------------------------
// DagUnit
// ---------------------------------------------------------------------------

/// A single work unit extracted from the DAG YAML.
///
/// Each unit maps to one work-package-like task that the executor
/// can dispatch to an agent pool.
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct DagUnit {
    pub id: String,
    pub epic: String,
    pub repo: String,
    pub title: String,
    pub unit_type: String,
    pub sequence: u32,
    pub status: UnitStatus,
}

impl DagUnit {
    /// Human-readable label for logging.
    pub fn label(&self) -> String {
        format!("{}-{}", self.epic, self.id)
    }

    /// Canonical branch name for this unit.
    pub fn branch_name(&self) -> String {
        format!("dag/{}-{}", self.epic.to_lowercase(), self.id.to_lowercase())
    }
}

// ---------------------------------------------------------------------------
// Execution wave
// ---------------------------------------------------------------------------

/// A set of units that can execute in parallel.
#[derive(Debug, Clone)]
pub struct ExecutionWave {
    pub wave_number: u32,
    pub unit_ids: Vec<String>,
    pub units: Vec<DagUnit>,
}

// ---------------------------------------------------------------------------
// Tests
// ---------------------------------------------------------------------------

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn unit_type_from_str() {
        assert_eq!(UnitType::from("bridge"), UnitType::Bridge);
        assert_eq!(UnitType::from("dag"), UnitType::Dag);
        assert_eq!(UnitType::from("unknown-xyz"), UnitType::Other);
    }

    #[test]
    fn dag_unit_label() {
        let u = DagUnit {
            id: "F11".into(),
            epic: "F".into(),
            repo: "agileplus".into(),
            title: "test".into(),
            unit_type: "bridge".into(),
            sequence: 0,
            status: UnitStatus::Pending,
        };
        assert_eq!(u.label(), "F-F11");
        assert_eq!(u.branch_name(), "dag/f-f11");
    }
}
