#!/usr/bin/env python3
"""Check archive + push state of every KooshaPari repo in scope."""
import json, subprocess, sys

REPOS = [
    "Benchora", "portage", "AgilePlus", "pheno-harness", "Tracera",
    "phenodag", "vibeproxy-monitoring-unified", "phenotype-org-audits",
    "heliosBench", "phenotype-registry", "nanovms", "PhenoCompose", "BytePort",
]

print(f"{'repo':32s} | {'archived':8s} | {'disabled':8s} | {'visibility':10s} | default")
print("-" * 100)

for r in REPOS:
    try:
        out = subprocess.run(
            ["gh", "api", f"repos/KooshaPari/{r}", "--jq",
             "{name: .name, archived: .archived, disabled: .disabled, visibility: .visibility, default_branch: .default_branch}"],
            capture_output=True, text=True, timeout=15,
        )
        if out.returncode != 0:
            print(f"{r:32s} | ERROR: {out.stderr.strip()[:50]}")
            continue
        d = json.loads(out.stdout)
        print(f"{d['name']:32s} | {str(d['archived']):8s} | {str(d['disabled']):8s} | {d.get('visibility','?'):10s} | {d.get('default_branch','?')}")
    except Exception as e:
        print(f"{r:32s} | EXC: {e}")