    [BLOCK_A, BLOCK_B, BLOCK_C, BLOCK_D, BLOCK_E, BLOCK_F, BLOCK_G, BLOCK_H, BLOCK_I,
     BLOCK_J, BLOCK_K, BLOCK_L, BLOCK_M, BLOCK_N, BLOCK_O, BLOCK_P, BLOCK_Q, BLOCK_R,
     BLOCK_S, BLOCK_T, BLOCK_U]
