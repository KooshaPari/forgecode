#!/usr/bin/env python3
"""Mega generator: produces WP blocks A-Z+ into work_dag_cu_20260624_000000.md.

This script appends blocks B through Z to the file. Block A was already generated
into _dag_part2_block_a.md and will be appended here.
"""
import os, sys

BASE = r"C:\Users\koosh\_cu_audit"
FINAL = os.path.join(BASE, "work_dag_cu_20260624_000000.md")
BLOCK_A = os.path.join(BASE, "_dag_part2_block_a.md")


def wp(num, slug, title, repo, spec, plan, tasks, pillar, deps, blocks, est, owner, score,
       status, desc, accept, refs, sota, ext_wins, int_wins):
    """Format one WP block."""
    spec_line = f"agileplus-specs/{spec}/spec.md" if spec != "N/A" else "N/A"
    plan_line = f"agileplus-specs/{plan}/plan.md" if plan != "N/A" else "N/A"
    tasks_line = f"agileplus-specs/{tasks}/tasks.md" if tasks != "N/A" else "N/A"
    deps_line = ",".join(deps) if deps else "-"
    blocks_line = ",".join(blocks) if blocks else "-"
    return f"""### WP-{num:03d}: {slug} -- {title}

```
Repo: {repo}
Spec: {spec_line}
Plan: {plan_line}
Tasks: {tasks_line}
Pillar: {pillar}
Depends: {deps_line}
Blocks: {blocks_line}
Est: {est}
Owner: {owner}
Score: {score}/10
Status: {status}
Description: {desc}
Acceptance: {accept}
Refs: {refs}
SOTA: {sota}
External-Wins: {ext_wins}
Internal-Wins: {int_wins}
```
"""


def bulk(num_start, count, slug_prefix, title_prefix, repo, pillar, deps_base,
         blocks_base, est, owner, desc_tmpl, accept_tmpl, refs_tmpl,
         sota_tmpl, ext_wins_tmpl, int_wins_tmpl):
    """Generate `count` WPs with auto-incremented numbers."""
    out = []
    for i in range(count):
        num = num_start + i
        slug = f"{slug_prefix}-{i+1:02d}"
        title = title_prefix.format(i=i+1)
        out.append(wp(
            num, slug, title, repo, "170-cu-platform", "170-cu-platform",
            "170-cu-platform", pillar,
            deps_base + [f"WP-{num-1:03d}"] if i > 0 else deps_base,
            blocks_base, est, owner, "?",
            "pending",
            desc_tmpl.format(i=i+1, num=num),
            accept_tmpl.format(i=i+1),
            refs_tmpl.format(i=i+1),
            sota_tmpl.format(i=i+1),
            ext_wins_tmpl.format(i=i+1),
            int_wins_tmpl.format(i=i+1),
        ))
    return out


