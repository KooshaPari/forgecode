[package]
name = "civis"
version.workspace = true
edition.workspace = true
authors.workspace = true
license.workspace = true
rust-version.workspace = true
publish = false

[dev-dependencies]
criterion = "0.6"
hecs = "0.10"
rand = "0.8.6"
rand_chacha = "0.3"
civ-agents = { path = "crates/agents" }
civ-economy = { path = "crates/economy" }
civ-voxel = { path = "crates/voxel" }

[[bench]]
name = "civis_perf"
harness = false

[workspace]
members = [
  ".",
  "crates/engine",
  "crates/dag",
  "crates/server",
  "crates/voxel-bridge",
  "crates/build",
  "crates/genetics",
  "crates/economy",
  "crates/species",
  "crates/agents",
  "crates/needs",
  "crates/diffusion",
  "crates/diplomacy",
  "crates/laws",
  "crates/research",
  "crates/tactics",
  "crates/planet",
  "crates/protocol-3d",
  "crates/mod-host",
  "crates/civlab-sdk",
  "crates/civis-cli",
  "crates/civis-mcp",
  "crates/powers",
  "crates/watch",
  "crates/save-db",
  "crates/hud",
  "crates/legends",
  "crates/civ-emergence-metrics",
  "crates/civ-institutions",
  "crates/infra",
  "crates/physics-substrate",
  "crates/audio",
  "crates/holocron",
  "crates/i18n",
  "crates/dag",
  "clients/bevy-ref",
  # "clients/fyrox-ref" - excluded until fyrox 1.x API is wired (see docs/research/fyrox-evaluation.md)
]
default-members = ["."]
exclude = [
  "clients/godot-ref/rust",
  "clients/unreal-show/Source/Civis/rust-shim",
]
resolver = "2"

[workspace.package]
version = "0.1.0"
edition = "2021"
authors = ["CivLab"]
license = "MIT OR Apache-2.0"
rust-version = "1.75"

# --- Dev-loop profiles (see docs/development-guide/dev-loop.md) ---
# These tune ONLY the dev profile; `release` is untouched, so release
# determinism and optimization are unaffected.
[profile.dev]
# Our own crates: opt-level 0 = fastest possible compile (the code we edit).
opt-level = 0
# Lightweight line-table debuginfo only - full DWARF is the slowest part of a
# dev link. `debug = 1` keeps backtraces/line numbers while shrinking link time.
debug = 1
# Split debuginfo out of the object files so the linker copies less. On Windows
# MSVC this maps to a separate .pdb ("packed"); on *nix to "unpacked".
split-debuginfo = "packed"

# Heavy game-engine deps (bevy, wgpu, bevy_kira_audio) are compiled once and
# rarely change, so optimizing them keeps the *running* sandbox fast without
# slowing our warm rebuilds. opt-level 3 here is the standard Bevy fast-dev
# recommendation. Lighter deps (serde, rand, etc.) intentionally fall through
# to the workspace `[profile.dev]` (opt-level = 0, debug = 1) so target/ does
# not bloat and incremental re-links stay cheap.
#
# `debug = 1` keeps line tables so breakpoints / backtraces inside bevy_ecs,
# wgpu, and kira work when stepping through a sim issue - without paying for
# full inline DWARF on the first build.
[profile.dev.package.bevy]
opt-level = 3
debug = 1

[profile.dev.package.wgpu]
opt-level = 3
debug = 1

[profile.dev.package.bevy_kira_audio]
opt-level = 3
debug = 1

[patch.crates-io]
metal = { path = "vendor/metal" }
kira = { path = "vendor/kira" }
simba = { path = "vendor/simba" }
