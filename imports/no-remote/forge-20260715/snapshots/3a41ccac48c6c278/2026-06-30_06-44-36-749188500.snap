[Console]::OutputEncoding = [System.Text.Encoding]::UTF8
$ErrorActionPreference = "Continue"
gh api repos/cline/cline/commits?per_page=200 2>$null | Out-File -Encoding utf8 "$env:TEMP\commits.json"
$json = Get-Content -Raw "$env:TEMP\commits.json" | ConvertFrom-Json
Write-Host "Commits received: $($json.Count)"
$lines = foreach ($c in $json) {
  $firstLine = ($c.commit.message -split "`n")[0]
  ("{0}  {1}" -f $c.sha.Substring(0,10), $firstLine)
}
$lines | Select-Object -First 80 | ForEach-Object { Write-Host $_ }
