#!/usr/bin/awk -f
# count-expected.awk - compute expected task count for a phenodag preset YAML
# Usage: awk -f count-expected.awk presets/foo.yaml
# Returns: core.stages * core.width + sum(side_dags[].size)
# All regexes use [\/] syntax to keep both gawk and POSIX awk happy.

BEGIN {
    c = 0; w = 0; s = 0
    in_core = 0; in_side = 0
}
/^[[:space:]]*$/      { next }
/^core:[[:space:]]*$/ {
    in_core = 1; in_side = 0
    next
}
/^side_dags:[[:space:]]*$/ {
    in_core = 0; in_side = 1
    next
}
/^[^[:space:]]/ {
    in_core = 0; in_side = 0
}
in_core && /^[[:space:]]+stages:[[:space:]]+[0-9]+/ {
    c = $2 + 0
}
in_core && /^[[:space:]]+width:[[:space:]]+[0-9]+/ {
    w = $2 + 0
}
in_side && /^[[:space:]]+[\-][[:space:]]+id:/ {
    next
}
in_side && /^[[:space:]]+size:[[:space:]]+[0-9]+/ {
    s += $2 + 0
}
END {
    print (in_core ? c * w : 0) + (in_side ? s : 0)
}