#!/usr/bin/env python3
"""Consolidate autofix worktree info per repo."""
import json
import subprocess
from pathlib import Path

REPOS = ["eyetracker", "eventra", "configra", "benchora", "authvault", "quillr"]

# Repo root → list of (worktree_path, branch)
def list_wt(repo_root: str):
    p = subprocess.run(["git", "-C", repo_root, "worktree", "list", "--porcelain"],
                       capture_output=True, text=True, timeout=10)
    if p.returncode != 0:
        return []
    wts, cur = [], {}
    for line in p.stdout.splitlines():
        if line.startswith("worktree "):
            if cur: wts.append(cur); cur = {}
            cur["path"] = line[len("worktree "):]
        elif line.startswith("HEAD "):
            cur["head"] = line[len("HEAD "):]
        elif line.startswith("branch "):
            cur["branch"] = line[len("branch "):]
    if cur: wts.append(cur)
    return wts


def is_autofix(branch: str) -> bool:
    if not branch:
        return False
    b = branch.lower()
    return any(t in b for t in ["ci-red", "ci-fix", "deny-fix", "docs-fix", "fix/ci", "fix/rustfmt", "rust-v2"])


# Map: repo -> list of {path, branch, autofix}
result = {}

# Main clones
for r in REPOS:
    entries = []
    seen = set()
    candidates = [
        fr"C:\Users\koosh\Dev\{r}",
        fr"C:\Users\koosh\pheno\{r}",
        fr"C:\Users\koosh\{r}",
    ]
    for cand in candidates:
        if Path(cand).is_dir():
            for wt in list_wt(cand):
                path = wt["path"]
                # Normalize casing: only add if exact (case-insensitive dedupe)
                key = path.lower().replace("\\", "/")
                if key in seen:
                    continue
                seen.add(key)
                entries.append({
                    "path": path,
                    "branch": wt.get("branch", ""),
                    "head": wt.get("head", ""),
                    "autofix": is_autofix(wt.get("branch", "")),
                })
    result[r] = entries

# authvault-cve-13RjMo (non-git)
result["authvault_cve_13RjMo_snapshot"] = [{
    "path": r"C:\Users\koosh\authvault-cve-13RjMo",
    "branch": "(non-git snapshot)",
    "head": "",
    "autofix": True,
    "note": "loose directory named authvault-cve-13RjMo; not a git worktree",
}]

# Print
print(json.dumps(result, indent=2))
Path(r"C:\Users\koosh\_pr_state\_autofix_worktrees.json").write_text(json.dumps(result, indent=2), encoding="utf-8")