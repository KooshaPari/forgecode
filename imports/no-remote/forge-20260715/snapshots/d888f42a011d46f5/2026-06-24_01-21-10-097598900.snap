name: CI
on:
  push:
    branches: [main, integration/consolidate]
  pull_request:
    branches: [main]

# Tier-0 hygiene: cancel superseded runs on the same ref to save CI minutes
# and reduce pressure on the hosted-runner pool. Matches the pattern used
# by Configra's ci.yml / sbom.yml / deny.yml / trufflehog.yml.
concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: ${{ github.event_name == 'pull_request' }}

jobs:
  ci:
    name: CI
    runs-on: ubuntu-latest
    timeout-minutes: 30
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
      - uses: dtolnay/rust-toolchain@29eef336d9b2848a0b548edc03f92a220660cdb8 # stable
      - uses: Swatinem/rust-cache@779680da715d629b86a86f9a2e2c439d7e8a065a # v2
      - run: cargo check --workspace
      - run: cargo test --workspace
      - run: cargo clippy --workspace -- -D warnings
