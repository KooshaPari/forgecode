#!/bin/bash
nohup bash -c 'CARGO_TARGET_DIR=E:/cargo-target/watch-cli cd /c/Users/koosh/Dev/Civis/.worktrees/wt-watch-cli && cargo clippy -p civ-watch -p civis-cli --all-targets --message-format=short > .clippy_out.txt 2> .clippy_err.txt && echo DONE $? > .clippy_done.txt' </dev/null >/dev/null 2>&1 &