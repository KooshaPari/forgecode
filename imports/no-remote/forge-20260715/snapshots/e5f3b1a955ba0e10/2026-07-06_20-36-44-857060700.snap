$tokens = $null
$errs = $null
[void][System.Management.Automation.Language.Parser]::ParseFile($args[0], [ref]$tokens, [ref]$errs)
if ($errs -and $errs.Count -gt 0) {
    Write-Host "FAIL: $($args[0])"
    foreach ($e in $errs) { Write-Host "  - $e" }
    exit 1
}
Write-Host "OK: $($args[0])"