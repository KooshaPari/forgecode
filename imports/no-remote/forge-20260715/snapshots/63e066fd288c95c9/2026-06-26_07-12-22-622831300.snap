[package]
name = "holocron"
version = "0.1.0"
edition = "2021"
description = "Holocron Keycap UI — verb registry, command palette, context-aware verb ranking for godgame"
license = "MIT OR Apache-2.0"

[lib]
path = "src/lib.rs"

[dependencies]
serde = { version = "1", features = ["derive"] }
serde_json = "1"