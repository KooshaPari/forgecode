import json

d = json.load(open('docs/audits/fr-matrix.json', encoding='utf-8'))
rows = d['rows']
total = len(rows)
spec_only = sum(1 for r in rows if r.get('status') == 'SPEC-ONLY')
spec_only_tc = sum(1 for r in rows if r.get('status') == 'SPEC-ONLY' and r.get('test_refs') and not r.get('code_refs'))
covered = sum(1 for r in rows if r.get('status') == 'COVERED')
other = total - covered - spec_only

print(f'Total: {total}')
print(f'COVERED: {covered}')
print(f'SPEC-ONLY: {spec_only}')
print(f'  with tests+no code: {spec_only_tc}')
print(f'Other: {other}')
print(f'Coverage: {100 * covered // total}%')
