import v8 from "node:v8";
import fs from "node:fs";
import os from "node:os";
import path from "node:path";
const p = path.join(os.tmpdir(), "heap-test3.heapsnapshot");
v8.writeHeapSnapshot(p);
const raw = fs.readFileSync(p, "utf8");
const meta = { x: 1, capturedAt: "2026-06-25T16:00:00Z", label: null };
const metaJson = JSON.stringify(meta);
const wrapped = `{"snapshot":${raw},"meta_data":${metaJson},"trace_function_info_flags":{}}`;
fs.writeFileSync(p, wrapped);
const buf = Buffer.alloc(128);
const fd = fs.openSync(p, "r");
fs.readSync(fd, buf, 0, 128, 0);
fs.closeSync(fd);
const head = buf.toString("utf8");
console.log("first 128 bytes:");
console.log(head);
console.log("---");
console.log('contains snapshot:', head.includes('"snapshot"'));
console.log('contains meta_data:', head.includes('"meta_data"'));
console.log('starts with {:', head.startsWith("{"));
fs.unlinkSync(p);

