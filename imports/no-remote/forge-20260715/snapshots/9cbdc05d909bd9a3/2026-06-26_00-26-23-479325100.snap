import v8 from "node:v8";
import fs from "node:fs";
import os from "node:os";
import path from "node:path";
const p = path.join(os.tmpdir(), "heap-test2.heapsnapshot");
v8.writeHeapSnapshot(p);
const raw = fs.readFileSync(p, "utf8");
const wrapped = { meta_data: { x: 1, capturedAt: "2026-06-25T16:00:00Z", label: null, heapUsedMb: 50, heapTotalMb: 100, heapSizeLimitMb: 4096, nodeVersion: process.version, pid: 1, platform: process.platform }, trace_function_info_flags: {}, snapshot: JSON.parse(raw) };
fs.writeFileSync(p, JSON.stringify(wrapped));
const buf = Buffer.alloc(256);
const fd = fs.openSync(p, "r");
fs.readSync(fd, buf, 0, 256, 0);
fs.closeSync(fd);
const head = buf.toString("utf8");
console.log("first 256 bytes:");
console.log(head);
console.log("---");
console.log('contains snapshot:', head.includes('"snapshot"'));
console.log('contains meta_data:', head.includes('"meta_data"'));
console.log('size:', fs.statSync(p).size);
fs.unlinkSync(p);
