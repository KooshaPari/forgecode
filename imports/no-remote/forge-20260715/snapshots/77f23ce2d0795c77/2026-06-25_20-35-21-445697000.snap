const T0 = "import { describe, it, expect } from \"vitest\";\nimport {\n  getSkillsProviderForFormat,\n  getSkillsModelIdForFormat,\n  type SkillsProviderLabel,\n} from \"../formatSkillsHelpers.ts\";\n\ndescribe(\"getSkillsProviderForFormat\", () => {\n  it(\"maps CLAUDE to anthropic\", () => {\n    expect(getSkillsProviderForFormat(\"CLAUDE\")).toBe(\"anthropic\");\n  });\n  it(\"maps GEMINI to google\", () => {\n    expect(getSkillsProviderForFormat(\"GEMINI\")).toBe(\"google\");\n  });\n  it(\"defaults to openai for OPENAI\", () => {\n    expect(getSkillsProviderForFormat(\"OPENAI\")).toBe(\"openai\");\n  });\n  it(\"defaults to openai for unknown\", () => {\n    expect(getSkillsProviderForFormat(\"WATSON\")).toBe(\"openai\");\n  });\n  it(\"defaults to openai for empty\", () => {\n    expect(getSkillsProviderForFormat(\"\")).toBe(\"openai\");\n  });\n  it(\"is case-sensitive\", () => {\n    expect(getSkillsProviderForFormat(\"claude\")).toBe(\"openai\");\n  });\n});\n\ndescribe(\"getSkillsModelIdForFormat\", () => {\n  it(\"maps CLAUDE to claude\", () => {\n    expect(getSkillsModelIdForFormat(\"CLAUDE\")).toBe(\"claude\");\n  });\n  it(\"maps GEMINI to gemini\", () => {\n    expect(getSkillsModelIdForFormat(\"GEMINI\")).toBe(\"gemini\");\n  });\n  it(\"defaults to openai for OPENAI\", () => {\n    expect(getSkillsModelIdForFormat(\"OPENAI\")).toBe(\"openai\");\n  });\n  it(\"defaults to openai for unknown\", () => {\n    expect(getSkillsModelIdForFormat(\"WATSON\")).toBe(\"openai\");\n  });\n});\n\ndescribe(\"SkillsProviderLabel type\", () => {\n  it(\"accepts the documented provider labels\", () => {\n    const anthropic: SkillsProviderLabel = \"anthropic\";\n    const google: SkillsProviderLabel = \"google\";\n    const openai: SkillsProviderLabel = \"openai\";\n    expect([anthropic, google, openai]).toEqual([\"anthropic\", \"google\", \"openai\"]);\n  });\n});\n\ndescribe(\"provider/model pair consistency\", () => {\n  it(\"claude/anthropic pair\", () => {\n    expect(getSkillsModelIdForFormat(\"CLAUDE\")).toBe(\"claude\");\n    expect(getSkillsProviderForFormat(\"CLAUDE\")).toBe(\"anthropic\");\n  });\n  it(\"gemini/google pair\", () => {\n    expect(getSkillsModelIdForFormat(\"GEMINI\")).toBe(\"gemini\");\n    expect(getSkillsProviderForFormat(\"GEMINI\")).toBe(\"google\");\n  });\n});\n";
const P0 = "C:\\Users\\koosh\\OmniRoute-upstream\\open-sse\\handlers\\chatCore\\__tests__\\formatSkillsHelpers.test.ts";
