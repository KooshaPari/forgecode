[package]
name = "phenotype-types"
version = "0.1.0"
edition = "2021"
license = "MIT"
authors = ["Koosha Pari"]
description = "Shared type definitions across the Phenotype ecosystem — OCI instance records, path helpers, and canonical data models used by compute/infra agents."

[dependencies]
serde = { workspace = false, version = "1", features = ["derive"] }
serde_json = { workspace = false, version = "1" }
anyhow = { workspace = false, version = "1" }
chrono = { workspace = false, version = "0.4", features = ["serde"] }
tokio = { workspace = false, version = "1", features = ["fs"] }
