[package]
name = "kvirtual"
version = "0.1.0"
edition = "2021"
description = "Desktop automation CLI (kvd) — absorbed from _tmp_kvirtualstage/kvirtualdesktop"
license = "MIT OR Apache-2.0"
repository = "https://github.com/KooshaPari/phenotype-infra"
publish = false

[[bin]]
name = "kvd"
path = "src/main.rs"

[features]
default = []
full = ["desktop", "container", "vm", "record", "tui"]
desktop = ["dep:autopilot-fs", "dep:screenshots", "dep:image"]
container = ["dep:bollard"]
vm = ["dep:libvirt"]
record = ["dep:ffmpeg-next", "dep:rodio"]
tui = ["dep:crossterm", "dep:ratatui", "dep:dialoguer", "dep:indicatif"]

[dependencies]
# Core
clap = { version = "4", features = ["derive", "cargo"] }
tokio = { workspace = true, features = ["full"] }
serde = { workspace = true, features = ["derive"] }
serde_json = { workspace = true }
anyhow = { workspace = true }
thiserror = { workspace = true }
async-trait = { workspace = true }
futures = { workspace = true }

# Configuration
toml = "0.8"
dirs = "5"
uuid = { workspace = true, features = ["v4"] }
chrono = { workspace = true, features = ["serde"] }

# Logging
tracing = { workspace = true }
tracing-subscriber = { workspace = true }

# Optional — desktop automation (stub wrappers)
autopilot-fs = { version = "0.1", optional = true }
screenshots = { version = "0.4", optional = true }
image = { version = "0.24", optional = true }

# Optional — container/VM
bollard = { version = "0.14", optional = true }
libvirt = { version = "0.1", optional = true }

# Optional — recording
ffmpeg-next = { version = "6.0", optional = true }
rodio = { version = "0.17", optional = true }

# Optional — TUI
crossterm = { version = "0.27", optional = true }
ratatui = { version = "0.24", optional = true }
dialoguer = { version = "0.11", optional = true }
indicatif = { version = "0.17", optional = true }

# Credential management
credential-manager = { path = "../credential-manager", optional = true }

[dev-dependencies]
tempfile = "3"
