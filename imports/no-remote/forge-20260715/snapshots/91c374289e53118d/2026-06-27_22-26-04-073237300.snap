# ================ ANALYSIS ================

now = datetime.datetime(2026, 6, 27, 7, 0, 0, tzinfo=datetime.timezone.utc)

THRESHOLDS = {
    "wip": 14, "recover": 7, "dependabot": 14, "feature": 21,
    "fix": 21, "chore": 21, "ci": 14, "docs": 21,
    "audit-review": 14, "main": 0, "epic": 21
}


def categorize(name, age_days):
    if name == "main":
        return "main", "active", "keep"
    if name.startswith("wip/"):
        return "wip", ("stale" if age_days > 14 else "active"), "recover-or-delete"
    if name.startswith("recover/") or name.startswith("reconcile/"):
        return "recover", ("stale" if age_days > 7 else "active"), "review-and-merge-or-delete"
    if name.startswith("dependabot/"):
        return "dependabot", ("stale" if age_days > 14 else "active"), "merge-or-close"
    if name.startswith("fix/") or name.startswith("cve-"):
        return "fix", ("stale" if age_days > 21 else "active"), "review-and-merge"
    if name.startswith("chore/"):
        return "chore", ("stale" if age_days > 21 else "active"), "review-and-merge"
    if name.startswith("ci/"):
        return "ci", ("stale" if age_days > 14 else "active"), "review-and-merge"
    if name.startswith("docs/") or name.startswith("docs-"):
        return "docs", ("stale" if age_days > 21 else "active"), "review-and-merge"
    if name.startswith("audit/") or name.startswith("review/") or name.startswith("consolidate/"):
        return "audit-review", ("stale" if age_days > 14 else "active"), "review-and-close"
    if name.startswith("epic/") or name.startswith("epic-") or name.startswith("feat/"):
        return "feature", ("stale" if age_days > 21 else "active"), "active-development"
    if name.startswith("B34-") or name.startswith("B34/"):
        return "feature", ("stale" if age_days > 21 else "active"), "active-development"
    if name.startswith("bp-dag"):
        return "feature", ("stale" if age_days > 14 else "active"), "active-development"
    prefix = name.split("/")[0] if "/" in name else "other"
    return prefix, ("stale" if age_days > 30 else "active"), "review"


# Build branch entries
report_branches = []
for b in BRANCHES:
    name = b["name"]
    sha = b["sha"]
    date_str = SHA_DATES.get(sha, "")
    age_days = -1
    if date_str:
        dt = datetime.datetime.fromisoformat(date_str.replace("Z", "+00:00"))
        age_days = (now - dt).days

    cat, status, action = categorize(name, age_days)
    pr_info = OPEN_PRS.get(name, None)

    report_branches.append({
        "name": name,
        "sha": sha,
        "last_commit_date": date_str or None,
        "age_days": age_days,
        "category": cat,
        "status": status,
        "recommended_action": action,
        "has_open_pr": pr_info is not None,
        "pr_number": pr_info["number"] if pr_info else None,
        "pr_state": pr_info["state"] if pr_info else None,
        "pr_draft": pr_info.get("draft", False) if pr_info else None,
        "protected": b["protected"],
        "staleness_threshold_days": THRESHOLDS.get(cat, 30)
    })

# Aggregate categories
cats = {}
for r in report_branches:
    c = r["category"]
    cats.setdefault(c, {"total": 0, "stale": 0, "active": 0, "with_pr": 0})
    cats[c]["total"] += 1
    if r["status"] == "stale":
        cats[c]["stale"] += 1
    else:
        cats[c]["active"] += 1
    if r["has_open_pr"]:
        cats[c]["with_pr"] += 1

stale_total = sum(1 for r in report_branches if r["status"] == "stale")
active_total = sum(1 for r in report_branches if r["status"] == "active")
with_pr = sum(1 for r in report_branches if r["has_open_pr"])

# Find stale branches that are very old (>30 days)
very_stale = [r for r in report_branches if r["age_days"] > 30]

report = {
    "report_metadata": {
        "dag_unit": "A11",
        "title": "byteport-pool: Branch audit",
        "phase": "Phase 1",
        "pool": "byteport-pool",
        "repo": "KooshaPari/BytePort",
        "analysis_date": "2026-06-27T07:00:00Z",
        "data_source": "GitHub API (gh api repos/KooshaPari/BytePort/branches --paginate)",
        "staleness_threshold_days": THRESHOLDS,
        "total_branches_fetched": len(report_branches),
        "unique_commits_checked": len(SHA_DATES)
    },
    "executive_summary": {
        "total_branches": len(report_branches),
        "active_branches": active_total,
        "stale_branches": stale_total,
        "stale_percentage": round(stale_total / len(report_branches) * 100, 1),
        "branches_with_open_prs": with_pr,
        "protected_branches": 1,
        "wip_branches": 2,
        "recover_branches": 4,
        "dependabot_branches": 3
    },
    "categories": cats,
    "stale_branches": sorted(
        [r for r in report_branches if r["status"] == "stale"],
        key=lambda x: x["age_days"], reverse=True
    ),
    "active_branches_excluding_main": sorted(
        [r for r in report_branches if r["status"] == "active" and r["name"] != "main"],
        key=lambda x: x["name"]
    ),
    "protected_branches": [r for r in report_branches if r["protected"]],
    "wip_recover_branches": sorted(
        [r for r in report_branches if r["category"] in ("wip", "recover")],
        key=lambda x: x["name"]
    ),
    "very_stale_branches_over_30d": sorted(
        very_stale, key=lambda x: x["age_days"], reverse=True
    ),
    "all_branches": sorted(report_branches, key=lambda x: x["name"]),
    "findings": [
        {
            "id": "F1",
