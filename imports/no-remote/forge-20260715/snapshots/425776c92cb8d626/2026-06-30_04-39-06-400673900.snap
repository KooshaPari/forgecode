{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "noEmit": true,
    "allowJs": false,
    "noResolve": true,
    "noLib": true,
    "types": [],
    "paths": {}
  },
  "files": [
    "open-sse/config/providers/registry/clinepass/index.ts"
  ]
}
