{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": "..",
    "paths": {
      "../../shared.ts": ["./_typecheck_tmp/shared_stub.ts"]
    }
  },
  "files": [
    "./shared_stub-for-clinepass.ts",
    "../open-sse/config/providers/registry/clinepass/index.ts"
  ]
}
