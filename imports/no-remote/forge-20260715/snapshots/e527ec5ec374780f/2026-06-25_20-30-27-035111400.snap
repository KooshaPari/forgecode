@echo off
powershell -NoProfile -Command "Set-Location 'C:\Users\koosh\phenotype-infra'; $env:CARGO_TERM_COLOR='never'; $proc = Start-Process -FilePath 'cargo' -ArgumentList 'generate-lockfile' -NoNewWindow -PassThru -RedirectStandardOutput 'C:\Users\koosh\_gen_lock_stdout.txt' -RedirectStandardError 'C:\Users\koosh\_gen_lock_stderr.txt'; Write-Host ('Started PID ' + $proc.Id); $proc | Wait-Process -Timeout 60; if (-not $proc.HasExited) { Write-Host 'TIMEOUT'; $proc | Stop-Process -Force } else { Write-Host ('Exited ' + $proc.ExitCode) }; Write-Host ('STDOUT=' + (Get-Item 'C:\Users\koosh\_gen_lock_stdout.txt').Length); Write-Host ('STDERR=' + (Get-Item 'C:\Users\koosh\_gen_lock_stderr.txt').Length)"