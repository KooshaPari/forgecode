[package]
name = "eyetracker-inference"
version = "0.1.0-alpha"
edition = "2021"
description = "ML inference pipeline for eye tracking"

[dependencies]
eyetracker-domain = { path = "../eyetracker-domain" }
eyetracker-camera = { path = "../eyetracker-camera" }
anyhow = "1"
bincode = "1"
dirs = "5"
image = "0.25"
nalgebra = "0.33"
serde = { workspace = true }
serde_json = "1"
tracing = "0.1"
thiserror = { workspace = true }

[target.'cfg(target_os = "macos")'.dependencies]
core-graphics = "0.23"

[dev-dependencies]
bincode = "1"
serde_json = "1"
tempfile = "3"

[lib]
name = "eyetracker_inference"
path = "src/lib.rs"
