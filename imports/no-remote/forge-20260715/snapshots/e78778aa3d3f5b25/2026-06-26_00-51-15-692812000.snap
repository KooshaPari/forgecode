// src/discovery/index.ts — discovery route surface.
// Implements docs/research/DISCOVERY_TOOL_DESIGN.md

import { Hono } from "hono";
import { runDiscovery } from "./providers.ts";

export const discovery = new Hono();

discovery.get("/providers", async (c) => {
  const report = await runDiscovery();
  return c.json(report);
});

discovery.post("/scan", async (c) => {
  // Force a fresh scan (clears any 5-min cache)
  const report = await runDiscovery();
  return c.json(report);
});
