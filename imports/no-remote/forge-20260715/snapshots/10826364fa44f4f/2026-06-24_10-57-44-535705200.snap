---
// Project landing page — generated from landing.json config
// Self-contained: no external component dependencies

import config from '../../data/config.json';

const { name, slug, domain, description, tier, repo, language, license, status, features, links } = config;

// Derive a tagline from the description (first sentence)
const tagline = description?.split('.')[0] + '.' || `${name} — Phenotype ecosystem project`;

// Build sections from flat config
const brand = { name, tagline, domain };
const hero = { title: name, subtitle: tagline, cta: { text: 'Get Started', href: links?.github || `https://github.com/${repo}` } };
const featureSection = { title: 'Features', items: features?.map((f: string) => ({ title: f, description: '' })) || [] };
const ctaSection = { title: `Explore ${name}`, actions: [
  { text: 'GitHub', href: links?.github || `https://github.com/${repo}` },
  { text: 'Docs', href: links?.docs || `https://${domain}/docs` },
  { text: 'Releases', href: links?.releases || `https://github.com/${repo}/releases` }
] };
const footer = { brand: name, repo: repo, year: 2026 };
const header = { brand: name, nav: [
  { label: 'Home', href: '/' },
  { label: 'GitHub', href: links?.github || `https://github.com/${repo}` },
  { label: 'Docs', href: links?.docs || `https://${domain}/docs` }
] };
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{brand.name}</title>
  <meta name="description" content={brand.tagline}>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
</head>
<body class="bg-slate-950 text-slate-100">
  <!-- Header -->
  <header class="border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="text-xl font-bold tracking-tight">{header.brand}</a>
      <nav class="flex gap-6">
        {header.nav.map((item) => (
          <a href={item.href} class="text-sm text-slate-400 hover:text-white transition-colors">{item.label}</a>
        ))}
      </nav>
    </div>
  </header>

  <!-- Hero -->
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-5xl font-bold tracking-tight mb-6">{hero.title}</h1>
      <p class="text-xl text-slate-400 mb-10 max-w-2xl mx-auto">{hero.subtitle}</p>
      <a href={hero.cta.href} class="inline-flex items-center gap-2 bg-slate-100 text-slate-900 px-6 py-3 rounded-lg font-semibold hover:bg-white transition-colors">
        {hero.cta.text}
      </a>
      <div class="mt-6 flex items-center justify-center gap-4 text-sm text-slate-500">
        <span>{language}</span>
        <span class="text-slate-700">|</span>
        <span>{license}</span>
        <span class="text-slate-700">|</span>
        <span class="text-emerald-400">{status}</span>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 px-6 border-t border-slate-800">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold mb-12 text-center">{featureSection.title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featureSection.items.map((item, index) => (
          <div class="p-6 rounded-xl border border-slate-800 bg-slate-900/50">
            <div class="w-10 h-10 rounded-lg bg-slate-800 flex items-center justify-center mb-4 text-slate-300 font-mono text-sm">
              {String(index + 1).padStart(2, '0')}
            </div>
            <h3 class="text-lg font-semibold mb-2">{item.title}</h3>
            {item.description && <p class="text-sm text-slate-400">{item.description}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6 border-t border-slate-800">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-6">{ctaSection.title}</h2>
      <div class="flex flex-wrap items-center justify-center gap-4">
        {ctaSection.actions.map((action) => (
          <a href={action.href} class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold border border-slate-700 hover:border-slate-500 transition-colors">
            {action.text}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-12 px-6 border-t border-slate-800">
    <div class="max-w-6xl mx-auto flex items-center justify-between text-sm text-slate-500">
      <span>{footer.brand} &copy; {footer.year}</span>
      <a href={`https://github.com/${footer.repo}`} class="hover:text-slate-300 transition-colors">{footer.repo}</a>
    </div>
  </footer>
</body>
</html>
