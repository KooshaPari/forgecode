---
// Project landing page — generated from landing.json config
// Self-contained: no external component dependencies

import config from '../../data/config.json';

const { name, slug, domain, description, tier, repo, language, license, status, features, links } = config;

// Derive a tagline from the description (first sentence)
const tagline = description?.split('.')[0] + '.' || `${name} — Phenotype ecosystem project`;

// Build sections from flat config
const brand = { name, tagline, domain };
const hero = { title: name, subtitle: tagline, cta: { text: 'Get Started', href: links?.github || `https://github.com/${repo}` } };
const featureSection = { title: 'Features', items: features?.map((f: string) => ({ title: f, description: '' })) || [] };
const ctaSection = { title: `Explore ${name}`, actions: [
  { text: 'GitHub', href: links?.github || `https://github.com/${repo}` },
  { text: 'Docs', href: links?.docs || `https://${domain}/docs` },
  { text: 'Releases', href: links?.releases || `https://github.com/${repo}/releases` }
] };
const footer = { brand: name, repo: repo, year: 2026 };
const header = { brand: name, nav: [
  { label: 'Home', href: '/' },
  { label: 'GitHub', href: links?.github || `https://github.com/${repo}` },
  { label: 'Docs', href: links?.docs || `https://${domain}/docs` }
] };
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{brand.name}</title>
  <meta name="description" content={brand.tagline}>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700&family=JetBrains+Mono:wght@400;500&family=Montserrat:wght@500;600;700&display=swap"
  >
</head>
<body class="bg-app text-fg">
  <!-- Header -->
  <header class="border-b border-app divider">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="text-xl font-bold tracking-tight text-fg">{header.brand}</a>
      <nav class="flex gap-6">
        {header.nav.map((item) => (
          <a href={item.href} class="text-sm text-muted hover:text-primary transition-colors">{item.label}</a>
        ))}
      </nav>
    </div>
  </header>

  <!-- Hero -->
  <section class="py-24 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="display text-5xl font-bold tracking-tight mb-6 text-fg">{hero.title}</h1>
      <p class="text-xl text-muted mb-10 max-w-2xl mx-auto">{hero.subtitle}</p>
      <a href={hero.cta.href} class="btn-primary">
        {hero.cta.text}
      </a>
      <div class="mt-6 flex items-center justify-center gap-4 text-sm text-dim">
        <span class="text-dim">{language}</span>
        <span aria-hidden="true" class="text-dim">|</span>
        <span class="text-dim">{license}</span>
        <span aria-hidden="true" class="text-dim">|</span>
        <span class="text-primary">{status}</span>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-20 px-6 border-t border-app divider">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold mb-12 text-center text-fg">{featureSection.title}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featureSection.items.map((item, index) => (
          <div class="p-6 rounded-xl surface-card">
            <div class="w-10 h-10 rounded-lg surface-strong flex items-center justify-center mb-4 text-muted mono text-sm">
              {String(index + 1).padStart(2, '0')}
            </div>
            <h3 class="text-lg font-semibold mb-2 text-fg">{item.title}</h3>
            {item.description && <p class="text-sm text-muted">{item.description}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6 border-t border-app divider">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-6 text-fg">{ctaSection.title}</h2>
      <div class="flex flex-wrap items-center justify-center gap-4">
        {ctaSection.actions.map((action) => (
          <a href={action.href} class="btn-secondary">
            {action.text}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-12 px-6 border-t border-app divider">
    <div class="max-w-6xl mx-auto flex items-center justify-between text-sm text-dim">
      <span>{footer.brand} &copy; {footer.year}</span>
      <a href={`https://github.com/${footer.repo}`} class="hover:text-primary transition-colors">{footer.repo}</a>
    </div>
  </footer>
</body>
</html>
