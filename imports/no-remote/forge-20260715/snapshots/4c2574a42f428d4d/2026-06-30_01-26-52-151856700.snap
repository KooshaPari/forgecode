[package]
name = "pheno-dag"
version = "0.1.0"
edition = "2021"
license = "Apache-2.0"
description = "Reusable DAG unit abstraction: DagUnit lifecycle, YAML executor, and automation gates for Phenotype epics"
publish = false

[dependencies]
byteport-dag = { path = "../byteport-dag" }
serde = { version = "1", features = ["derive"] }
serde_yaml = "0.9"
serde_json = "1"
thiserror = "2.0"
uuid = { version = "1", features = ["v4"] }
chrono = { version = "0.4", features = ["serde"] }
