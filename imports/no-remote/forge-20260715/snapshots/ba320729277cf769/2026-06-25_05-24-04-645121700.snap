{
  "name": "appgeneric",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.jsx",
    "format": "prettier --write \"**/*.+(js|jsx|json)\"",
    "format:check": "prettier --check \"**/*.+(js|jsx|json)\"",
    "test": "vitest run",
    "legacy-tooling:scan": "python3 tools/legacy-enforcement/scanner/legacy_tooling_scanner.py --repo-root . --policy tools/legacy-enforcement/policy/rules.yaml --output-json legacy_tooling_report.json --output-md legacy_tooling_report.md"
  },
  "dependencies": {
    "@pchmn/expo-material3-theme": "^1.3.1",
    "@react-native-community/masked-view": "^0.1.11",
    "@react-native-masked-view/masked-view": "0.2.9",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^6.9.17",
    "@react-navigation/stack": "^6.3.20",
    "expo": "~56.0.8",
    "expo-linear-gradient": "~56.0.4",
    "expo-splash-screen": "~0.20.5",
    "expo-status-bar": "~1.6.0",
    "hermes-engine": "^0.11.0",
    "react": "18.2.0",
    "react-native": "0.85.2",
    "react-native-gesture-handler": "~3.0.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-paper": "^5.11.3",
    "react-native-reanimated": "~3.3.0",
    "react-native-safe-area-context": "4.6.3",
    "react-native-screens": "~4.25.2",
    "react-native-splash-screen": "^3.3.0",
    "react-native-svg": "15.15.4",
    "react-native-vector-icons": "^10.0.2",
    "@gorhom/bottom-sheet": "^4.6.4"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/eslint-parser": "^7.23.3",
    "@react-native-community/eslint-config": "^3.2.0",
    "@types/node": "^25.9.1",
    "concurrently": "^8.2.2",
    "eslint": "^9.26.0",
    "eslint-plugin-react": "^7.33.2",
    "postcss": "^8.5.13",
    "prettier": "^3.1.0",
    "react-native-svg-transformer": "^1.1.0",
    "vitest": "^4.1.5"
  },
  "private": true
}
