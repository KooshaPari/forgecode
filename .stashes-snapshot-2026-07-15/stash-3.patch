[32m+[m[32m        self.enabled = enabled;[m
[32m+[m[32m    }[m
[32m+[m
[32m+[m[32m    /// Check if summarization is enabled (regardless of strategy)[m
[32m+[m[32m    pub fn is_enabled(&self) -> bool {[m
