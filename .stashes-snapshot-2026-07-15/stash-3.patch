[32m+[m[32m    }[m
[32m+[m
[32m+[m[32m    /// Generate a summary using the configured strategy.[m
[32m+[m[32m    ///[m
[32m+[m[32m    /// Returns the summary text, or an error if summarization fails.[m
[32m+[m[32m    pub async fn generate_summary<S: ProviderService>([m
[32m+[m[32m        &self,[m
[32m+[m[32m        context_summary: &ContextSummary,[m
