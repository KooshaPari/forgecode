[32m+[m[32m    }[m
[32m+[m
[32m+[m[32m    /// Get total messages saved[m
[32m+[m[32m    pub fn total_messages_saved(&self) -> usize {[m
[32m+[m[32m        self.total_messages_saved[m
[32m+[m[32m    }[m
[32m+[m
[32m+[m[32m    /// Get count by strategy[m
