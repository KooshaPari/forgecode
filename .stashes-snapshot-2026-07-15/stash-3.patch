[32m+[m[32m        }[m
[32m+[m[32m        let successes = self.events.len() - self.failure_count;[m
[32m+[m[32m        successes as f64 / self.events.len() as f64[m
[32m+[m[32m    }[m
[32m+[m
[32m+[m[32m    /// Get average token reduction percentage[m
[32m+[m[32m    pub fn avg_reduction_percent(&self) -> f64 {[m
[32m+[m[32m        if self.events.is_empty() {[m
[32m+[m[32m            return 0.0;[m
[32m+[m[32m        }[m
