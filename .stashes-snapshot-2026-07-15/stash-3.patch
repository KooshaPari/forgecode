[32m+[m[32m        sum / self.events.len() as f64[m
[32m+[m[32m    }[m
[32m+[m
[32m+[m[32m    /// Get average compaction duration in milliseconds[m
[32m+[m[32m    pub fn avg_duration_ms(&self) -> f64 {[m
[32m+[m[32m        if self.events.is_empty() {[m
[32m+[m[32m            return 0.0;[m
[32m+[m[32m        }[m
