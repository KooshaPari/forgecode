[32m+[m
[32m+[m[32m    /// Generate a summary using template-based extraction.[m
[32m+[m[32m    fn generate_template_summary(&self, context_summary: &ContextSummary) -> anyhow::Result<String> {[m
[32m+[m[32m        self.template_engine.render([m
[32m+[m[32m            "forge-partial-summary-frame.md",[m
[32m+[m[32m            &serde_json::json!({"messages": context_summary.messages}),[m
[32m+[m[32m        )[m
[32m+[m[32m    }[m
[32m+[m
[32m+[m[32m    /// Generate a summary using LLM.[m
[32m+[m[32m    async fn generate_llm_summary<S: ProviderService>([m
[32m+[m[32m        &self,[m
[32m+[m[32m        context_summary: &ContextSummary,[m
[32m+[m[32m        services: &S,[m
[32m+[m[32m        provider: Provider<Url>,[m
[32m+[m[32m    ) -> anyhow::Result<String> {[m
[32m+[m[32m        if !self.enabled {[m
[32m+[m[32m            return self.generate_template_summary(context_summary);[m
[32m+[m[32m        }[m
[32m+[m
[32m+[m[32m        let model_id = self[m
[32m+[m[32m            .compact[m
[32m+[m[32m            .summary_model[m
[32m+[m[32m            .clone()[m
[32m+[m[32m            .unwrap_or_else(|| ModelId::new("claude-sonnet-4-20250514"));[m
[32m+[m
[32m+[m[32m        info!([m
[32m+[m[32m            model = %model_id,[m
[32m+[m[32m            timeout_secs = self.timeout.as_secs(),[m
[32m+[m[32m            "Generating LLM summary"[m
[32m+[m[32m        );[m
[32m+[m
[32m+[m[32m        // Build the prompt[m
[32m+[m[32m        let prompt = self.build_summarization_prompt(context_summary);[m
[32m+[m
[32m+[m[32m        // Create a minimal context with just the prompt[m
[32m+[m[32m        let prompt_context = Context::default()[m
[32m+[m[32m            .add_message(ContextMessage::user(prompt, None));[m
[32m+[m
[32m+[m[32m        // Make the LLM call with timeout[m
[32m+[m[32m        let summary = tokio::time::timeout([m
[32m+[m[32m            self.timeout,[m
[32m+[m[32m            services.chat(&model_id, prompt_context, provider),[m
[32m+[m[32m        )[m
[32m+[m[32m        .await[m
[32m+[m[32m        .with_context(|| "LLM summarization timed out")?[m
[32m+[m[32m        .with_context(|| "LLM summarization failed")?;[m
[32m+[m
[32m+[m[32m        // Extract the text content from the response[m
[32m+[m[32m        let summary_message = summary.into_full(false).await?;[m
[32m+[m[32m        let summary_text = summary_message.content.as_str().to_string();[m
[32m+[m
[32m+[m[32m        info!([m
[32m+[m[32m            summary_tokens = context_summary.messages.len(),[m
[32m+[m[32m            "Generated LLM summary successfully"[m
[32m+[m[32m        );[m
[32m+[m
[32m+[m[32m        Ok(summary_text)[m
[32m+[m[32m    }[m
[32m+[m
[32m+[m[32m    /// Build the summarization prompt from the context summary.[m
[32m+[m[32m    fn build_summarization_prompt(&self, context_summary: &ContextSummary) -> String {[m
[32m+[m[32m        // Choose template based on available space[m
[32m+[m[32m        let template_name = if self.compact.summary_max_tokens.unwrap_or(500) <= 200 {[m
[32m+[m[32m            "forge-summarization-prompt-compact.md"[m
[32m+[m[32m        } else {[m
[32m+[m[32m            "forge-summarization-prompt.md"[m
[32m+[m[32m        };[m
[32m+[m
[32m+[m[32m        match self.template_engine.render([m
[32m+[m[32m            template_name,[m
[32m+[m[32m            &serde_json::json!({"messages": context_summary.messages}),[m
[32m+[m[32m        ) {[m
[32m+[m[32m            Ok(prompt) => prompt,[m
[32m+[m[32m            Err(e) => {[m
[32m+[m[32m                // Fallback to a simple prompt[m
[32m+[m[32m                warn!("Failed to render summarization template: {}", e);[m
[32m+[m[32m                format!([m
[32m+[m[32m                    "Summarize the following conversation in 200 tokens or less:\n\n{}",[m
[32m+[m[32m                    context_summary[m
[32m+[m[32m                        .messages[m
[32m+[m[32m                        .iter()[m
[32m+[m[32m                        .take(10)[m
[32m+[m[32m                        .map(|m| format!("{:?}: {:?}", m.role, m.contents))[m
[32m+[m[32m                        .collect::<Vec<_>>()[m
[32m+[m[32m                        .join("\n")[m
[32m+[m[32m                )[m
[32m+[m[32m            }[m
[32m+[m[32m        }[m
[32m+[m[32m    }[m
[32m+[m[32m}[m
[32m+[m
[32m+[m[32m/// Extension trait for Compact to add summarization strategy checks[m
[32m+[m[32mpub trait SummarizationStrategyExt {[m
