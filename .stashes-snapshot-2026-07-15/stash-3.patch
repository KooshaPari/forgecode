[32m+[m[32m                // Try LLM first, fall back to template on error[m
[32m+[m[32m                match self.generate_llm_summary(context_summary, services, provider).await {[m
[32m+[m[32m                    Ok(summary) => Ok(summary),[m
[32m+[m[32m                    Err(e) => {[m
[32m+[m[32m                        warn!("LLM summarization failed, falling back to template: {}", e);[m
[32m+[m[32m                        self.generate_template_summary(context_summary)[m
[32m+[m[32m                    }[m
[32m+[m[32m                }[m
[32m+[m[32m            }[m
